{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "lifestyle-app",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_date": "2026-03-17",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
		"enabled": true
	}
}