---
interface Props {
  title?: string;
  subtitle?: string;
  padding?: boolean;
}

const {
  title = "",
  subtitle = "",
  padding = true,
} = Astro.props;
---

<article class:list={["note-card", padding && "note-card-padded"]}>
  {(title || subtitle) && (
    <div class="note-card-header">
      <div class="note-card-heading">
        {title && <h2 class="section-title">{title}</h2>}
        {subtitle && <p class="section-subtitle">{subtitle}</p>}
      </div>
      <slot name="header-actions" />
    </div>
  )}

  <div class="note-card-body">
    <slot />
  </div>
</article>

<style>
  .note-card {
    width: 100%;
    border-radius: var(--radius);
    border: 1px solid var(--border-soft);
    box-shadow: var(--card-shadow);
    color: var(--text-main);

    background: var(--resolved-section-color);
  }

  .note-card-padded {
    padding: 1rem;
  }

  .note-card-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.85rem;
  }

  .note-card-heading {
    min-width: 0;
  }

  .note-card-body {
    display: block;
  }
</style>