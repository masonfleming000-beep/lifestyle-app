---
/**
 * Expandable section card component.
 * Wraps content inside a collapsible details/summary layout,
 * useful for organizing longer sections into compact panels.
 */
interface Props {
  title: string;
  subtitle?: string;
  open?: boolean;
}

const { title, subtitle = "", open = false } = Astro.props;
---

<details class="section-card surface-section" open={open}>
  <summary class="section-card-summary">
    <div class="section-card-header">
      <h2 class="section-title">{title}</h2>
      {subtitle && <p class="section-subtitle">{subtitle}</p>}
    </div>
    <span class="section-card-icon">+</span>
  </summary>

  <div class="section-card-body">
    <slot />
  </div>
</details>

<style>
  .section-card {
    width: 100%;
    border-radius: 20px;
    background: var(--section-card-surface-color);
    border: 1px solid var(--border-soft);
    box-shadow: var(--card-shadow);
    overflow: visible;
  }

  .section-card-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.2rem;
    border-radius: 20px 20px 0 0;
    transition: background 0.18s ease;
  }

  .section-card-summary::-webkit-details-marker {
    display: none;
  }

  .section-card-summary:hover {
    background: color-mix(in srgb, var(--section-card-surface-color) 90%, var(--resolved-header-color));
  }

  .section-card-header {
    display: grid;
    gap: 0.25rem;
    min-width: 0;
  }

  .section-title {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-main);
  }

  .section-subtitle {
    margin: 0;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .section-card-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    display: grid;
    place-items: center;
    background: var(--pill-bg);
    color: var(--text-main);
    font-size: 1.15rem;
    font-weight: 700;
    flex: 0 0 auto;
    transition: transform 0.2s ease;
  }

  .section-card[open] .section-card-icon {
    transform: rotate(45deg);
  }

  .section-card-body {
    padding: 0 1.2rem 1.2rem;
    border-top: 1px solid var(--border-soft);
  }
</style>