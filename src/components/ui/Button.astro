---
/**
 * Shared button primitive for actions and link-style buttons.
 */
interface Props {
  href?: string;
  id?: string;
  type?: "button" | "submit" | "reset";
  variant?: "primary" | "secondary" | "danger";
  size?: "md" | "sm";
  disabled?: boolean;
  class?: string;
  target?: string;
  rel?: string;
}

const {
  href,
  id,
  type = "button",
  variant = "secondary",
  size = "md",
  disabled = false,
  class: className = "",
  target,
  rel,
} = Astro.props;

const variantClass =
  variant === "primary"
    ? "button-primary"
    : variant === "danger"
      ? "danger-btn"
      : "button-secondary";

const sizeClass = size === "sm" ? "ui-button-sm" : "ui-button-md";
const classes = ["ui-button", variantClass, sizeClass, className].filter(Boolean).join(" ");
---

{href ? (
  <a id={id} href={href} class={classes} target={target} rel={rel} aria-disabled={disabled ? "true" : undefined}>
    <slot />
  </a>
) : (
  <button id={id} type={type} class={classes} disabled={disabled}>
    <slot />
  </button>
)}

<style>
  .ui-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .ui-button-sm {
    min-height: 36px;
  }

  .ui-button-md {
    min-height: 42px;
  }

  a[aria-disabled="true"] {
    pointer-events: none;
    opacity: 0.65;
  }
</style>
