---
/**
 * Reusable quick-link card component.
 * Used to display a styled navigation card that links
 * to another page, section, or app feature.
 */
interface Props {
  href: string;
  title: string;
  text?: string;
}

const { href, title, text = "" } = Astro.props;
---

<a href={href} class="quick-link-card">
  <h3>{title}</h3>
  {text && <p>{text}</p>}
</a>

<style>
  .quick-link-card {
    display: block;
    text-decoration: none;
    color: inherit;
    width: 100%;

    padding: 1rem;
    border-radius: var(--radius, 18px);
    border: 1px solid var(--border-soft, var(--border-color));
    box-shadow: var(--card-shadow);
    background: var(--quick-link-card-surface-color, var(--card-surface-color, var(--resolved-section-color, var(--surface-card, var(--section-color, #fff)))));

    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease,
      background 0.18s ease,
      border-color 0.18s ease;
  }

  .quick-link-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--card-shadow-hover, var(--card-shadow));
  }

  .quick-link-card h3,
  .quick-link-card p {
    margin: 0;
  }

  .quick-link-card h3 {
    color: var(--text-main, var(--text-primary));
  }

  .quick-link-card p {
    margin-top: 0.35rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.45;
  }
</style>
