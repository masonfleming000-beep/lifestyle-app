---
/**
 * Reusable content card component.
 * Supports an optional title, subtitle, header actions slot,
 * and padded body content for displaying notes or grouped information.
 */
const links = [
  { href: "/", label: "Home" },
  { href: "/today", label: "Today" },
  { href: "/fitness", label: "Fitness" },
  { href: "/nutrition", label: "Nutrition" },
  { href: "/mind", label: "Mind" },
  { href: "/education", label: "Education" },
  { href: "/work", label: "Work" },
  { href: "/career", label: "Career" },
  { href: "/hobbies", label: "Hobbies" },
  { href: "/settings/profile", label: "Settings" },
];

const currentPath = Astro.url.pathname;
const currentPage =
  links.find((link) => link.href === currentPath)?.label ??
  (currentPath.startsWith("/profile/") ? "My Profile" : "Menu");

const isHomePage = currentPath === "/";
---

<header class="topbar surface-header">
  <div class="topbar-inner compact">
    <a href="/" class="brand">
      <span class="brand-mark">LIFE</span>
      <div>
        <p class="brand-kicker">Lifestyle</p>
        <h1>{currentPage}</h1>
      </div>
    </a>

    <div class="topbar-actions">
      <div id="auth-status" class="auth-status">Checking session...</div>

      <details class="menu-dropdown">
        <summary>Menu</summary>

        <div class:list={["dropdown-panel", "surface-dropdown", isHomePage && "dropdown-panel-home"]}>
          <div id="dynamic-profile-link-wrap" class="dynamic-profile-link-wrap"></div>

          {links.map((link) => (
            <a
              href={link.href}
              class={currentPath === link.href ? "is-active" : ""}
            >
              {link.label}
            </a>
          ))}

          <a id="login-link" href="/login">Login</a>
          <a id="signup-link" href="/signup">Sign up</a>
          <button id="logout-btn" type="button" class="nav-logout-btn" style="display:none;">
            Log out
          </button>
        </div>
      </details>
    </div>
  </div>
</header>

<script>
  const authStatusEl = document.getElementById("auth-status");
  const loginLink = document.getElementById("login-link");
  const signupLink = document.getElementById("signup-link");
  const logoutBtn = document.getElementById("logout-btn");
  const profileLinkWrap = document.getElementById("dynamic-profile-link-wrap");

  function setLoggedOut() {
    if (authStatusEl) authStatusEl.textContent = "Not signed in";
    if (loginLink) loginLink.style.display = "";
    if (signupLink) signupLink.style.display = "";
    if (logoutBtn) logoutBtn.style.display = "none";
    if (profileLinkWrap) profileLinkWrap.innerHTML = "";
  }

  /**
   * @param {{ email?: string, username?: string, displayName?: string, handle?: string, avatarUrl?: string } | null} user
   */
  function setLoggedIn(user) {
    const display =
      (user && user.displayName) ||
      (user && user.username) ||
      (user && user.handle) ||
      (user && user.email) ||
      "Signed in";

    if (authStatusEl) authStatusEl.textContent = display;
    if (loginLink) loginLink.style.display = "none";
    if (signupLink) signupLink.style.display = "none";
    if (logoutBtn) logoutBtn.style.display = "block";

    if (profileLinkWrap && user && user.username) {
      const isActive = window.location.pathname === `/profile/${user.username}`;
      profileLinkWrap.innerHTML = `
        <a href="/profile/${encodeURIComponent(user.username)}" class="${isActive ? "is-active" : ""}">
          My Profile
        </a>
      `;
    }
  }

  async function loadCurrentUser() {
    try {
      const response = await fetch("/api/me", {
        credentials: "include",
        cache: "no-store",
      });

      const data = await response.json().catch(() => ({}));

      if (data && data.ok && data.user && data.user.email) {
        setLoggedIn(data.user);
      } else {
        setLoggedOut();
      }
    } catch (error) {
      console.error("Failed to load current user:", error);
      setLoggedOut();
    }
  }

  if (logoutBtn) {
    logoutBtn.addEventListener("click", async () => {
      try {
        await fetch("/api/auth/logout", {
          method: "POST",
          credentials: "include",
        });
      } catch (error) {
        console.error("Logout failed:", error);
      }

      window.location.href = "/login";
    });
  }

  loadCurrentUser();
</script>

<style>
  .dynamic-profile-link-wrap {
    display: contents;
  }
</style>