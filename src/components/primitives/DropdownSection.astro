---
interface Props {
  kicker?: string;
  title: string;
  subtitle?: string;
  open?: boolean;
  className?: string;
  contentClassName?: string;
}

const {
  kicker = '',
  title,
  subtitle = '',
  open = true,
  className = '',
  contentClassName = 'dropdown-content',
} = Astro.props;
---

<details class:list={["dropdown-card", className]} open={open}>
  <summary>
    <div>
      {kicker && <p class="kicker">{kicker}</p>}
      <h2 class="section-title">{title}</h2>
      {subtitle && <p class="section-subtitle">{subtitle}</p>}
    </div>
    <span class="dropdown-arrow">⌄</span>
  </summary>

  <div class:list={[contentClassName]}>
    <slot />
  </div>
</details>
