---
/**
 * Shared actions row / editor toolbar.
 */
interface ActionItem {
  label: string;
  id?: string;
  type?: "button" | "submit" | "reset";
  variant?: "primary" | "secondary" | "danger";
  disabled?: boolean;
}

interface Props {
  actions?: ActionItem[];
  align?: "start" | "end" | "between";
  wrap?: boolean;
}

const {
  actions = [],
  align = "start",
  wrap = true,
} = Astro.props;

function classForVariant(variant?: string) {
  if (variant === "danger") return "danger-btn";
  if (variant === "primary") return "button-primary";
  return "button-secondary";
}
---

<div class:list={["editor-toolbar", `action-bar-${align}`, wrap && "action-bar-wrap"]}>
  {actions.map((action) => (
    <button
      id={action.id || undefined}
      type={action.type || "button"}
      class={classForVariant(action.variant)}
      disabled={action.disabled}
    >
      {action.label}
    </button>
  ))}

  <slot />
</div>

<style>
  .action-bar-wrap {
    flex-wrap: wrap;
  }

  .action-bar-start {
    justify-content: flex-start;
  }

  .action-bar-end {
    justify-content: flex-end;
  }

  .action-bar-between {
    justify-content: space-between;
  }
</style>
