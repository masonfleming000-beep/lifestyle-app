    async function loadState() {
      try {
        const res = await fetch(`/api/state?pageKey=${encodeURIComponent(pageKey)}`, {
          credentials: "include",
          cache: "no-store",
        });

        if (!res.ok) return null;
        const data = await res.json();
        return data?.state ?? null;
      } catch (error) {
        console.error("Failed to load workout builder state:", error);
        return null;
      }
    }

    async function saveState() {
      if (!hasLoadedInitialState) return;

      if (isSaving) {
        pendingSave = true;
        return;
      }

      isSaving = true;

      try {
        await fetch("/api/state", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            pageKey,
            state: {
              workoutTypes,
              selectedType,
            },
          }),
        });
      } catch (error) {
        console.error("Failed to save workout builder state:", error);
      } finally {
        isSaving = false;

        if (pendingSave) {
          pendingSave = false;
          await saveState();
        }
      }
    }

