      const session = {
        id:
          typeof crypto !== "undefined" && crypto.randomUUID
            ? crypto.randomUUID()
            : `cardio-session-${Date.now()}-${Math.random().toString(16).slice(2)}`,
        type: "cardio",
        dateTime: new Date().toISOString(),
