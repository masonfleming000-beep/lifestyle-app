---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Workout Builder | Lifestyle App"
  description="Build and track custom running workouts"
>
  <section class="hero">
    <div class="hero-card">
      <p class="kicker">Running</p>
      <h1>Workout Builder</h1>
      <p>
        Choose a workout type, set your parameters, and track each step live as
        you go.
      </p>
    </div>
  </section>

  <section class="section">
    <article class="card">
      <div class="section-header">
        <div>
          <h2 class="section-title">Choose Workout Type</h2>
          <p class="section-subtitle">
            Build HIIT, intervals, recovery runs, tempo runs, fartlek sessions, hill workouts, power workouts, or long runs.
          </p>
        </div>
      </div>

      <div class="editor-toolbar">
        <button id="edit-workout-types-button" class="button-secondary" type="button">
          Edit
        </button>
      </div>

      <div class="workout-type-select-wrap">
        <label class="workout-field">
          <span>Workout Type</span>
          <select id="workout-type-select" class="workout-type-select"></select>
        </label>
      </div>

      <div id="workout-type-edit-panel" class="workout-type-edit-panel" hidden></div>
    </article>
  </section>

  <section class="section">
    <article class="card soft">
      <div class="section-header">
        <div>
          <h2 class="section-title">Set Workout</h2>
          <p class="section-subtitle">Customize the workout before you start.</p>
        </div>
      </div>

      <form id="workout-builder-form" class="workout-form">
        <div id="workout-form-fields"></div>

        <div class="workout-form-actions">
          <button type="submit" class="button-primary">Start Workout</button>
        </div>
      </form>
    </article>
  </section>

  <section class="section">
    <article class="card" id="live-workout-card" hidden>
      <div class="section-header">
        <div>
          <h2 class="section-title">Live Workout</h2>
          <p class="section-subtitle">
            Fill in your real results and check each step off as you go.
          </p>
        </div>
      </div>

      <div id="live-workout-summary" class="live-workout-summary"></div>
      <ul id="live-workout-steps" class="routine-list workout-live-list"></ul>

      <div class="workout-form-actions">
        <button id="reset-workout-button" type="button" class="button-secondary">
          Reset Workout
        </button>
      </div>
    </article>
  </section>

  <script is:inline>
    const pageKey = "cardio-workout-builder";

    const defaultWorkoutTypes = {
      hiit: {
        label: "HIIT",
        fields: [
          { name: "rounds", label: "Intervals", type: "number", min: 1, value: 8 },
          { name: "workSeconds", label: "Work Time (seconds)", type: "number", min: 5, value: 30 },
          { name: "restSeconds", label: "Rest Time (seconds)", type: "number", min: 5, value: 30 },
        ],
      },
      intervals: {
        label: "Intervals",
        fields: [
          { name: "sprintCount", label: "Number of Sprints", type: "number", min: 1, value: 4 },
          { name: "sprintDistance", label: "Sprint Distance", type: "text", value: "200m" },
          { name: "sprintTargetTime", label: "Sprint Target Time", type: "text", value: "0:35" },
          { name: "restDistance", label: "Jog Rest Distance", type: "text", value: "100m" },
        ],
      },
      steady: {
        label: "Steady State",
        fields: [
          { name: "pace", label: "Target Pace", type: "text", value: "8:45 / mile" },
          { name: "distance", label: "Distance (miles)", type: "number", min: 1, step: "0.5", value: 5 },
        ],
      },
      tempo: {
        label: "Tempo Run",
        fields: [
          { name: "warmupDistance", label: "Warmup Distance (miles)", type: "number", min: 0, step: "0.5", value: 1 },
          { name: "tempoDistance", label: "Tempo Distance (miles)", type: "number", min: 0.5, step: "0.5", value: 3 },
          { name: "tempoPace", label: "Tempo Pace", type: "text", value: "7:15 / mile" },
          { name: "cooldownDistance", label: "Cooldown Distance (miles)", type: "number", min: 0, step: "0.5", value: 1 },
        ],
      },
      fartlek: {
        label: "Fartlek",
        fields: [
          { name: "cycles", label: "Hard / Easy Cycles", type: "number", min: 1, value: 6 },
          { name: "hardMinutes", label: "Hard Effort (minutes)", type: "number", min: 1, value: 2 },
          { name: "easyMinutes", label: "Easy Effort (minutes)", type: "number", min: 1, value: 2 },
          { name: "hardEffort", label: "Hard Effort Target", type: "text", value: "5K effort" },
          { name: "easyEffort", label: "Easy Effort Target", type: "text", value: "Easy jog" },
        ],
      },
      hill: {
        label: "Hill Repeats",
        fields: [
          { name: "repeatCount", label: "Hill Repeats", type: "number", min: 1, value: 6 },
          { name: "hillDistance", label: "Hill Distance", type: "text", value: "200m" },
          { name: "hillTarget", label: "Uphill Target", type: "text", value: "Hard effort" },
          { name: "recoveryType", label: "Recovery", type: "text", value: "Walk/jog back down" },
        ],
      },
      power: {
        label: "Power Workout",
        fields: [
          { name: "intervalCount", label: "Power Intervals", type: "number", min: 1, value: 5 },
          { name: "workMinutes", label: "Work Interval (minutes)", type: "number", min: 1, value: 3 },
          { name: "targetWatts", label: "Target Watts", type: "number", min: 50, value: 250 },
          { name: "recoveryMinutes", label: "Recovery (minutes)", type: "number", min: 1, value: 2 },
        ],
      },
      recovery: {
        label: "Recovery Run",
        fields: [
          { name: "pace", label: "Target Pace", type: "text", value: "9:00 / mile" },
          { name: "distance", label: "Distance (miles)", type: "number", min: 1, step: "0.5", value: 3 },
        ],
      },
      longrun: {
        label: "Long Run",
        fields: [
          { name: "pace", label: "Target Pace", type: "text", value: "8:30 / mile" },
          { name: "distance", label: "Distance (miles)", type: "number", min: 1, step: "0.5", value: 10 },
        ],
      },
    };

    let workoutTypes = cloneWorkoutTypes(defaultWorkoutTypes);
    let selectedType = "hiit";
    let activeWorkout = null;
    let isEditingWorkoutTypes = false;
    let hasLoadedInitialState = false;
    let isSaving = false;
    let pendingSave = false;

    const workoutTypeSelect = document.getElementById("workout-type-select");
    const workoutTypeEditPanel = document.getElementById("workout-type-edit-panel");
    const editWorkoutTypesButton = document.getElementById("edit-workout-types-button");
    const formFields = document.getElementById("workout-form-fields");
    const form = document.getElementById("workout-builder-form");
    const liveWorkoutCard = document.getElementById("live-workout-card");
    const liveWorkoutSummary = document.getElementById("live-workout-summary");
    const liveWorkoutSteps = document.getElementById("live-workout-steps");
    const resetWorkoutButton = document.getElementById("reset-workout-button");

    function cloneWorkoutTypes(types) {
      return JSON.parse(JSON.stringify(types));
    }

    function slugify(value) {
      return String(value || "")
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "");
    }

    function getWorkoutTypeEntries() {
      return Object.entries(workoutTypes);
    }

    function getFirstWorkoutTypeKey() {
      return getWorkoutTypeEntries()[0]?.[0] || "";
    }

    function ensureSelectedTypeExists() {
      if (!workoutTypes[selectedType]) {
        selectedType = getFirstWorkoutTypeKey();
      }
    }

    function createDefaultFieldSetForType(typeKey) {
      if (typeKey === "hiit") {
        return [
          { name: "rounds", label: "Intervals", type: "number", min: 1, value: 8 },
          { name: "workSeconds", label: "Work Time (seconds)", type: "number", min: 5, value: 30 },
          { name: "restSeconds", label: "Rest Time (seconds)", type: "number", min: 5, value: 30 },
        ];
      }

      if (typeKey === "intervals") {
        return [
          { name: "sprintCount", label: "Number of Sprints", type: "number", min: 1, value: 4 },
          { name: "sprintDistance", label: "Sprint Distance", type: "text", value: "200m" },
          { name: "sprintTargetTime", label: "Sprint Target Time", type: "text", value: "0:35" },
          { name: "restDistance", label: "Jog Rest Distance", type: "text", value: "100m" },
        ];
      }

      if (typeKey === "tempo") {
        return [
          { name: "warmupDistance", label: "Warmup Distance (miles)", type: "number", min: 0, step: "0.5", value: 1 },
          { name: "tempoDistance", label: "Tempo Distance (miles)", type: "number", min: 0.5, step: "0.5", value: 3 },
          { name: "tempoPace", label: "Tempo Pace", type: "text", value: "7:15 / mile" },
          { name: "cooldownDistance", label: "Cooldown Distance (miles)", type: "number", min: 0, step: "0.5", value: 1 },
        ];
      }

      if (typeKey === "fartlek") {
        return [
          { name: "cycles", label: "Hard / Easy Cycles", type: "number", min: 1, value: 6 },
          { name: "hardMinutes", label: "Hard Effort (minutes)", type: "number", min: 1, value: 2 },
          { name: "easyMinutes", label: "Easy Effort (minutes)", type: "number", min: 1, value: 2 },
          { name: "hardEffort", label: "Hard Effort Target", type: "text", value: "5K effort" },
          { name: "easyEffort", label: "Easy Effort Target", type: "text", value: "Easy jog" },
        ];
      }

      if (typeKey === "hill") {
        return [
          { name: "repeatCount", label: "Hill Repeats", type: "number", min: 1, value: 6 },
          { name: "hillDistance", label: "Hill Distance", type: "text", value: "200m" },
          { name: "hillTarget", label: "Uphill Target", type: "text", value: "Hard effort" },
          { name: "recoveryType", label: "Recovery", type: "text", value: "Walk/jog back down" },
        ];
      }

      if (typeKey === "power") {
        return [
          { name: "intervalCount", label: "Power Intervals", type: "number", min: 1, value: 5 },
          { name: "workMinutes", label: "Work Interval (minutes)", type: "number", min: 1, value: 3 },
          { name: "targetWatts", label: "Target Watts", type: "number", min: 50, value: 250 },
          { name: "recoveryMinutes", label: "Recovery (minutes)", type: "number", min: 1, value: 2 },
        ];
      }

      return [
        { name: "pace", label: "Target Pace", type: "text", value: "9:00 / mile" },
        { name: "distance", label: "Distance (miles)", type: "number", min: 1, step: "0.5", value: 3 },
      ];
    }

    function normalizeSavedWorkoutTypes(savedTypes) {
      if (!savedTypes || typeof savedTypes !== "object") {
        return cloneWorkoutTypes(defaultWorkoutTypes);
      }

      const normalized = {};

      Object.entries(savedTypes).forEach(([key, config]) => {
        if (!config || typeof config !== "object") return;

        const safeKey = slugify(key);
        if (!safeKey) return;

        const label = String(config.label || safeKey).trim() || safeKey;
        const fields = Array.isArray(config.fields) && config.fields.length
          ? config.fields.map((field, index) => ({
              name: String(field.name || `field-${index + 1}`).trim() || `field-${index + 1}`,
              label: String(field.label || `Field ${index + 1}`).trim() || `Field ${index + 1}`,
              type: field.type === "number" ? "number" : "text",
              min: field.min ?? "",
              step: field.step ?? "",
              value: field.value ?? "",
            }))
          : createDefaultFieldSetForType(safeKey);

        normalized[safeKey] = { label, fields };
      });

      if (!Object.keys(normalized).length) {
        return cloneWorkoutTypes(defaultWorkoutTypes);
      }

      return normalized;
    }

    async function loadState() {
      try {
        const res = await fetch(`/api/state?pageKey=${encodeURIComponent(pageKey)}`, {
          credentials: "include",
          cache: "no-store",
        });

        if (!res.ok) return null;
        const data = await res.json();
        return data?.state ?? null;
      } catch (error) {
        console.error("Failed to load workout builder state:", error);
        return null;
      }
    }

    async function saveState() {
      if (!hasLoadedInitialState) return;

      if (isSaving) {
        pendingSave = true;
        return;
      }

      isSaving = true;

      try {
        await fetch("/api/state", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            pageKey,
            state: {
              workoutTypes,
              selectedType,
            },
          }),
        });
      } catch (error) {
        console.error("Failed to save workout builder state:", error);
      } finally {
        isSaving = false;

        if (pendingSave) {
          pendingSave = false;
          await saveState();
        }
      }
    }

    function renderTypeSelect() {
      workoutTypeSelect.innerHTML = "";

      getWorkoutTypeEntries().forEach(([key, config]) => {
        const option = document.createElement("option");
        option.value = key;
        option.textContent = config.label;
        option.selected = key === selectedType;
        workoutTypeSelect.appendChild(option);
      });
    }

    function renderWorkoutTypeEditor() {
      workoutTypeEditPanel.innerHTML = "";
      workoutTypeEditPanel.hidden = !isEditingWorkoutTypes;

      editWorkoutTypesButton.textContent = isEditingWorkoutTypes ? "Done" : "Edit";

      if (!isEditingWorkoutTypes) return;

      getWorkoutTypeEntries().forEach(([key, config]) => {
        const card = document.createElement("div");
        card.className = "workout-type-edit-card";

        const row = document.createElement("div");
        row.className = "workout-type-edit-row";

        const input = document.createElement("input");
        input.type = "text";
        input.className = "workout-type-inline-input";
        input.value = config.label;
        input.placeholder = "Workout type name";

        input.addEventListener("change", async () => {
          const nextLabel = input.value.trim() || config.label;
          workoutTypes[key].label = nextLabel;
          renderTypeSelect();
          renderWorkoutTypeEditor();
          renderFormFields();
          await saveState();
        });

        const deleteButton = document.createElement("button");
        deleteButton.type = "button";
        deleteButton.className = "routine-action-button";
        deleteButton.textContent = "Delete";

        deleteButton.addEventListener("click", async () => {
          if (Object.keys(workoutTypes).length <= 1) return;

          delete workoutTypes[key];
          ensureSelectedTypeExists();
          renderTypeSelect();
          renderWorkoutTypeEditor();
          renderFormFields();
          await saveState();
        });

        row.appendChild(input);
        row.appendChild(deleteButton);
        card.appendChild(row);
        workoutTypeEditPanel.appendChild(card);
      });

      const actions = document.createElement("div");
      actions.className = "workout-type-edit-actions";

      const addButton = document.createElement("button");
      addButton.type = "button";
      addButton.className = "routine-action-button";
      addButton.textContent = "Add Workout Type";

      addButton.addEventListener("click", async () => {
        let baseKey = "new-workout";
        let counter = 1;
        let newKey = baseKey;

        while (workoutTypes[newKey]) {
          counter += 1;
          newKey = `${baseKey}-${counter}`;
        }

        workoutTypes[newKey] = {
          label: "New Workout",
          fields: createDefaultFieldSetForType(newKey),
        };

        selectedType = newKey;
        renderTypeSelect();
        renderWorkoutTypeEditor();
        renderFormFields();
        await saveState();

        const inputs = workoutTypeEditPanel.querySelectorAll(".workout-type-inline-input");
        const lastInput = inputs[inputs.length - 1];
        if (lastInput) lastInput.focus();
      });

      const restoreButton = document.createElement("button");
      restoreButton.type = "button";
      restoreButton.className = "routine-action-button";
      restoreButton.textContent = "Restore Defaults";

      restoreButton.addEventListener("click", async () => {
        workoutTypes = cloneWorkoutTypes(defaultWorkoutTypes);
        selectedType = "hiit";
        renderTypeSelect();
        renderWorkoutTypeEditor();
        renderFormFields();
        await saveState();
      });

      actions.appendChild(addButton);
      actions.appendChild(restoreButton);
      workoutTypeEditPanel.appendChild(actions);
    }

    function renderFormFields() {
      ensureSelectedTypeExists();

      const config = workoutTypes[selectedType];
      if (!config) {
        formFields.innerHTML = "";
        return;
      }

      formFields.innerHTML = config.fields
        .map((field) => {
          const safeName = field.name || "field";
          const safeLabel = field.label || "Field";
          const safeType = field.type === "number" ? "number" : "text";
          const safeValue = field.value ?? "";
          const safeMin = safeType === "number" ? (field.min ?? "") : "";
          const safeStep = safeType === "number" ? (field.step ?? "") : "";

          return `
            <label class="workout-field">
              <span>${safeLabel}</span>
              <input
                name="${safeName}"
                type="${safeType}"
                value="${safeValue}"
                min="${safeMin}"
                step="${safeStep}"
                required
              />
            </label>
          `;
        })
        .join("");
    }

    function getFormValues() {
      const data = new FormData(form);
      return Object.fromEntries(data.entries());
    }

    function createStep({
      text,
      target = "",
      actualLabel = "Actual Time / Result",
      actualPlaceholder = "Enter actual result",
    }) {
      return {
        text,
        target,
        done: false,
        actual: "",
        actualLabel,
        actualPlaceholder,
      };
    }

    function addDistanceSteps(steps, label, distance, pace, splitLabel = "Actual Mile Split") {
      const wholeMiles = Math.floor(distance);
      const remainder = distance - wholeMiles;

      for (let i = 1; i <= wholeMiles; i++) {
        steps.push(
          createStep({
            text: `${label} Mile ${i}`,
            target: pace,
            actualLabel: splitLabel,
            actualPlaceholder: "Example: 8:32\nFelt controlled",
          })
        );
      }

      if (remainder > 0) {
        steps.push(
          createStep({
            text: `${label} Final ${remainder.toFixed(1)} mile segment`,
            target: pace,
            actualLabel: "Actual Split / Notes",
            actualPlaceholder: "Example: 4:08\nStayed smooth",
          })
        );
      }
    }

    function buildWorkout(type, values) {
      if (type === "hiit") {
        const rounds = Number(values.rounds);
        const workSeconds = Number(values.workSeconds);
        const restSeconds = Number(values.restSeconds);

        const steps = [];

        for (let i = 1; i <= rounds; i++) {
          steps.push(
            createStep({
              text: `Interval ${i}: Work`,
              target: `${workSeconds}s`,
              actualLabel: "Actual Work Time / Notes",
              actualPlaceholder: "Example: 31s\nFelt strong",
            })
          );

          if (i < rounds) {
            steps.push(
              createStep({
                text: `Rest ${i}: Recovery`,
                target: `${restSeconds}s`,
                actualLabel: "Actual Rest Time / Notes",
                actualPlaceholder: "Example: 35s\nWalked part of it",
              })
            );
          }
        }

        return {
          type,
          title: workoutTypes[type].label,
          summary: `${rounds} intervals · ${workSeconds}s work · ${restSeconds}s rest`,
          steps,
        };
      }

      if (type === "intervals") {
        const sprintCount = Number(values.sprintCount);
        const sprintDistance = values.sprintDistance;
        const sprintTargetTime = values.sprintTargetTime;
        const restDistance = values.restDistance;

        const steps = [];

        for (let i = 1; i <= sprintCount; i++) {
          steps.push(
            createStep({
              text: `Sprint ${i}`,
              target: `${sprintDistance} in ${sprintTargetTime}`,
              actualLabel: "Actual Sprint Time / Notes",
              actualPlaceholder: "Example: 0:34\nGood turnover",
            })
          );

          steps.push(
            createStep({
              text: `Jog recovery ${i}`,
              target: `${restDistance}`,
              actualLabel: "Actual Recovery Distance / Notes",
              actualPlaceholder: "Example: 100m\nJogged easy",
            })
          );
        }

        steps.push(
          createStep({
            text: "Extended jog recovery",
            target: `${sprintCount * 4} × ${restDistance}`,
            actualLabel: "Actual Recovery Distance / Notes",
            actualPlaceholder: "Example: 400m\nNeeded extra time",
          })
        );

        return {
          type,
          title: workoutTypes[type].label,
          summary: `${sprintCount} sprints · ${sprintDistance} target ${sprintTargetTime} · ${restDistance} jog rest`,
          steps,
        };
      }

      if (type === "tempo") {
        const warmupDistance = Number(values.warmupDistance || 0);
        const tempoDistance = Number(values.tempoDistance || 0);
        const tempoPace = values.tempoPace || "Tempo pace";
        const cooldownDistance = Number(values.cooldownDistance || 0);
        const steps = [];

        if (warmupDistance > 0) {
          addDistanceSteps(steps, "Warmup", warmupDistance, "Easy pace");
        }

        if (tempoDistance > 0) {
          addDistanceSteps(steps, "Tempo", tempoDistance, tempoPace, "Actual Tempo Split");
        }

        if (cooldownDistance > 0) {
          addDistanceSteps(steps, "Cooldown", cooldownDistance, "Easy pace");
        }

        steps.push(
          createStep({
            text: "Finish tempo workout",
            target: `${warmupDistance + tempoDistance + cooldownDistance} miles total`,
            actualLabel: "Overall Time / Notes",
            actualPlaceholder: "Example: 38:42\nTempo felt controlled throughout",
          })
        );

        return {
          type,
          title: workoutTypes[type].label,
          summary: `${warmupDistance} mi warmup · ${tempoDistance} mi tempo at ${tempoPace} · ${cooldownDistance} mi cooldown`,
          steps,
        };
      }

      if (type === "fartlek") {
        const cycles = Number(values.cycles);
        const hardMinutes = Number(values.hardMinutes);
        const easyMinutes = Number(values.easyMinutes);
        const hardEffort = values.hardEffort || "Hard";
        const easyEffort = values.easyEffort || "Easy";
        const steps = [];

        for (let i = 1; i <= cycles; i++) {
          steps.push(
            createStep({
              text: `Cycle ${i}: Hard`,
              target: `${hardMinutes} min · ${hardEffort}`,
              actualLabel: "Actual Hard Segment / Notes",
              actualPlaceholder: "Example: 2:00\nStrong effort",
            })
          );

          steps.push(
            createStep({
              text: `Cycle ${i}: Easy`,
              target: `${easyMinutes} min · ${easyEffort}`,
              actualLabel: "Actual Easy Segment / Notes",
              actualPlaceholder: "Example: 2:10\nRecovered well",
            })
          );
        }

        return {
          type,
          title: workoutTypes[type].label,
          summary: `${cycles} cycles · ${hardMinutes} min hard / ${easyMinutes} min easy`,
          steps,
        };
      }

      if (type === "hill") {
        const repeatCount = Number(values.repeatCount);
        const hillDistance = values.hillDistance;
        const hillTarget = values.hillTarget;
        const recoveryType = values.recoveryType;
        const steps = [];

        for (let i = 1; i <= repeatCount; i++) {
          steps.push(
            createStep({
              text: `Hill Repeat ${i}: Uphill`,
              target: `${hillDistance} · ${hillTarget}`,
              actualLabel: "Actual Uphill Time / Notes",
              actualPlaceholder: "Example: 0:46\nStayed tall",
            })
          );

          steps.push(
            createStep({
              text: `Hill Repeat ${i}: Recovery`,
              target: recoveryType,
              actualLabel: "Actual Recovery / Notes",
              actualPlaceholder: "Example: Jog down\nBreathing recovered",
            })
          );
        }

        return {
          type,
          title: workoutTypes[type].label,
          summary: `${repeatCount} repeats · ${hillDistance} uphill · ${recoveryType}`,
          steps,
        };
      }

      if (type === "power") {
        const intervalCount = Number(values.intervalCount);
        const workMinutes = Number(values.workMinutes);
        const targetWatts = Number(values.targetWatts);
        const recoveryMinutes = Number(values.recoveryMinutes);
        const steps = [];

        for (let i = 1; i <= intervalCount; i++) {
          steps.push(
            createStep({
              text: `Power Interval ${i}`,
              target: `${workMinutes} min @ ${targetWatts} watts`,
              actualLabel: "Actual Watts / Notes",
              actualPlaceholder: "Example: 248 avg watts\nCadence steady",
            })
          );

          if (i < intervalCount) {
            steps.push(
              createStep({
                text: `Recovery ${i}`,
                target: `${recoveryMinutes} min easy`,
                actualLabel: "Actual Recovery / Notes",
                actualPlaceholder: "Example: 2:00\nEasy spin",
              })
            );
          }
        }

        return {
          type,
          title: workoutTypes[type].label,
          summary: `${intervalCount} intervals · ${workMinutes} min @ ${targetWatts}W · ${recoveryMinutes} min recovery`,
          steps,
        };
      }

      if (
        type === "steady" ||
        type === "recovery" ||
        type === "longrun" ||
        workoutTypes[type]?.fields?.some((field) => field.name === "distance")
      ) {
        const pace = values.pace ?? "Easy pace";
        const distance = Number(values.distance);
        const steps = [];

        addDistanceSteps(steps, "", distance, pace);

        steps.push(
          createStep({
            text: `Finish ${distance} mile ${workoutTypes[type].label.toLowerCase()}`,
            target: `${distance} miles total`,
            actualLabel: "Overall Time / Notes",
            actualPlaceholder: "Example: 27:41\nLegs felt good overall",
          })
        );

        return {
          type,
          title: workoutTypes[type].label,
          summary: `${distance} miles at ${pace}`,
          steps,
        };
      }

      const genericFields = workoutTypes[type]?.fields || [];
      const genericSummary = genericFields
        .map((field) => `${field.label}: ${values[field.name] ?? field.value ?? ""}`)
        .join(" · ");

      return {
        type,
        title: workoutTypes[type]?.label || "Workout",
        summary: genericSummary,
        steps: [
          createStep({
            text: workoutTypes[type]?.label || "Workout",
            target: genericSummary,
            actualLabel: "Actual Result / Notes",
            actualPlaceholder: "Enter your actual result",
          }),
        ],
      };
    }

    function renderLiveWorkout(workout) {
      activeWorkout = workout;
      liveWorkoutCard.hidden = false;
      liveWorkoutSummary.innerHTML = `
        <p><strong>${workout.title}</strong> · ${workout.summary}</p>
      `;

      liveWorkoutSteps.innerHTML = "";

      workout.steps.forEach((step, index) => {
        const li = document.createElement("li");
        li.className = "routine-item workout-step-card" + (step.done ? " is-done" : "");

        const header = document.createElement("div");
        header.className = "workout-step-header";

        const checkbox = document.createElement("input");
        checkbox.type = "checkbox";
        checkbox.checked = !!step.done;
        checkbox.className = "workout-step-checkbox";

        checkbox.addEventListener("change", () => {
          activeWorkout.steps[index].done = checkbox.checked;
          renderLiveWorkout(activeWorkout);
        });

        const copy = document.createElement("div");
        copy.className = "workout-step-copy";

        const title = document.createElement("div");
        title.className = "workout-step-title";
        title.textContent = step.text;

        const target = document.createElement("div");
        target.className = "workout-step-target";
        target.textContent = `Target: ${step.target || "-"}`;

        copy.appendChild(title);
        copy.appendChild(target);

        header.appendChild(checkbox);
        header.appendChild(copy);

        const actualWrap = document.createElement("div");
        actualWrap.className = "workout-actual-field";

        const actualLabel = document.createElement("label");
        actualLabel.className = "workout-actual-label";
        actualLabel.textContent = step.actualLabel || "Actual Time / Result";

        const actualInput = document.createElement("textarea");
        actualInput.className = "workout-actual-textarea";
        actualInput.rows = 3;
        actualInput.placeholder = step.actualPlaceholder || "Enter actual result";
        actualInput.value = step.actual || "";

        actualInput.addEventListener("input", (event) => {
          activeWorkout.steps[index].actual = event.target.value;
        });

        actualWrap.appendChild(actualLabel);
        actualWrap.appendChild(actualInput);

        li.appendChild(header);
        li.appendChild(actualWrap);
        liveWorkoutSteps.appendChild(li);
      });
    }

    editWorkoutTypesButton.addEventListener("click", () => {
      isEditingWorkoutTypes = !isEditingWorkoutTypes;
      renderWorkoutTypeEditor();
    });

    workoutTypeSelect.addEventListener("change", () => {
      selectedType = workoutTypeSelect.value;
      renderTypeSelect();
      renderFormFields();
      saveState();
    });

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const values = getFormValues();
      const workout = buildWorkout(selectedType, values);
      renderLiveWorkout(workout);
    });

    resetWorkoutButton.addEventListener("click", () => {
      activeWorkout = null;
      liveWorkoutCard.hidden = true;
      liveWorkoutSteps.innerHTML = "";
      liveWorkoutSummary.innerHTML = "";
      renderFormFields();
    });

    async function init() {
      const saved = await loadState();

      workoutTypes = normalizeSavedWorkoutTypes(saved?.workoutTypes);

      selectedType =
        typeof saved?.selectedType === "string" && workoutTypes[saved.selectedType]
          ? saved.selectedType
          : getFirstWorkoutTypeKey();

      ensureSelectedTypeExists();

      hasLoadedInitialState = true;

      renderTypeSelect();
      renderWorkoutTypeEditor();
      renderFormFields();
    }

    init();
  </script>

