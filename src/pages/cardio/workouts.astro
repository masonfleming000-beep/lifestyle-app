                          ${option.label}
                        </option>
                      `
                    )
                    .join("")}
                </select>
              </label>
            `;
          }

          const safeType = field.type === "number" ? "number" : "text";
          const safeMin = safeType === "number" ? (field.min ?? "") : "";
          const safeStep = safeType === "number" ? (field.step ?? "") : "";
          const safePlaceholder = field.placeholder ?? "";
          const isOptional = safeName === "totalTime" || safeName === "pace";
          return `
            <label class="workout-field">
              <span>${safeLabel}</span>
              <input
                name="${safeName}"
                type="${safeType}"
                value="${safeValue}"
                min="${safeMin}"
                step="${safeStep}"
                placeholder="${safePlaceholder}"
                ${isOptional ? "" : "required"}
              />
            </label>
          `;
        })
        .join("");
    }
    function addDistanceSteps(steps, label, distance, pace, splitLabel = "Actual Mile Split") {
      const wholeMiles = Math.floor(distance);
      const remainder = distance - wholeMiles;

      for (let i = 1; i <= wholeMiles; i++) {
        steps.push(
          createStep({
            text: `${label} Mile ${i}`,
            target: pace,
            actualLabel: splitLabel,
            actualPlaceholder: "Example: 8:32\nFelt controlled",
          })
        );
      }

      if (remainder > 0) {
        steps.push(
          createStep({
            text: `${label} Final ${remainder.toFixed(1)} mile segment`,
            target: pace,
            actualLabel: "Actual Split / Notes",
            actualPlaceholder: "Example: 4:08\nStayed smooth",
          })
        );
      }
    }

    function buildWorkout(type, values) {
      if (type === "hiit") {
        const rounds = Number(values.rounds);
        const workSeconds = Number(values.workSeconds);
        const restSeconds = Number(values.restSeconds);

        const steps = [];

        for (let i = 1; i <= rounds; i++) {
          steps.push(
            createStep({
              text: `Interval ${i}: Work`,
              target: `${workSeconds}s`,
              actualLabel: "Actual Work Time / Notes",
              actualPlaceholder: "Example: 31s\nFelt strong",
            })
          );

          if (i < rounds) {
            steps.push(
              createStep({
                text: `Rest ${i}: Recovery`,
                target: `${restSeconds}s`,
                actualLabel: "Actual Rest Time / Notes",
                actualPlaceholder: "Example: 35s\nWalked part of it",
              })
            );
          }
        }

        return {
          type,
          title: workoutTypes[type].label,
          summary: `${rounds} intervals · ${workSeconds}s work · ${restSeconds}s rest`,
          steps,
        };
      }

      if (type === "intervals") {
        const sprintCount = Number(values.sprintCount);
        const sprintDistance = values.sprintDistance;
        const sprintTargetTime = values.sprintTargetTime;
        const restDistance = values.restDistance;

        const steps = [];

        for (let i = 1; i <= sprintCount; i++) {
          steps.push(
            createStep({
              text: `Sprint ${i}`,
              target: `${sprintDistance} in ${sprintTargetTime}`,
              actualLabel: "Actual Sprint Time / Notes",
              actualPlaceholder: "Example: 0:34\nGood turnover",
            })
          );

          steps.push(
            createStep({
              text: `Jog recovery ${i}`,
              target: `${restDistance}`,
              actualLabel: "Actual Recovery Distance / Notes",
              actualPlaceholder: "Example: 100m\nJogged easy",
            })
          );
        }

        steps.push(
          createStep({
            text: "Extended jog recovery",
            target: `${sprintCount * 4} × ${restDistance}`,
            actualLabel: "Actual Recovery Distance / Notes",
            actualPlaceholder: "Example: 400m\nNeeded extra time",
          })
        );

        return {
          type,
          title: workoutTypes[type].label,
          summary: `${sprintCount} sprints · ${sprintDistance} target ${sprintTargetTime} · ${restDistance} jog rest`,
          steps,
        };
      }

      if (type === "tempo") {
        const warmupDistance = Number(values.warmupDistance || 0);
        const tempoDistance = Number(values.tempoDistance || 0);
        const tempoPace = values.tempoPace || values.pace || "Tempo pace";
        const cooldownDistance = Number(values.cooldownDistance || 0);
        const plannedMetrics = getPlannedRunMetrics(type, {
          ...values,
          pace: tempoPace,
        });

        const steps = [];

        if (warmupDistance > 0) {
          addDistanceSteps(steps, "Warmup", warmupDistance, "Easy pace");
        }

        if (tempoDistance > 0) {
          addDistanceSteps(steps, "Tempo", tempoDistance, tempoPace, "Actual Tempo Split");
        }

        if (cooldownDistance > 0) {
          addDistanceSteps(steps, "Cooldown", cooldownDistance, "Easy pace");
        }

        steps.push(
          createStep({
            text: "Finish tempo workout",
            target: `${plannedMetrics.distance} miles total`,
            actualLabel: "Overall Time / Notes",
            actualPlaceholder: "Example: 38:42\nTempo felt controlled throughout",
          })
        );

        return {
          type,
          title: workoutTypes[type].label,
          summary: `${warmupDistance} mi warmup · ${tempoDistance} mi tempo at ${tempoPace} · ${cooldownDistance} mi cooldown`,
          steps,
          meta: {
            distanceMiles: plannedMetrics.distance,
            plannedTotalTimeMinutes: plannedMetrics.totalTimeMinutes,
            plannedPaceMinutes: plannedMetrics.paceMinutes,
            plannedTotalTimeDisplay: plannedMetrics.totalTimeDisplay,
            plannedPaceDisplay: plannedMetrics.paceDisplay, 
          },
        };
      }
      if (type === "fartlek") {
        const cycles = Number(values.cycles);
        const hardMinutes = Number(values.hardMinutes);
        const easyMinutes = Number(values.easyMinutes);
        const hardEffort = values.hardEffort || "Hard";
        const easyEffort = values.easyEffort || "Easy";
        const steps = [];

        for (let i = 1; i <= cycles; i++) {
          steps.push(
            createStep({
              text: `Cycle ${i}: Hard`,
              target: `${hardMinutes} min · ${hardEffort}`,
              actualLabel: "Actual Hard Segment / Notes",
              actualPlaceholder: "Example: 2:00\nStrong effort",
            })
          );

          steps.push(
            createStep({
              text: `Cycle ${i}: Easy`,
              target: `${easyMinutes} min · ${easyEffort}`,
              actualLabel: "Actual Easy Segment / Notes",
              actualPlaceholder: "Example: 2:10\nRecovered well",
            })
          );
        }

        return {
          type,
          title: workoutTypes[type].label,
          summary: `${cycles} cycles · ${hardMinutes} min hard / ${easyMinutes} min easy`,
          steps,
        };
      }

      if (type === "hill") {
        const repeatCount = Number(values.repeatCount);
        const hillDistance = values.hillDistance;
        const hillTarget = values.hillTarget;
        const recoveryType = values.recoveryType;
        const steps = [];

        for (let i = 1; i <= repeatCount; i++) {
          steps.push(
            createStep({
              text: `Hill Repeat ${i}: Uphill`,
              target: `${hillDistance} · ${hillTarget}`,
              actualLabel: "Actual Uphill Time / Notes",
              actualPlaceholder: "Example: 0:46\nStayed tall",
            })
          );

          steps.push(
            createStep({
              text: `Hill Repeat ${i}: Recovery`,
              target: recoveryType,
              actualLabel: "Actual Recovery / Notes",
              actualPlaceholder: "Example: Jog down\nBreathing recovered",
            })
          );
        }

        return {
          type,
          title: workoutTypes[type].label,
          summary: `${repeatCount} repeats · ${hillDistance} uphill · ${recoveryType}`,
          steps,
        };
      }

      if (type === "power") {
        const intervalCount = Number(values.intervalCount);
        const workMinutes = Number(values.workMinutes);
        const targetWatts = Number(values.targetWatts);
        const recoveryMinutes = Number(values.recoveryMinutes);
        const steps = [];

        for (let i = 1; i <= intervalCount; i++) {
          steps.push(
            createStep({
              text: `Power Interval ${i}`,
              target: `${workMinutes} min @ ${targetWatts} watts`,
              actualLabel: "Actual Watts / Notes",
              actualPlaceholder: "Example: 248 avg watts\nCadence steady",
            })
          );

          if (i < intervalCount) {
            steps.push(
              createStep({
                text: `Recovery ${i}`,
                target: `${recoveryMinutes} min easy`,
                actualLabel: "Actual Recovery / Notes",
                actualPlaceholder: "Example: 2:00\nEasy spin",
              })
            );
          }
        }

        return {
          type,
          title: workoutTypes[type].label,
          summary: `${intervalCount} intervals · ${workMinutes} min @ ${targetWatts}W · ${recoveryMinutes} min recovery`,
          steps,
        };
      }

       if (
        type === "steady" ||
        type === "recovery" ||
        type === "longrun" ||
        workoutTypes[type]?.fields?.some((field) => field.name === "distance")
      ) {
        const pace = values.pace ?? "Easy pace";
        const distance = Number(values.distance);
        const plannedMetrics = getPlannedRunMetrics(type, values);
        const steps = [];

        addDistanceSteps(steps, "", distance, plannedMetrics.paceDisplay || pace);

        steps.push(
          createStep({
            text: `Finish ${distance} mile ${workoutTypes[type].label.toLowerCase()}`,
            target: `${distance} miles total`,
            actualLabel: "Overall Time / Notes",
            actualPlaceholder: "Example: 27:41\nLegs felt good overall",
          })
        );

        return {
          type,
          title: workoutTypes[type].label,
          summary: `${distance} miles${
            plannedMetrics.paceDisplay ? ` at ${plannedMetrics.paceDisplay}` : pace ? ` at ${pace}` : ""
          }${
            plannedMetrics.totalTimeDisplay ? ` · ${plannedMetrics.totalTimeDisplay} total` : ""
          }`,
          steps,
          meta: {
            distanceMiles: plannedMetrics.distance,
            plannedTotalTimeMinutes: plannedMetrics.totalTimeMinutes,
            plannedPaceMinutes: plannedMetrics.paceMinutes,
            plannedTotalTimeDisplay: plannedMetrics.totalTimeDisplay,
            plannedPaceDisplay: plannedMetrics.paceDisplay, 
          },
        };
      }

      const genericFields = workoutTypes[type]?.fields || [];
      const genericSummary = genericFields
        .map((field) => `${field.label}: ${values[field.name] ?? field.value ?? ""}`)
        .join(" · ");

      return {
        type,
        title: workoutTypes[type]?.label || "Workout",
        summary: genericSummary,
        steps: [
          createStep({
            text: workoutTypes[type]?.label || "Workout",
            target: genericSummary,
            actualLabel: "Actual Result / Notes",
            actualPlaceholder: "Enter your actual result",
          }),
        ],
      };
    }

