      if (!config) {
        formFields.innerHTML = "";
        return;
      }

      const baseFields = [...config.fields];
      
      if (isRunWorkoutType(selectedType)) {
        const hasPaceField = baseFields.some(
          (field) => field.name === "pace" || field.name === "tempoPace"
        );
        const hasTotalTimeField = baseFields.some((field) => field.name === "totalTime");

        if (!hasTotalTimeField) {
          baseFields.push({
            name: "totalTime",
            label: "Planned Total Time",
            type: "text",
            value: "",
            placeholder: "Leave blank to calculate from distance + pace",
          });
        }

        if (!hasPaceField) {
          baseFields.push({
            name: "pace",
            label: "Target Pace",
            type: "text",
            value: "",
            placeholder: "Leave blank to calculate from distance + total time",
          });
        }
      }

      formFields.innerHTML = baseFields
        .map((field) => {
          const safeName = field.name || "field";
          const safeLabel = field.label || "Field";
          const safeValue = field.value ?? "";

          if (field.type === "select") {
            const options = Array.isArray(field.options) ? field.options : [];
            return `
              <label class="workout-field">
                <span>${safeLabel}</span>
                <select name="${safeName}">
                  ${options
                    .map(
                      (option) => `
