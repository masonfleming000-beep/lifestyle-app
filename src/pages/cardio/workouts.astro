      const manualPanel = document.getElementById("manual-metrics-panel");
      const visibleMetricsPanel = document.getElementById("visible-calculated-metrics");

      if (manualPanel) {
        manualPanel.hidden = true;
        manualPanel.innerHTML = "";
      }

      if (visibleMetricsPanel) {
        visibleMetricsPanel.innerHTML = "";
      }

      if (cardioWorkoutNotes instanceof HTMLTextAreaElement) {
        cardioWorkoutNotes.value = "";
      }

      renderFormFields();
    });

    saveSplitsButton?.addEventListener("click", () => {
      saveCurrentSplits();
    });

    openManualMetricsButton?.addEventListener("click", () => {
      if (!activeWorkout) return;
      renderManualMetricsPanel();
    });

    autoCalculateMetricsButton?.addEventListener("click", () => {
      console.log("AUTO BUTTON CLICKED");
      console.log("activeWorkout:", activeWorkout);
      console.log("steps:", activeWorkout?.steps);

      if (!activeWorkout) return;

      const calculated = calculateCardioMetricsFromCompletedSteps(activeWorkout);
      console.log("calculated metrics:", calculated);

      visibleMetrics = {
        ...visibleMetrics,
        ...calculated,
      };

      calculationMode = "auto";
      console.log("visibleMetrics after calc:", visibleMetrics);

      renderVisibleMetrics();
    });
    async function init() {
      const saved = await loadState();

      workoutTypes = normalizeSavedWorkoutTypes(saved?.workoutTypes);

      selectedType =
        typeof saved?.selectedType === "string" && workoutTypes[saved.selectedType]
          ? saved.selectedType
          : getFirstWorkoutTypeKey();

      ensureSelectedTypeExists();

      const historyState = await loadFitnessHistory();
      weightliftingHistory = Array.isArray(historyState?.weightliftingSessions)
        ? historyState.weightliftingSessions
        : [];
      cardioHistory = Array.isArray(historyState?.cardioSessions) ? historyState.cardioSessions : [];

      hasLoadedInitialState = true;

      renderTypeSelect();
      renderWorkoutTypeEditor();
      renderFormFields();
    }

    init();
  </script>

