---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Workout Builder | Lifestyle App"
  description="Build and track custom running workouts"
>
  <section class="hero">
    <div class="hero-card">
      <p class="kicker">Running</p>
      <h1>Workout Builder</h1>
      <p>
        Choose a workout type, set your parameters, and track each step live as
        you go.
      </p>
    </div>
  </section>

  <section class="section">
    <article class="card">
      <div class="section-header">
        <div>
          <h2 class="section-title">Choose Workout Type</h2>
          <p class="section-subtitle">
            Build HIIT, intervals, recovery runs, tempo runs, fartlek sessions, hill workouts, power workouts, or long runs.
          </p>
        </div>
      </div>

      <div class="editor-toolbar">
        <button id="edit-workout-types-button" class="button-secondary" type="button">
          Edit
        </button>
      </div>

      <div class="workout-type-select-wrap">
        <label class="workout-field">
          <span>Workout Type</span>
          <select id="workout-type-select" class="workout-type-select"></select>
        </label>
      </div>

      <div id="workout-type-edit-panel" class="workout-type-edit-panel" hidden></div>
    </article>
  </section>

  <section class="section">
    <article class="card soft">
      <div class="section-header">
        <div>
          <h2 class="section-title">Set Workout</h2>
          <p class="section-subtitle">Customize the workout before you start.</p>
        </div>
      </div>

      <form id="workout-builder-form" class="workout-form">
        <div id="workout-form-fields"></div>

        <div class="workout-form-actions">
          <button type="submit" class="button-primary">Start Workout</button>
        </div>
      </form>
    </article>
  </section>

  <section class="section">
    <article class="card" id="live-workout-card" hidden>
      <div class="section-header">
        <div>
          <h2 class="section-title">Live Workout</h2>
          <p class="section-subtitle">
            Fill in your real results and check each step off as you go.
          </p>
        </div>
      </div>

      <div class="workout-session-notes">
        <label class="workout-field">
          <span>Workout Notes</span>
          <textarea
            id="cardio-workout-notes"
            class="workout-actual-textarea"
            rows="4"
            placeholder="Overall notes for this cardio workout"
          ></textarea>
        </label>
      </div>

      <div id="live-workout-summary" class="live-workout-summary"></div>
      <ul id="live-workout-steps" class="routine-list workout-live-list"></ul>

      <div class="workout-form-actions multi-action-workout-actions">
        <button id="save-splits-button" type="button" class="button-secondary">
          Save Splits / Times
        </button>

        <button id="open-manual-metrics-button" type="button" class="button-secondary">
          Fill In Metrics Manually
        </button>

        <button id="auto-calculate-metrics-button" type="button" class="button-secondary">
          Auto Calculate Metrics
        </button>

        <button id="save-completed-workout-button" type="button" class="button-primary">
          Save Completed Workout
        </button>

        <button id="reset-workout-button" type="button" class="button-secondary">
          Reset Workout
        </button>
      </div>

      <div id="manual-metrics-panel" class="cardio-metrics-panel" hidden></div>
      <div id="visible-calculated-metrics" class="session-metrics"></div>
    </article>
  </section>

  <script is:inline>
    const pageKey = "cardio-workout-builder";

    const fitnessHistoryPageKey = "fitness-history";
    const profileStatsPageKey = "profile-stats";

    const defaultWorkoutTypes = {
      hiit: {
        label: "HIIT",
        fields: [
          { name: "rounds", label: "Intervals", type: "number", min: 1, value: 8 },
          { name: "workSeconds", label: "Work Time (seconds)", type: "number", min: 5, value: 30 },
          { name: "restSeconds", label: "Rest Time (seconds)", type: "number", min: 5, value: 30 },
        ],
      },
      intervals: {
        label: "Intervals",
        fields: [
          { name: "sprintCount", label: "Number of Sprints", type: "number", min: 1, value: 4 },
          { name: "sprintDistance", label: "Sprint Distance", type: "text", value: "200m" },
          { name: "sprintTargetTime", label: "Sprint Target Time", type: "text", value: "0:35" },
          { name: "restDistance", label: "Jog Rest Distance", type: "text", value: "100m" },
        ],
      },
      steady: {
        label: "Steady State",
        fields: [
          { name: "pace", label: "Target Pace", type: "text", value: "8:45 / mile" },
          { name: "distance", label: "Distance (miles)", type: "number", min: 1, step: "0.5", value: 5 },
        ],
      },
      tempo: {
        label: "Tempo Run",
        fields: [
          { name: "warmupDistance", label: "Warmup Distance (miles)", type: "number", min: 0, step: "0.5", value: 1 },
          { name: "tempoDistance", label: "Tempo Distance (miles)", type: "number", min: 0.5, step: "0.5", value: 3 },
          { name: "tempoPace", label: "Tempo Pace", type: "text", value: "7:15 / mile" },
          { name: "cooldownDistance", label: "Cooldown Distance (miles)", type: "number", min: 0, step: "0.5", value: 1 },
        ],
      },
      fartlek: {
        label: "Fartlek",
        fields: [
          { name: "cycles", label: "Hard / Easy Cycles", type: "number", min: 1, value: 6 },
          { name: "hardMinutes", label: "Hard Effort (minutes)", type: "number", min: 1, value: 2 },
          { name: "easyMinutes", label: "Easy Effort (minutes)", type: "number", min: 1, value: 2 },
          { name: "hardEffort", label: "Hard Effort Target", type: "text", value: "5K effort" },
          { name: "easyEffort", label: "Easy Effort Target", type: "text", value: "Easy jog" },
        ],
      },
      hill: {
        label: "Hill Repeats",
        fields: [
          { name: "repeatCount", label: "Hill Repeats", type: "number", min: 1, value: 6 },
          { name: "hillDistance", label: "Hill Distance", type: "text", value: "200m" },
          { name: "hillTarget", label: "Uphill Target", type: "text", value: "Hard effort" },
          { name: "recoveryType", label: "Recovery", type: "text", value: "Walk/jog back down" },
        ],
      },
      power: {
        label: "Power Workout",
        fields: [
          { name: "intervalCount", label: "Power Intervals", type: "number", min: 1, value: 5 },
          { name: "workMinutes", label: "Work Interval (minutes)", type: "number", min: 1, value: 3 },
          { name: "targetWatts", label: "Target Watts", type: "number", min: 50, value: 250 },
          { name: "recoveryMinutes", label: "Recovery (minutes)", type: "number", min: 1, value: 2 },
        ],
      },
      recovery: {
        label: "Recovery Run",
        fields: [
          { name: "pace", label: "Target Pace", type: "text", value: "9:00 / mile" },
          { name: "distance", label: "Distance (miles)", type: "number", min: 1, step: "0.5", value: 3 },
        ],
      },
      longrun: {
        label: "Long Run",
        fields: [
          { name: "pace", label: "Target Pace", type: "text", value: "8:30 / mile" },
          { name: "distance", label: "Distance (miles)", type: "number", min: 1, step: "0.5", value: 10 },
        ],
      },
    };

    let workoutTypes = cloneWorkoutTypes(defaultWorkoutTypes);
    let selectedType = "hiit";
    let activeWorkout = null;
    let cardioHistory = [];
    let weightliftingHistory = [];
    let isEditingWorkoutTypes = false;
    let hasLoadedInitialState = false;
    let isSaving = false;
    let pendingSave = false;
    let savedLiveSteps = [];
    let visibleMetrics = {};
    let calculationMode = "";

    const workoutTypeSelect = document.getElementById("workout-type-select");
    const workoutTypeEditPanel = document.getElementById("workout-type-edit-panel");
    const editWorkoutTypesButton = document.getElementById("edit-workout-types-button");
    const formFields = document.getElementById("workout-form-fields");
    const form = document.getElementById("workout-builder-form");
    const liveWorkoutCard = document.getElementById("live-workout-card");
    const liveWorkoutSummary = document.getElementById("live-workout-summary");
    const liveWorkoutSteps = document.getElementById("live-workout-steps");
    const resetWorkoutButton = document.getElementById("reset-workout-button");
    const saveCompletedWorkoutButton = document.getElementById("save-completed-workout-button");
    const saveSplitsButton = document.getElementById("save-splits-button");
    const openManualMetricsButton = document.getElementById("open-manual-metrics-button");
    const autoCalculateMetricsButton = document.getElementById("auto-calculate-metrics-button");

    function getFormValues() {
      const formData = new FormData(form);
      const values = {};

      for (const [key, value] of formData.entries()) {
        values[key] = typeof value === "string" ? value.trim() : value;
      }

      return values;
    }
    function getCompletedLiveSteps(workout) {
      return Array.isArray(workout?.steps)
        ? workout.steps
            .filter((step) => step?.done)
            .map((step) => ({
              text: step.text || "",
              actual: step.actual || "",
              done: true,
            }))
        : [];
    }

    function saveCurrentSplits() {
      if (!activeWorkout) return;

      savedLiveSteps = getCompletedLiveSteps(activeWorkout);
      renderVisibleMetrics();

      window.alert("Splits and completed step times saved.");
    }
    function getManualMetricFieldsForWorkout(type) {
      if (["steady", "recovery", "longrun", "tempo"].includes(type)) {
        return [
          { name: "totalDistance", label: "Total Distance (miles)" },
          { name: "totalTimeDisplay", label: "Total Time (ex: 42:18)" },
          { name: "averagePaceDisplay", label: "Average Pace (ex: 8:28 / mile)" },
          { name: "calories", label: "Calories" },
          { name: "heartRate", label: "Average Heart Rate (bpm)" },
        ];
      }

      if (["intervals", "hiit", "fartlek", "hill", "power"].includes(type)) {
        return [
          { name: "totalTimeDisplay", label: "Total Time" },
          { name: "totalDistance", label: "Total Distance" },
          { name: "calories", label: "Calories" },
          { name: "heartRate", label: "Average Heart Rate (bpm)" },
        ];
      }

      return [
        { name: "totalTimeDisplay", label: "Total Time" },
        { name: "totalDistance", label: "Total Distance" },
      ];
    }

    function renderManualMetricsPanel() {
      const panel = document.getElementById("manual-metrics-panel");
      if (!panel || !activeWorkout) return;

      const fields = getManualMetricFieldsForWorkout(activeWorkout.type);

      panel.hidden = false;
      panel.innerHTML = `
        <div class="section-header">
          <div>
            <h3 class="section-title">Manual Metrics</h3>
            <p class="section-subtitle">Enter any totals or derived values you want saved.</p>
          </div>
        </div>

        <div class="workout-form">
          ${fields.map((field) => `
            <label class="workout-field">
              <span>${field.label}</span>
              <input
                type="text"
                name="${field.name}"
                value="${visibleMetrics[field.name] ?? ""}"
              />
            </label>
          `).join("")}
        </div>

        <div class="workout-form-actions">
          <button id="save-manual-metrics-button" type="button" class="button-primary">
            Save Manual Metrics
          </button>
        </div>
      `;

      document.getElementById("save-manual-metrics-button")?.addEventListener("click", () => {
        const inputs = panel.querySelectorAll("input[name]");
        const nextMetrics = { ...visibleMetrics };

        inputs.forEach((input) => {
          nextMetrics[input.name] = input.value.trim();
        });

        visibleMetrics = normalizeVisibleMetrics(nextMetrics);
        calculationMode = "manual";
        renderVisibleMetrics();
      });
    }

    function normalizeVisibleMetrics(metrics) {
      const normalized = { ...metrics };

      if (normalized.totalDistance !== undefined) {
        const num = Number(normalized.totalDistance);
        normalized.totalDistance = Number.isFinite(num) ? Number(num.toFixed(2)) : 0;
      }

      if (normalized.totalTimeDisplay) {
        normalized.totalTimeMinutes = roundToTwo(parseTimeToMinutes(normalized.totalTimeDisplay));
      }

      if (normalized.averagePaceDisplay) {
        normalized.averagePaceMinutes = roundToTwo(parseTimeToMinutes(normalized.averagePaceDisplay));
      }

      if (!normalized.averagePaceDisplay && normalized.averagePaceMinutes > 0) {
        normalized.averagePaceDisplay = formatPaceFromMinutes(normalized.averagePaceMinutes);
      }

      if (!normalized.totalTimeDisplay && normalized.totalTimeMinutes > 0) {
        normalized.totalTimeDisplay = formatMinutesAsTime(normalized.totalTimeMinutes);
      }

      return normalized;
    }
    function createStep({
      text,
      target = "",
      actual = "",
      done = false,
      actualLabel = "Actual Result / Notes",
      actualPlaceholder = "Enter actual result",
    }) {
      return {
        text,
        target,
        actual,
        done,
        actualLabel,
        actualPlaceholder,
      };
    }
    async function loadFitnessHistory() {
      try {
        const res = await fetch(`/api/state?pageKey=${encodeURIComponent(fitnessHistoryPageKey)}`, {
          credentials: "include",
          cache: "no-store",
        });

        if (!res.ok) return { weightliftingSessions: [], cardioSessions: [] };

        const data = await res.json();
        const history = data?.state ?? {};
        return {
          weightliftingSessions: Array.isArray(history?.weightliftingSessions)
            ? history.weightliftingSessions
            : [],
          cardioSessions: Array.isArray(history?.cardioSessions) ? history.cardioSessions : [],
        };
      } catch (error) {
        console.error("Failed to load fitness history:", error);
        return { weightliftingSessions: [], cardioSessions: [] };
      }
    }

    async function saveFitnessHistory(nextState) {
      try {
        await fetch("/api/state", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ pageKey: fitnessHistoryPageKey, state: nextState }),
        });
      } catch (error) {
        console.error("Failed to save fitness history:", error);
      }
    }

    async function loadProfileStats() {
      try {
        const res = await fetch(`/api/state?pageKey=${encodeURIComponent(profileStatsPageKey)}`, {
          credentials: "include",
          cache: "no-store",
        });

        if (!res.ok) return { fitness: {}, hobbies: {} };

        const data = await res.json();
        return data?.state ?? { fitness: {}, hobbies: {} };
      } catch (error) {
        console.error("Failed to load profile stats:", error);
        return { fitness: {}, hobbies: {} };
      }
    }

    function buildFitnessStats(historyState) {
      const weightSessions = Array.isArray(historyState?.weightliftingSessions)
        ? historyState.weightliftingSessions
        : [];
      const cardioSessions = Array.isArray(historyState?.cardioSessions) ? historyState.cardioSessions : [];
      const latestDate = [...weightSessions, ...cardioSessions]
        .map((item) => item?.dateTime || "")
        .filter(Boolean)
        .sort((a, b) => new Date(b).getTime() - new Date(a).getTime())[0] || "";

      return {
        totalWeightliftingSessions: weightSessions.length,
        totalCardioSessions: cardioSessions.length,
        totalFitnessSessions: weightSessions.length + cardioSessions.length,
        lastWorkoutAt: latestDate,
        updatedAt: new Date().toISOString(),
      };
    }

    async function syncFitnessStats() {
      const existingStats = await loadProfileStats();
      await fetch("/api/state", {
        method: "POST",
        credentials: "include",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          pageKey: profileStatsPageKey,
          state: {
            ...existingStats,
            fitness: buildFitnessStats({
              weightliftingSessions: weightliftingHistory,
              cardioSessions: cardioHistory,
            }),
          },
        }),
      });
    }

    function cloneWorkoutTypes(types) {
      return JSON.parse(JSON.stringify(types));
    }

    function slugify(value) {
      return String(value || "")
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "");
    }

    function getWorkoutTypeEntries() {
      return Object.entries(workoutTypes);
    }

    function getFirstWorkoutTypeKey() {
      return getWorkoutTypeEntries()[0]?.[0] || "";
    }

    function ensureSelectedTypeExists() {
      if (!workoutTypes[selectedType]) {
        selectedType = getFirstWorkoutTypeKey();
      }
    }

    function createDefaultFieldSetForType(typeKey) {
      if (typeKey === "hiit") {
        return [
          { name: "rounds", label: "Intervals", type: "number", min: 1, value: 8 },
          { name: "workSeconds", label: "Work Time (seconds)", type: "number", min: 5, value: 30 },
          { name: "restSeconds", label: "Rest Time (seconds)", type: "number", min: 5, value: 30 },
        ];
      }

      if (typeKey === "intervals") {
        return [
          { name: "sprintCount", label: "Number of Sprints", type: "number", min: 1, value: 4 },
          { name: "sprintDistance", label: "Sprint Distance", type: "text", value: "200m" },
          { name: "sprintTargetTime", label: "Sprint Target Time", type: "text", value: "0:35" },
          { name: "restDistance", label: "Jog Rest Distance", type: "text", value: "100m" },
        ];
      }

      if (typeKey === "tempo") {
        return [
          { name: "warmupDistance", label: "Warmup Distance (miles)", type: "number", min: 0, step: "0.5", value: 1 },
          { name: "tempoDistance", label: "Tempo Distance (miles)", type: "number", min: 0.5, step: "0.5", value: 3 },
          { name: "tempoPace", label: "Tempo Pace", type: "text", value: "7:15 / mile" },
          { name: "cooldownDistance", label: "Cooldown Distance (miles)", type: "number", min: 0, step: "0.5", value: 1 },
        ];
      }

      if (typeKey === "fartlek") {
        return [
          { name: "cycles", label: "Hard / Easy Cycles", type: "number", min: 1, value: 6 },
          { name: "hardMinutes", label: "Hard Effort (minutes)", type: "number", min: 1, value: 2 },
          { name: "easyMinutes", label: "Easy Effort (minutes)", type: "number", min: 1, value: 2 },
          { name: "hardEffort", label: "Hard Effort Target", type: "text", value: "5K effort" },
          { name: "easyEffort", label: "Easy Effort Target", type: "text", value: "Easy jog" },
        ];
      }

      if (typeKey === "hill") {
        return [
          { name: "repeatCount", label: "Hill Repeats", type: "number", min: 1, value: 6 },
          { name: "hillDistance", label: "Hill Distance", type: "text", value: "200m" },
          { name: "hillTarget", label: "Uphill Target", type: "text", value: "Hard effort" },
          { name: "recoveryType", label: "Recovery", type: "text", value: "Walk/jog back down" },
        ];
      }

      if (typeKey === "power") {
        return [
          { name: "intervalCount", label: "Power Intervals", type: "number", min: 1, value: 5 },
          { name: "workMinutes", label: "Work Interval (minutes)", type: "number", min: 1, value: 3 },
          { name: "targetWatts", label: "Target Watts", type: "number", min: 50, value: 250 },
          { name: "recoveryMinutes", label: "Recovery (minutes)", type: "number", min: 1, value: 2 },
        ];
      }

      return [
        { name: "pace", label: "Target Pace", type: "text", value: "9:00 / mile" },
        { name: "distance", label: "Distance (miles)", type: "number", min: 1, step: "0.5", value: 3 },
      ];
    }

    function normalizeSavedWorkoutTypes(savedTypes) {
      if (!savedTypes || typeof savedTypes !== "object") {
        return cloneWorkoutTypes(defaultWorkoutTypes);
      }

      const normalized = {};

      Object.entries(savedTypes).forEach(([key, config]) => {
        if (!config || typeof config !== "object") return;

        const safeKey = slugify(key);
        if (!safeKey) return;

        const label = String(config.label || safeKey).trim() || safeKey;
        const fields = Array.isArray(config.fields) && config.fields.length
          ? config.fields.map((field, index) => ({
              name: String(field.name || `field-${index + 1}`).trim() || `field-${index + 1}`,
              label: String(field.label || `Field ${index + 1}`).trim() || `Field ${index + 1}`,
              type: field.type === "number" ? "number" : "text",
              min: field.min ?? "",
              step: field.step ?? "",
              value: field.value ?? "",
            }))
          : createDefaultFieldSetForType(safeKey);

        normalized[safeKey] = { label, fields };
      });

      if (!Object.keys(normalized).length) {
        return cloneWorkoutTypes(defaultWorkoutTypes);
      }

      return normalized;
    }

function parseTimeToMinutes(value) {
  const text = String(value || "")
    .trim()
    .toLowerCase()
    .replace(/\/\s*mile/g, "")
    .replace(/\s*per\s*mile/g, "")
    .trim();

  if (!text) return 0;

  const hms = text.match(/^(\d+):(\d{1,2}):(\d{2})$/);
  if (hms) {
    const hours = Number(hms[1] || 0);
    const minutes = Number(hms[2] || 0);
    const seconds = Number(hms[3] || 0);
    return hours * 60 + minutes + seconds / 60;
  }

  const ms = text.match(/^(\d+):(\d{1,2})$/);
  if (ms) {
    const minutes = Number(ms[1] || 0);
    const seconds = Number(ms[2] || 0);
    return minutes + seconds / 60;
  }

  const numeric = Number(text);
  return Number.isFinite(numeric) ? numeric : 0;
}

function formatMinutesAsTime(totalMinutes) {
  if (!Number.isFinite(totalMinutes) || totalMinutes <= 0) return "";

  const totalSeconds = Math.round(totalMinutes * 60);
  const hours = Math.floor(totalSeconds / 3600);
  const minutes = Math.floor((totalSeconds % 3600) / 60);
  const seconds = totalSeconds % 60;

  if (hours > 0) {
    return `${hours}:${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
  }

  return `${minutes}:${String(seconds).padStart(2, "0")}`;
}

function formatPaceFromMinutes(minutesPerMile) {
  if (!Number.isFinite(minutesPerMile) || minutesPerMile <= 0) return "";

  const totalSeconds = Math.round(minutesPerMile * 60);
  const minutes = Math.floor(totalSeconds / 60);
  const seconds = totalSeconds % 60;
  return `${minutes}:${String(seconds).padStart(2, "0")} / mile`;
}

function isRunWorkoutType(type) {
  return ["steady", "recovery", "longrun", "tempo"].includes(type);
}

function roundToTwo(value) {
  return Number.isFinite(value) ? Number(value.toFixed(2)) : 0;
}

function getRunDistanceFromValues(type, values) {
  if (type === "tempo") {
    return (
      Number(values.warmupDistance || 0) +
      Number(values.tempoDistance || 0) +
      Number(values.cooldownDistance || 0)
    );
  }

  return Number(values.distance || 0);
}

function getPlannedRunMetrics(type, values) {
  const distance = getRunDistanceFromValues(type, values);

  const totalTimeMinutes = parseTimeToMinutes(values.totalTime);
  const paceMinutes = parseTimeToMinutes(values.pace);

  let resolvedTotalTimeMinutes = 0;
  let resolvedPaceMinutes = 0;

  if (distance > 0 && paceMinutes > 0 && totalTimeMinutes <= 0) {
    resolvedPaceMinutes = paceMinutes;
    resolvedTotalTimeMinutes = distance * paceMinutes;
  } else if (distance > 0 && totalTimeMinutes > 0 && paceMinutes <= 0) {
    resolvedTotalTimeMinutes = totalTimeMinutes;
    resolvedPaceMinutes = totalTimeMinutes / distance;
  } else if (distance > 0 && totalTimeMinutes > 0 && paceMinutes > 0) {
    resolvedTotalTimeMinutes = totalTimeMinutes;
    resolvedPaceMinutes = paceMinutes;
  } else {
    resolvedTotalTimeMinutes = totalTimeMinutes > 0 ? totalTimeMinutes : 0;
    resolvedPaceMinutes = paceMinutes > 0 ? paceMinutes : 0;
  }

  return {
    distance: roundToTwo(distance),
    totalTimeMinutes: roundToTwo(resolvedTotalTimeMinutes),
    paceMinutes: roundToTwo(resolvedPaceMinutes),
    totalTimeDisplay: formatMinutesAsTime(resolvedTotalTimeMinutes),
    paceDisplay: formatPaceFromMinutes(resolvedPaceMinutes),
  };
}

function parseOverallActualTimeFromWorkout(workout) {
  const steps = Array.isArray(workout?.steps) ? workout.steps : [];
  const finishStep = [...steps].reverse().find((step) =>
    String(step?.text || "").toLowerCase().includes("finish")
  );

  if (!finishStep?.actual) return 0;

  const firstLine = String(finishStep.actual).split("\n")[0].trim();
  return parseTimeToMinutes(firstLine);
}

function parseStepDistanceInMiles(step) {
  const combined = `${step?.text || ""} ${step?.target || ""}`.toLowerCase();

  const finalMileMatch = combined.match(/final\s+(\d+(?:\.\d+)?)\s*mile/);
  if (finalMileMatch) {
    const miles = Number(finalMileMatch[1]);
    return Number.isFinite(miles) ? miles : 0;
  }

  const standardMileMatch = combined.match(/(\d+(?:\.\d+)?)\s*(?:mi|mile|miles)\b/);
  if (standardMileMatch) {
    const miles = Number(standardMileMatch[1]);
    return Number.isFinite(miles) ? miles : 0;
  }

  const reversedMileMatch = combined.match(/\bmile\s+(\d+(?:\.\d+)?)\b/);
  if (reversedMileMatch) {
    const miles = Number(reversedMileMatch[1]);
    return Number.isFinite(miles) ? miles : 0;
  }

  const kmMatch = combined.match(/(\d+(?:\.\d+)?)\s*km\b/);
  if (kmMatch) {
    const km = Number(kmMatch[1]);
    return Number.isFinite(km) ? km * 0.621371 : 0;
  }

  const meterMatch = combined.match(/(\d+(?:\.\d+)?)\s*m\b/);
  if (meterMatch) {
    const meters = Number(meterMatch[1]);
    return Number.isFinite(meters) ? meters / 1609.34 : 0;
  }

  return 0;
}

function isDistanceSplitStep(step) {
  const combined = `${step?.text || ""} ${step?.target || ""}`.toLowerCase();
  return (
    combined.includes("mile") ||
    combined.includes("mi") ||
    combined.includes("km") ||
    combined.includes("m")
  );
}

function calculateCardioMetricsFromCompletedSteps(workout) {
  const steps = Array.isArray(workout?.steps)
    ? workout.steps.filter((step) => step?.done)
    : [];

  let totalDistance = 0;
  let totalTimeMinutes = 0;

  for (const step of steps) {
    if (!isDistanceSplitStep(step)) continue;

    const distance = parseStepDistanceInMiles(step);
    const timeMinutes = parseTimeToMinutes(step.actual);

    if (distance > 0 && timeMinutes > 0) {
      totalDistance += distance;
      totalTimeMinutes += timeMinutes;
    }
  }

  const averagePaceMinutes =
    totalDistance > 0 && totalTimeMinutes > 0 ? totalTimeMinutes / totalDistance : 0;

  return {
    totalDistance: totalDistance > 0 ? Number(totalDistance.toFixed(2)) : 0,
    totalTimeMinutes: totalTimeMinutes > 0 ? Number(totalTimeMinutes.toFixed(2)) : 0,
    averagePaceMinutes: averagePaceMinutes > 0 ? Number(averagePaceMinutes.toFixed(2)) : 0,
    totalTimeDisplay: formatMinutesAsTime(totalTimeMinutes),
    averagePaceDisplay: formatPaceFromMinutes(averagePaceMinutes),
  };
}

