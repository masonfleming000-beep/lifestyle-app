---
import BaseLayout from "../layouts/BaseLayout.astro";
import { cardioRules, cardioGoals, warmup, cooldown, recentSessions } from "../data/cardio";

const stravaEmbedUrl =
  "https://www.strava.com/athletes/115475457/latest-rides/6aa243149a11d283a34873ef8f65f506d1cba24e";

const defaultWarmupItems = JSON.stringify(warmup);
const defaultCooldownItems = JSON.stringify(cooldown);
---

<BaseLayout title="Cardio | Lifestyle App" description="Cardio dashboard">
  <section class="hero">
    <div class="hero-card">
      <p class="kicker">Cardio</p>
      <h1>Build endurance with structure.</h1>
      <p>
        A cleaner cardio page with your Strava feed, goals, rules, and saved
        warm-up / cool-down checklists.
      </p>
    </div>
  </section>

  <section class="section">
    <article class="card soft">
      <div class="section-header">
        <div>
          <h2 class="section-title">Strava</h2>
          <p class="section-subtitle">Latest activity snapshot.</p>
        </div>
      </div>

      <div class="running-embed-shell">
        <iframe
          src={stravaEmbedUrl}
          title="Strava latest cardio activities"
          frameborder="0"
          scrolling="no"
          loading="lazy"
          allowtransparency="true"
        ></iframe>
      </div>
    </article>
  </section>

  <div class="section-actions">
    <a href="/cardio/workouts" class="button-primary">Build Workout</a>
  </div>

  <section class="section">
    <div class="grid two">
      <details class="dropdown-card" open>
        <summary>
          <div>
            <p class="kicker">Cardio</p>
            <h2 class="section-title">Rules</h2>
          </div>
          <span class="dropdown-arrow">⌄</span>
        </summary>

        <div class="dropdown-content">
          <ul class="list-clean">
            {cardioRules.map((rule) => (
              <li>{rule}</li>
            ))}
          </ul>
        </div>
      </details>

      <details class="dropdown-card">
        <summary>
          <div>
            <p class="kicker">Cardio</p>
            <h2 class="section-title">Goals</h2>
          </div>
          <span class="dropdown-arrow">⌄</span>
        </summary>

        <div class="dropdown-content">
          <ul class="list-clean">
            {cardioGoals.map((goal) => (
              <li>{goal}</li>
            ))}
          </ul>
        </div>
      </details>
    </div>
  </section>

  <section class="section">
    <article class="card">
      <h2 class="section-title">Recent Sessions</h2>
      <ul class="list-clean">
        {recentSessions.map((session) => (
          <li><strong>{session.title}</strong> — {session.detail}</li>
        ))}
      </ul>
    </article>
  </section>

  <section class="section">
    <div class="grid two">
      <details class="dropdown-card" open>
        <summary>
          <div>
            <p class="kicker">Checklist</p>
            <h2 class="section-title">Warm Up</h2>
          </div>
          <span class="dropdown-arrow">⌄</span>
        </summary>

        <div class="dropdown-content">
          <ul id="cardio-warmup-list" class="routine-list"></ul>
        </div>
      </details>

      <details class="dropdown-card">
        <summary>
          <div>
            <p class="kicker">Checklist</p>
            <h2 class="section-title">Cool Down</h2>
          </div>
          <span class="dropdown-arrow">⌄</span>
        </summary>

        <div class="dropdown-content">
          <ul id="cardio-cooldown-list" class="routine-list"></ul>
        </div>
      </details>
    </div>
  </section>

  <script define:vars={{ defaultWarmupItems, defaultCooldownItems }}>
    const pageKey = "cardio";

    const warmupListEl = document.getElementById("cardio-warmup-list");
    const cooldownListEl = document.getElementById("cardio-cooldown-list");

    const defaultWarmupChecklist = JSON.parse(defaultWarmupItems);
    const defaultCooldownChecklist = JSON.parse(defaultCooldownItems);

    let state = {
      warmup: defaultWarmupChecklist.map((text) => ({ text, done: false })),
      cooldown: defaultCooldownChecklist.map((text) => ({ text, done: false })),
    };

    let hasLoadedInitialState = false;
    let isSaving = false;
    let pendingSave = false;

    function mergeDefaults(savedItems, defaultItems, keyFn) {
      const merged = [...(savedItems || [])];

      defaultItems.forEach((defaultItem) => {
        const exists = merged.some((item) => keyFn(item) === keyFn(defaultItem));
        if (!exists) merged.push(defaultItem);
      });

      return merged;
    }

    async function loadState() {
      try {
        const res = await fetch(`/api/state?pageKey=${encodeURIComponent(pageKey)}`, {
          credentials: "include",
          cache: "no-store",
        });

        if (!res.ok) return null;

        const data = await res.json();
        console.log("[cardio] loaded state", data?.state);
        return data?.state ?? null;
      } catch (error) {
        console.error("Failed to load state:", error);
        return null;
      }
    }

    async function saveState() {
      if (!hasLoadedInitialState) return;

      if (isSaving) {
        pendingSave = true;
        return;
      }

      isSaving = true;

      try {
        console.log("[cardio] saving state", state);

        await fetch("/api/state", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ pageKey, state }),
        });
      } catch (error) {
        console.error("Failed to save state:", error);
      } finally {
        isSaving = false;

        if (pendingSave) {
          pendingSave = false;
          await saveState();
        }
      }
    }

    function renderChecklist(listEl, key) {
      if (!listEl) return;

      listEl.innerHTML = "";

      state[key].forEach((item, itemIndex) => {
        const li = document.createElement("li");
        li.className = "routine-item" + (item.done ? " is-done" : "");

        const label = document.createElement("label");
        label.className = "routine-left";

        const checkbox = document.createElement("input");
        checkbox.type = "checkbox";
        checkbox.checked = !!item.done;

        checkbox.addEventListener("change", async () => {
          console.log("[cardio] rendering", key, state[key]);
          state[key][itemIndex].done = checkbox.checked;
          renderChecklist(listEl, key);
          await saveState();
        });

        const text = document.createElement("span");
        text.textContent = item.text;

        label.appendChild(checkbox);
        label.appendChild(text);
        li.appendChild(label);
        listEl.appendChild(li);
      });
    }

    async function init() {
      renderChecklist(warmupListEl, "warmup");
      renderChecklist(cooldownListEl, "cooldown");

      const saved = await loadState();
      console.log("[cardio] saved from api", saved);

      state = {
        warmup: mergeDefaults(
          saved?.warmup,
          defaultWarmupChecklist.map((text) => ({ text, done: false })),
          (item) => item.text
        ).map((item) => ({
          text: item.text,
          done: !!item.done,
        })),
        cooldown: mergeDefaults(
          saved?.cooldown,
          defaultCooldownChecklist.map((text) => ({ text, done: false })),
          (item) => item.text
        ).map((item) => ({
          text: item.text,
          done: !!item.done,
        })),
      };

      console.log("[cardio] normalized state", state);

      hasLoadedInitialState = true;

      renderChecklist(warmupListEl, "warmup");
      renderChecklist(cooldownListEl, "cooldown");

    }

    init();
  </script>
</BaseLayout>