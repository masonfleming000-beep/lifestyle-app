---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  cardioRules,
  cardioGoals,
  warmup,
  cooldown,
  recentSessions,
  defaultStravaEmbed,
} from "../data/cardio";

const defaultWarmupItems = JSON.stringify(warmup);
const defaultCooldownItems = JSON.stringify(cooldown);
const defaultRulesItems = JSON.stringify(cardioRules);
const defaultGoalsItems = JSON.stringify(cardioGoals);
const defaultStravaValue = JSON.stringify(defaultStravaEmbed);
---

<BaseLayout title="Cardio | Lifestyle App" description="Cardio dashboard">
  <section class="hero">
    <div class="hero-card">
      <p class="kicker">Cardio</p>
      <h1>Build endurance with structure.</h1>
      <p>
        A cleaner cardio page with your Strava feed, goals, rules, and saved
        warm-up / cool-down checklists.
      </p>
    </div>
  </section>

  <section class="section">
    <article class="card">
      <div class="section-header">
        <div>
          <h2 class="section-title">Strava</h2>
          <p class="section-subtitle">Latest activity snapshot.</p>
        </div>
      </div>

      <div id="cardio-strava-container"></div>
    </article>
  </section>

  <div class="section-actions">
    <a href="/cardio/workouts" class="button-primary">Build Workout</a>
  </div>

  <section class="section">
    <div class="grid two">
      <details class="dropdown-card" open>
        <summary>
          <div>
            <p class="kicker">Cardio</p>
            <h2 class="section-title">Rules</h2>
          </div>
          <span class="dropdown-arrow">⌄</span>
        </summary>

        <div class="dropdown-content">
          <div class="editor-toolbar">
            <button id="rules-edit-btn" type="button" class="button-secondary">
              Edit
            </button>
          </div>
          <ul id="cardio-rules-list" class="list-clean editable-list"></ul>
        </div>
      </details>

      <details class="dropdown-card">
        <summary>
          <div>
            <p class="kicker">Cardio</p>
            <h2 class="section-title">Goals</h2>
          </div>
          <span class="dropdown-arrow">⌄</span>
        </summary>

        <div class="dropdown-content">
          <div class="editor-toolbar">
            <button id="goals-edit-btn" type="button" class="button-secondary">
              Edit
            </button>
          </div>
          <ul id="cardio-goals-list" class="list-clean editable-list"></ul>
        </div>
      </details>
    </div>
  </section>

  <section class="section">
    <article class="card">
      <h2 class="section-title">Recent Sessions</h2>
      <ul class="list-clean">
        {recentSessions.map((session) => (
          <li><strong>{session.title}</strong> — {session.detail}</li>
        ))}
      </ul>
    </article>
  </section>

  <section class="section">
    <div class="grid two">
      <details class="dropdown-card" open>
        <summary>
          <div>
            <p class="kicker">Checklist</p>
            <h2 class="section-title">Warm Up</h2>
          </div>
          <span class="dropdown-arrow">⌄</span>
        </summary>

        <div class="dropdown-content">
          <div class="editor-toolbar">
            <button id="warmup-edit-btn" type="button" class="button-secondary">
              Edit
            </button>
          </div>
          <ul id="cardio-warmup-list" class="routine-list editable-list"></ul>
        </div>
      </details>

      <details class="dropdown-card">
        <summary>
          <div>
            <p class="kicker">Checklist</p>
            <h2 class="section-title">Cool Down</h2>
          </div>
          <span class="dropdown-arrow">⌄</span>
        </summary>

        <div class="dropdown-content">
          <div class="editor-toolbar">
            <button id="cooldown-edit-btn" type="button" class="button-secondary">
              Edit
            </button>
          </div>
          <ul id="cardio-cooldown-list" class="routine-list editable-list"></ul>
        </div>
      </details>
    </div>
  </section>

  <script
    define:vars={{
      defaultWarmupItems,
      defaultCooldownItems,
      defaultRulesItems,
      defaultGoalsItems,
      defaultStravaValue,
    }}
  >
    const pageKey = "cardio";

    const warmupListEl = document.getElementById("cardio-warmup-list");
    const cooldownListEl = document.getElementById("cardio-cooldown-list");
    const rulesListEl = document.getElementById("cardio-rules-list");
    const goalsListEl = document.getElementById("cardio-goals-list");
    const stravaContainerEl = document.getElementById("cardio-strava-container");

    const rulesEditBtn = document.getElementById("rules-edit-btn");
    const goalsEditBtn = document.getElementById("goals-edit-btn");
    const warmupEditBtn = document.getElementById("warmup-edit-btn");
    const cooldownEditBtn = document.getElementById("cooldown-edit-btn");

    const defaultWarmupChecklist = JSON.parse(defaultWarmupItems);
    const defaultCooldownChecklist = JSON.parse(defaultCooldownItems);
    const defaultRulesList = JSON.parse(defaultRulesItems);
    const defaultGoalsList = JSON.parse(defaultGoalsItems);
    const defaultStravaEmbedUrl = JSON.parse(defaultStravaValue);

    const defaultWarmupState = defaultWarmupChecklist.map((text) => ({ text, done: false }));
    const defaultCooldownState = defaultCooldownChecklist.map((text) => ({ text, done: false }));
    const defaultRulesState = [...defaultRulesList];
    const defaultGoalsState = [...defaultGoalsList];

    const defaultWarmupTexts = new Set(defaultWarmupChecklist);
    const defaultCooldownTexts = new Set(defaultCooldownChecklist);
    const defaultRulesTexts = new Set(defaultRulesList);
    const defaultGoalsTexts = new Set(defaultGoalsList);

    let editMode = {
      rules: false,
      goals: false,
      warmup: false,
      cooldown: false,
    };

    let state = {
      warmup: defaultWarmupChecklist.map((text) => ({ text, done: false })),
      cooldown: defaultCooldownChecklist.map((text) => ({ text, done: false })),
      rules: [...defaultRulesList],
      goals: [...defaultGoalsList],
      stravaEmbed: defaultStravaEmbedUrl || "",
      removedDefaults: {
        warmup: [],
        cooldown: [],
        rules: [],
        goals: [],
      },
    };

    let hasLoadedInitialState = false;
    let isSaving = false;
    let pendingSave = false;

    function uniqueStrings(items = []) {
      return [...new Set(items.filter(Boolean))];
    }

    function normalizeChecklistItems(items = []) {
      if (!Array.isArray(items)) return [];
      return items
        .map((item) => {
          if (!item || typeof item !== "object") return null;
          const text = typeof item.text === "string" ? item.text.trim() : "";
          if (!text) return null;
          return {
            text,
            done: !!item.done,
          };
        })
        .filter(Boolean);
    }

    function normalizeStringItems(items = []) {
      if (!Array.isArray(items)) return [];
      return uniqueStrings(
        items.map((item) => (typeof item === "string" ? item.trim() : "")).filter(Boolean)
      );
    }

    function mergeDefaults(savedItems, defaultItems, keyFn, removedKeys = []) {
      const removedSet = new Set(removedKeys || []);
      const merged = [...(savedItems || [])];

      defaultItems.forEach((defaultItem) => {
        const key = keyFn(defaultItem);
        const exists = merged.some((item) => keyFn(item) === key);

        if (!exists && !removedSet.has(key)) {
          merged.push(defaultItem);
        }
      });

      return merged;
    }

    function mergeStringDefaults(savedItems, defaultItems, removedItems = []) {
      const removedSet = new Set(removedItems || []);
      const merged = [...(savedItems || [])];

      defaultItems.forEach((defaultItem) => {
        if (!merged.includes(defaultItem) && !removedSet.has(defaultItem)) {
          merged.push(defaultItem);
        }
      });

      return merged;
    }

    function splitChecklistAgainstDefaults(items, defaultTextsSet) {
      const normalizedItems = normalizeChecklistItems(items);

      const removedDefaults = normalizedItems
        .filter((item) => item.removedDefault === true)
        .map((item) => item.text);

      const customItems = normalizedItems
        .filter((item) => !defaultTextsSet.has(item.text))
        .map((item) => ({
          text: item.text,
          done: !!item.done,
        }));

      return {
        customItems,
        removedDefaults: uniqueStrings(removedDefaults),
      };
    }

    function splitStringsAgainstDefaults(items, defaultTextsSet) {
      const normalizedItems = normalizeStringItems(items);

      const removedDefaults = normalizedItems.filter((item) => item.startsWith("__removed__:"));
      const customItems = normalizedItems.filter(
        (item) => !defaultTextsSet.has(item) && !item.startsWith("__removed__:")
      );

      return {
        customItems,
        removedDefaults: uniqueStrings(
          removedDefaults.map((item) => item.replace(/^__removed__:/, ""))
        ),
      };
    }

    function buildChecklistState(customItems = [], defaultItems = [], removedDefaults = []) {
      const merged = mergeDefaults(
        normalizeChecklistItems(customItems),
        defaultItems.map((item) => ({ ...item })),
        (item) => item.text,
        uniqueStrings(removedDefaults)
      );

      return merged.map((item) => ({
        text: item.text,
        done: !!item.done,
      }));
    }

    function buildStringState(customItems = [], defaultItems = [], removedDefaults = []) {
      return mergeStringDefaults(
        normalizeStringItems(customItems),
        [...defaultItems],
        uniqueStrings(removedDefaults)
      ).filter(Boolean);
    }

    function normalizeCardioState(raw) {
      const parsed = raw && typeof raw === "object" ? raw : {};

      const removedDefaults = {
        warmup: uniqueStrings(parsed?.removedDefaults?.warmup),
        cooldown: uniqueStrings(parsed?.removedDefaults?.cooldown),
        rules: uniqueStrings(parsed?.removedDefaults?.rules),
        goals: uniqueStrings(parsed?.removedDefaults?.goals),
      };

      const hasNewShape =
        parsed?.removedDefaults &&
        typeof parsed.removedDefaults === "object";

      if (hasNewShape) {
        const normalizedWarmupSaved = normalizeChecklistItems(parsed?.warmup);
        const normalizedCooldownSaved = normalizeChecklistItems(parsed?.cooldown);
        const normalizedRulesSaved = normalizeStringItems(parsed?.rules);
        const normalizedGoalsSaved = normalizeStringItems(parsed?.goals);

        const warmupCustom = normalizedWarmupSaved.filter(
          (item) => !defaultWarmupTexts.has(item.text)
        );
        const cooldownCustom = normalizedCooldownSaved.filter(
          (item) => !defaultCooldownTexts.has(item.text)
        );
        const rulesCustom = normalizedRulesSaved.filter(
          (item) => !defaultRulesTexts.has(item)
        );
        const goalsCustom = normalizedGoalsSaved.filter(
          (item) => !defaultGoalsTexts.has(item)
        );

        return {
          removedDefaults,
          warmup: buildChecklistState(
            warmupCustom,
            defaultWarmupState,
            removedDefaults.warmup
          ),
          cooldown: buildChecklistState(
            cooldownCustom,
            defaultCooldownState,
            removedDefaults.cooldown
          ),
          rules: buildStringState(
            rulesCustom,
            defaultRulesState,
            removedDefaults.rules
          ),
          goals: buildStringState(
            goalsCustom,
            defaultGoalsState,
            removedDefaults.goals
          ),
          stravaEmbed:
            typeof parsed?.stravaEmbed === "string"
              ? parsed.stravaEmbed
              : defaultStravaEmbedUrl || "",
        };
      }

      const legacyWarmup = splitChecklistAgainstDefaults(parsed?.warmup || [], defaultWarmupTexts);
      const legacyCooldown = splitChecklistAgainstDefaults(
        parsed?.cooldown || [],
        defaultCooldownTexts
      );
      const legacyRules = splitStringsAgainstDefaults(parsed?.rules || [], defaultRulesTexts);
      const legacyGoals = splitStringsAgainstDefaults(parsed?.goals || [], defaultGoalsTexts);

      return {
        removedDefaults: {
          warmup: legacyWarmup.removedDefaults,
          cooldown: legacyCooldown.removedDefaults,
          rules: legacyRules.removedDefaults,
          goals: legacyGoals.removedDefaults,
        },
        warmup: buildChecklistState(
          legacyWarmup.customItems,
          defaultWarmupState,
          legacyWarmup.removedDefaults
        ),
        cooldown: buildChecklistState(
          legacyCooldown.customItems,
          defaultCooldownState,
          legacyCooldown.removedDefaults
        ),
        rules: buildStringState(
          legacyRules.customItems,
          defaultRulesState,
          legacyRules.removedDefaults
        ),
        goals: buildStringState(
          legacyGoals.customItems,
          defaultGoalsState,
          legacyGoals.removedDefaults
        ),
        stravaEmbed:
          typeof parsed?.stravaEmbed === "string"
            ? parsed.stravaEmbed
            : defaultStravaEmbedUrl || "",
      };
    }

    function syncStringSection(key) {
      const defaultsSet = key === "rules" ? defaultRulesTexts : defaultGoalsTexts;
      const normalized = normalizeStringItems(state[key]);

      const removedDefaults = Array.from(defaultsSet).filter(
        (item) => !normalized.includes(item)
      );

      const customItems = normalized.filter((item) => !defaultsSet.has(item));

      state[key] = buildStringState(
        customItems,
        key === "rules" ? defaultRulesState : defaultGoalsState,
        removedDefaults
      );

      state.removedDefaults[key] = removedDefaults;
    }

    function syncChecklistSection(key) {
      const defaultsSet = key === "warmup" ? defaultWarmupTexts : defaultCooldownTexts;
      const defaultState = key === "warmup" ? defaultWarmupState : defaultCooldownState;

      const normalized = normalizeChecklistItems(state[key]);

      const removedDefaults = Array.from(defaultsSet).filter(
        (item) => !normalized.some((entry) => entry.text === item)
      );

      const customItems = normalized.filter((item) => !defaultsSet.has(item.text));

      state[key] = buildChecklistState(customItems, defaultState, removedDefaults);
      state.removedDefaults[key] = removedDefaults;
    }

    function restoreStringDefaults(key) {
      const defaultsSet = key === "rules" ? defaultRulesTexts : defaultGoalsTexts;
      const defaultState = key === "rules" ? defaultRulesState : defaultGoalsState;
      const customItems = normalizeStringItems(state[key]).filter(
        (item) => !defaultsSet.has(item)
      );

      state.removedDefaults[key] = [];
      state[key] = buildStringState(customItems, defaultState, []);
    }

    function restoreChecklistDefaults(key) {
      const defaultsSet = key === "warmup" ? defaultWarmupTexts : defaultCooldownTexts;
      const defaultState = key === "warmup" ? defaultWarmupState : defaultCooldownState;
      const customItems = normalizeChecklistItems(state[key]).filter(
        (item) => !defaultsSet.has(item.text)
      );

      state.removedDefaults[key] = [];
      state[key] = buildChecklistState(customItems, defaultState, []);
    }

    async function loadState() {
      try {
        const res = await fetch(`/api/state?pageKey=${encodeURIComponent(pageKey)}`, {
          credentials: "include",
          cache: "no-store",
        });

        if (!res.ok) return null;

        const data = await res.json();
        return data?.state ?? null;
      } catch (error) {
        console.error("Failed to load state:", error);
        return null;
      }
    }

    async function saveState() {
      if (!hasLoadedInitialState) return;

      if (isSaving) {
        pendingSave = true;
        return;
      }

      isSaving = true;

      try {
        await fetch("/api/state", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ pageKey, state }),
        });
      } catch (error) {
        console.error("Failed to save state:", error);
      } finally {
        isSaving = false;

        if (pendingSave) {
          pendingSave = false;
          await saveState();
        }
      }
    }

    function createDeleteButton(onClick) {
      const button = document.createElement("button");
      button.type = "button";
      button.className = "routine-action-button";
      button.textContent = "Delete";
      button.addEventListener("click", onClick);
      return button;
    }

    function createAddButton(label, onClick) {
      const button = document.createElement("button");
      button.type = "button";
      button.className = "routine-action-button";
      button.textContent = label;
      button.addEventListener("click", onClick);
      return button;
    }

    function createRestoreButton(onClick) {
      const button = document.createElement("button");
      button.type = "button";
      button.className = "routine-action-button";
      button.textContent = "Restore Defaults";
      button.addEventListener("click", onClick);
      return button;
    }

    function renderSimpleEditableList(listEl, key) {
      if (!listEl) return;

      listEl.innerHTML = "";
      const isEditing = editMode[key];

      state[key].forEach((itemText, itemIndex) => {
        const li = document.createElement("li");
        li.className = "routine-item";

        const row = document.createElement("div");
        row.className = "routine-row";

        const left = document.createElement("div");
        left.className = "routine-left";

        if (isEditing) {
          const input = document.createElement("input");
          input.type = "text";
          input.className = "routine-inline-input";
          input.value = itemText;

          input.addEventListener("change", async () => {
            state[key][itemIndex] = input.value.trim();
            syncStringSection(key);
            renderSimpleEditableList(listEl, key);
            await saveState();
          });

          left.appendChild(input);
        } else {
          const text = document.createElement("span");
          text.textContent = itemText;
          left.appendChild(text);
        }

        row.appendChild(left);

        if (isEditing) {
          row.appendChild(
            createDeleteButton(async () => {
              state[key].splice(itemIndex, 1);
              syncStringSection(key);
              renderSimpleEditableList(listEl, key);
              await saveState();
            })
          );
        }

        li.appendChild(row);
        listEl.appendChild(li);
      });

      if (isEditing) {
        const actionsLi = document.createElement("li");
        actionsLi.className = "routine-item";

        const row = document.createElement("div");
        row.className = "routine-row routine-row-actions";

        const left = document.createElement("div");
        left.className = "routine-left";
        row.appendChild(left);

        const actions = document.createElement("div");
        actions.className = "routine-actions-group";

        actions.appendChild(
          createAddButton("Add", async () => {
            state[key].push("");
            renderSimpleEditableList(listEl, key);

            const inputs = listEl.querySelectorAll("input");
            const lastInput = inputs[inputs.length - 1];
            if (lastInput) lastInput.focus();

            await saveState();
          })
        );

        actions.appendChild(
          createRestoreButton(async () => {
            restoreStringDefaults(key);
            renderSimpleEditableList(listEl, key);
            await saveState();
          })
        );

        row.appendChild(actions);
        actionsLi.appendChild(row);
        listEl.appendChild(actionsLi);
      }
    }

    function renderChecklist(listEl, key) {
      if (!listEl) return;

      listEl.innerHTML = "";
      const isEditing = editMode[key];

      state[key].forEach((item, itemIndex) => {
        const li = document.createElement("li");
        li.className = "routine-item" + (!isEditing && item.done ? " is-done" : "");

        const row = document.createElement("div");
        row.className = "routine-row";

        if (isEditing) {
          const left = document.createElement("div");
          left.className = "routine-left";

          const input = document.createElement("input");
          input.type = "text";
          input.className = "routine-inline-input";
          input.value = item.text;

          input.addEventListener("change", async () => {
            state[key][itemIndex].text = input.value.trim();
            syncChecklistSection(key);
            renderChecklist(listEl, key);
            await saveState();
          });

          left.appendChild(input);
          row.appendChild(left);

          row.appendChild(
            createDeleteButton(async () => {
              state[key].splice(itemIndex, 1);
              syncChecklistSection(key);
              renderChecklist(listEl, key);
              await saveState();
            })
          );
        } else {
          const label = document.createElement("label");
          label.className = "routine-left";

          const checkbox = document.createElement("input");
          checkbox.type = "checkbox";
          checkbox.checked = !!item.done;

          checkbox.addEventListener("change", async () => {
            state[key][itemIndex].done = checkbox.checked;
            renderChecklist(listEl, key);
            await saveState();
          });

          const text = document.createElement("span");
          text.textContent = item.text;

          label.appendChild(checkbox);
          label.appendChild(text);
          row.appendChild(label);
        }

        li.appendChild(row);
        listEl.appendChild(li);
      });

      if (isEditing) {
        const actionsLi = document.createElement("li");
        actionsLi.className = "routine-item";

        const row = document.createElement("div");
        row.className = "routine-row routine-row-actions";

        const left = document.createElement("div");
        left.className = "routine-left";
        row.appendChild(left);

        const actions = document.createElement("div");
        actions.className = "routine-actions-group";

        actions.appendChild(
          createAddButton("Add", async () => {
            state[key].push({ text: "", done: false });
            renderChecklist(listEl, key);

            const inputs = listEl.querySelectorAll("input[type='text']");
            const lastInput = inputs[inputs.length - 1];
            if (lastInput) lastInput.focus();

            await saveState();
          })
        );

        actions.appendChild(
          createRestoreButton(async () => {
            restoreChecklistDefaults(key);
            renderChecklist(listEl, key);
            await saveState();
          })
        );

        row.appendChild(actions);
        actionsLi.appendChild(row);
        listEl.appendChild(actionsLi);
      }
    }

    function extractStravaSrc(value) {
      if (!value) return "";

      const trimmed = value.trim();

      if (trimmed.startsWith("<iframe")) {
        const srcMatch = trimmed.match(/src=['"]([^'"]+)['"]/i);
        return srcMatch?.[1] || "";
      }

      if (/^https?:\/\//i.test(trimmed)) {
        return trimmed;
      }

      return "";
    }

    function renderStrava() {
      if (!stravaContainerEl) return;

      stravaContainerEl.innerHTML = "";

      if (!state.stravaEmbed) {
        const wrapper = document.createElement("div");
        wrapper.className = "strava-empty-state";

        wrapper.innerHTML = `
          <div class="card">
            <p class="section-subtitle">No Strava embed added yet.</p>
            <div class="strava-guide">
              <p><strong>How to find your embed link:</strong></p>
              <ol>
                <li>Login to Strava</li>
                <li>Go to <strong>My Profile</strong></li>
                <li>Scroll to the bottom to <strong>Share Your Activities</strong></li>
                <li>Click <strong>"Share your activities"</strong></li>
                <li>Copy the embed code and paste it below</li>
              </ol>
              <p class="embed-example-label">Expected format:</p>
              <code class="embed-example">&lt;iframe height='454' width='300' frameborder='0' allowtransparency='true' scrolling='no' src='https://www.strava.com/athletes/115475457/latest-rides/6aa243149a11d283a34873ef8f65f506d1cba24e'&gt;&lt;/iframe&gt;</code>
            </div>
          </div>
        `;

        const form = document.createElement("div");
        form.className = "strava-form";

        const textarea = document.createElement("textarea");
        textarea.className = "routine-input";
        textarea.rows = 5;
        textarea.placeholder = "Paste Strava iframe embed code here";

        const saveButton = document.createElement("button");
        saveButton.type = "button";
        saveButton.className = "button-primary";
        saveButton.textContent = "Save Strava Embed";

        const feedback = document.createElement("p");
        feedback.className = "section-subtitle";

        saveButton.addEventListener("click", async () => {
          const src = extractStravaSrc(textarea.value);

          if (!src) {
            feedback.textContent = "Please paste a valid Strava iframe embed code or URL.";
            return;
          }

          state.stravaEmbed = src;
          renderStrava();
          await saveState();
        });

        form.appendChild(textarea);
        form.appendChild(saveButton);
        form.appendChild(feedback);
        wrapper.appendChild(form);

        stravaContainerEl.appendChild(wrapper);
        return;
      }

      const shell = document.createElement("div");
      shell.className = "running-embed-shell";

      const iframe = document.createElement("iframe");
      iframe.src = state.stravaEmbed;
      iframe.title = "Strava latest cardio activities";
      iframe.setAttribute("frameborder", "0");
      iframe.setAttribute("scrolling", "no");
      iframe.setAttribute("loading", "lazy");
      iframe.setAttribute("allowtransparency", "true");

      shell.appendChild(iframe);

      const actions = document.createElement("div");
      actions.className = "editor-toolbar";

      const clearButton = document.createElement("button");
      clearButton.type = "button";
      clearButton.className = "button-secondary";
      clearButton.textContent = "Remove Embed";

      clearButton.addEventListener("click", async () => {
        state.stravaEmbed = "";
        renderStrava();
        await saveState();
      });

      actions.appendChild(clearButton);

      stravaContainerEl.appendChild(shell);
      stravaContainerEl.appendChild(actions);
    }

    function renderAll() {
      renderChecklist(warmupListEl, "warmup");
      renderChecklist(cooldownListEl, "cooldown");
      renderSimpleEditableList(rulesListEl, "rules");
      renderSimpleEditableList(goalsListEl, "goals");
      renderStrava();

      if (rulesEditBtn) {
        rulesEditBtn.textContent = editMode.rules ? "Done" : "Edit";
      }

      if (goalsEditBtn) {
        goalsEditBtn.textContent = editMode.goals ? "Done" : "Edit";
      }

      if (warmupEditBtn) {
        warmupEditBtn.textContent = editMode.warmup ? "Done" : "Edit";
      }

      if (cooldownEditBtn) {
        cooldownEditBtn.textContent = editMode.cooldown ? "Done" : "Edit";
      }
    }

    function bindEditButtons() {
      if (rulesEditBtn) {
        rulesEditBtn.addEventListener("click", () => {
          editMode.rules = !editMode.rules;
          renderAll();
        });
      }

      if (goalsEditBtn) {
        goalsEditBtn.addEventListener("click", () => {
          editMode.goals = !editMode.goals;
          renderAll();
        });
      }

      if (warmupEditBtn) {
        warmupEditBtn.addEventListener("click", () => {
          editMode.warmup = !editMode.warmup;
          renderAll();
        });
      }

      if (cooldownEditBtn) {
        cooldownEditBtn.addEventListener("click", () => {
          editMode.cooldown = !editMode.cooldown;
          renderAll();
        });
      }
    }

    async function init() {
      renderAll();

      const saved = await loadState();
      state = normalizeCardioState(saved);

      hasLoadedInitialState = true;
      renderAll();
      bindEditButtons();
    }

    init();
  </script>

