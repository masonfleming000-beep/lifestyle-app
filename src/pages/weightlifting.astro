---
import BaseLayout from "../layouts/BaseLayout.astro";
import { liftingGroups } from "../data/weightlifting";

const defaultWeightliftingData = JSON.stringify({
  groups: liftingGroups,
  hiddenGroupIds: [],
  customGroups: [],
  groupDone: {},
  exerciseData: {},
  exerciseDone: {},
});
---

<BaseLayout title="Weight Training | Lifestyle App" description="Weight training dashboard">
  <section class="hero">
    <div class="hero-card">
      <p class="kicker">Weight Training</p>
      <h1>Train by muscle group.</h1>
      <p>
        Keep your defaults, add your own sections, add workouts to any section,
        and remove any section you do not want showing.
      </p>
    </div>
  </section>

  <section class="section">
    <article class="card">
      <div class="section-header">
        <div>
          <h2 class="section-title">Custom Sections</h2>
          <p class="section-subtitle">Create your own muscle groups or workout buckets.</p>
        </div>
      </div>

      <div class="custom-group-form">
        <input
          id="new-group-title"
          class="text-input"
          type="text"
          placeholder="New section name (ex. Triceps, Forearms, Full Body)"
        />
        <button type="button" class="secondary-btn" id="create-group-btn">
          Add section
        </button>
      </div>

      <div id="hidden-default-groups" class="hidden-default-groups"></div>
    </article>
  </section>

  <section class="section">
    <div class="grid one" id="weightlifting-groups">
      {liftingGroups.map((group) => (
        <details
          class="lift-group"
          data-group-id={group.id}
          data-group-title={group.title}
          data-is-custom="false"
        >
          <summary>
            <div class="lift-group-summary">
              <div>
                <p class="kicker">Muscle Group</p>
                <h2 class="section-title group-title">{group.title}</h2>
              </div>

              <div class="group-summary-actions" onclick="event.stopPropagation();">
                <button
                  type="button"
                  class="secondary-btn compact-btn"
                  data-toggle-section-editor={group.id}
                >
                  Edit section
                </button>

                <label class="group-hit-toggle">
                  <input
                    type="checkbox"
                    class="group-hit-checkbox"
                    data-group-hit={group.id}
                    aria-label={`Mark ${group.title} for today`}
                  />
                  <span>Today</span>
                </label>
              </div>
            </div>
          </summary>

          <div class="lift-group-body">
            <div class="section-editor" data-section-editor={group.id} hidden>
              <h3 class="card-title">Edit section</h3>

              <div class="mind-form-grid">
                <label>
                  <span>Section name</span>
                  <input
                    type="text"
                    class="text-input"
                    data-group-title-input={group.id}
                    value={group.title}
                    placeholder="Section name"
                  />
                </label>
              </div>

              <div class="mind-form-actions">
                <button
                  type="button"
                  class="secondary-btn"
                  data-save-group-title={group.id}
                >
                  Save name
                </button>

                <button
                  type="button"
                  class="secondary-btn"
                  data-restore-group-defaults={group.id}
                  data-is-custom="false"
                >
                  Restore default section
                </button>

                <button
                  type="button"
                  class="danger-btn"
                  data-delete-section={group.id}
                  data-is-custom="false"
                >
                  Delete section
                </button>
              </div>
            </div>

            <details class="add-exercise-panel">
              <summary class="secondary-btn add-exercise-toggle">Add exercise</summary>

              <form class="lift-exercise-form" data-exercise-form={group.id}>
                <h3 class="card-title">Add Exercise</h3>

                <div class="mind-form-grid">
                  <label>
                    <span>Name</span>
                    <input
                      type="text"
                      name="name"
                      placeholder="Ex: Incline Dumbbell Press"
                      required
                    />
                  </label>

                  <label>
                    <span>Video URL</span>
                    <input
                      type="text"
                      name="video"
                      placeholder="Paste YouTube link or embed code (optional)"
                    />
                  </label>

                  <label>
                    <span>Weight</span>
                    <input type="text" name="weight" placeholder="Ex: 50 lb" />
                  </label>

                  <label>
                    <span>Sets</span>
                    <input type="text" name="sets" placeholder="Ex: 3-4" required />
                  </label>

                  <label>
                    <span>Reps</span>
                    <input type="text" name="reps" placeholder="Ex: 8-12" required />
                  </label>

                  <label>
                    <span>Weeks since increase</span>
                    <input
                      type="text"
                      name="weeksSinceIncrease"
                      placeholder="Ex: 2"
                    />
                  </label>
                </div>

                <div class="mind-form-actions">
                  <button type="submit" class="secondary-btn">Add Exercise</button>

                  <button
                    type="button"
                    class="secondary-btn"
                    data-restore-exercises={group.id}
                    data-is-custom="false"
                  >
                    Restore default exercises
                  </button>
                </div>
              </form>
            </details>

            <div
              class="exercise-grid"
              id={`group-${group.id}`}
              data-group-id={group.id}
              data-default-exercises={JSON.stringify(group.exercises)}
            ></div>
          </div>
        </details>
      ))}
    </div>
  </section>

  <script define:vars={{ defaultWeightliftingData }}>
    const pageKey = "weightlifting";

    function cloneDefaults() {
      return JSON.parse(defaultWeightliftingData);
    }

    function slugify(value) {
      return value
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "");
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function parseYouTubeTimeToSeconds(value) {
      if (!value) return 0;

      if (/^\d+$/.test(value)) return Number(value);

      const match = value.match(/(?:(\d+)h)?(?:(\d+)m)?(?:(\d+)s)?/i);
      if (!match) return 0;

      const hours = Number(match[1] || 0);
      const minutes = Number(match[2] || 0);
      const seconds = Number(match[3] || 0);

      return hours * 3600 + minutes * 60 + seconds;
    }

    function normalizeYouTubeEmbed(input) {
      if (!input) return "";

      const raw = String(input).trim();
      let candidate = raw;

      if (raw.includes("<iframe")) {
        const srcMatch = raw.match(/src=["']([^"']+)["']/i);
        candidate = srcMatch?.[1]?.trim() || "";
      }

      if (!candidate) return "";

      let url;
      try {
        url = new URL(candidate);
      } catch {
        return "";
      }

      const host = url.hostname.replace(/^www\./, "");
      let videoId = "";
      let startSeconds = 0;

      if (host === "youtube.com" || host === "m.youtube.com") {
        if (url.pathname === "/watch") {
          videoId = url.searchParams.get("v") || "";
          startSeconds = parseYouTubeTimeToSeconds(url.searchParams.get("t") || "");
        } else if (url.pathname.startsWith("/embed/")) {
          videoId = url.pathname.split("/embed/")[1]?.split("/")[0] || "";
          startSeconds = parseYouTubeTimeToSeconds(url.searchParams.get("start") || "");
        } else if (url.pathname.startsWith("/shorts/")) {
          videoId = url.pathname.split("/shorts/")[1]?.split("/")[0] || "";
        } else if (url.pathname.startsWith("/live/")) {
          videoId = url.pathname.split("/live/")[1]?.split("/")[0] || "";
        }
      } else if (host === "youtu.be") {
        videoId = url.pathname.replace(/^\/+/, "").split("/")[0] || "";
        startSeconds = parseYouTubeTimeToSeconds(url.searchParams.get("t") || "");
      }

      if (!videoId) return "";

      const embedUrl = new URL(`https://www.youtube.com/embed/${videoId}`);
      if (startSeconds > 0) {
        embedUrl.searchParams.set("start", String(startSeconds));
      }

      return embedUrl.toString();
    }

    function normalizeExercise(exercise) {
      return {
        name: exercise?.name || "Untitled Exercise",
        weight: exercise?.weight || "",
        sets: exercise?.sets || "",
        reps: exercise?.reps || "",
        weeksSinceIncrease: exercise?.weeksSinceIncrease || "",
        video: normalizeYouTubeEmbed(exercise?.video || ""),
      };
    }

    function normalizeGroup(group) {
      return {
        id: group?.id || `group-${Date.now()}-${Math.random().toString(16).slice(2)}`,
        title: group?.title || "Untitled Group",
        exercises: Array.isArray(group?.exercises) ? group.exercises.map(normalizeExercise) : [],
      };
    }

    function normalizeData(raw) {
      const defaults = cloneDefaults();
      const parsed = raw && typeof raw === "object" ? raw : {};

      const defaultGroups = Array.isArray(defaults.groups) ? defaults.groups.map(normalizeGroup) : [];

      return {
        groups: Array.isArray(parsed.groups) ? parsed.groups.map(normalizeGroup) : defaultGroups,
        hiddenGroupIds: Array.isArray(parsed.hiddenGroupIds) ? parsed.hiddenGroupIds : [],
        customGroups: Array.isArray(parsed.customGroups) ? parsed.customGroups.map(normalizeGroup) : [],
        groupDone: parsed.groupDone && typeof parsed.groupDone === "object" ? parsed.groupDone : {},
        exerciseData: parsed.exerciseData && typeof parsed.exerciseData === "object" ? parsed.exerciseData : {},
        exerciseDone: parsed.exerciseDone && typeof parsed.exerciseDone === "object" ? parsed.exerciseDone : {},
      };
    }

    async function loadState() {
      try {
        const res = await fetch(`/api/state?pageKey=${encodeURIComponent(pageKey)}`, {
          credentials: "include",
          cache: "no-store",
        });

        if (!res.ok) return null;

        const data = await res.json();
        return data?.state ?? null;
      } catch (error) {
        console.error("Failed to load weightlifting state:", error);
        return null;
      }
    }

    let isSaving = false;
    let pendingSave = false;
    let hasLoadedInitialState = false;

    async function saveState() {
      if (!hasLoadedInitialState) return;

      if (isSaving) {
        pendingSave = true;
        return;
      }

      isSaving = true;

      try {
        await fetch("/api/state", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            pageKey,
            state: {
              groups: defaultGroups,
              hiddenGroupIds,
              customGroups,
              groupDone,
              exerciseData,
              exerciseDone,
            },
          }),
        });
      } catch (error) {
        console.error("Failed to save weightlifting state:", error);
      } finally {
        isSaving = false;

        if (pendingSave) {
          pendingSave = false;
          await saveState();
        }
      }
    }

    const sourceDefaultGroups = cloneDefaults().groups.map(normalizeGroup);

    let defaultGroups = sourceDefaultGroups.map(normalizeGroup);
    let hiddenGroupIds = [];
    let customGroups = [];
    let groupDone = {};
    let exerciseData = {};
    let exerciseDone = {};

    function getDefaultSourceGroup(groupId) {
      return sourceDefaultGroups.find((group) => group.id === groupId) || null;
    }

    function getMutableDefaultGroup(groupId) {
      return defaultGroups.find((group) => group.id === groupId) || null;
    }

    function getCustomGroup(groupId) {
      return customGroups.find((group) => group.id === groupId) || null;
    }

    function getExercises(groupId, defaults) {
      const saved = exerciseData[groupId];
      return Array.isArray(saved) ? saved.map(normalizeExercise) : defaults.map(normalizeExercise);
    }

    function saveExercises(groupId, exercises) {
      exerciseData[groupId] = exercises.map(normalizeExercise);
    }

    function clearSavedExercises(groupId) {
      delete exerciseData[groupId];
      delete exerciseDone[groupId];
    }

    function getExerciseDone(groupId) {
      const saved = exerciseDone[groupId];
      return saved && typeof saved === "object" ? saved : {};
    }

    function saveExerciseDone(groupId, value) {
      exerciseDone[groupId] = value;
    }

    function getCustomGroups() {
      return customGroups;
    }

    function saveCustomGroups(groups) {
      customGroups = groups.map(normalizeGroup);
    }

    function getHiddenGroups() {
      return hiddenGroupIds;
    }

    function saveHiddenGroups(groupIds) {
      hiddenGroupIds = [...groupIds];
    }

    function loadGroupDone() {
      return groupDone;
    }

    function saveGroupDone(value) {
      groupDone = { ...value };
    }

    function hideGroup(groupId) {
      const hidden = getHiddenGroups();
      if (!hidden.includes(groupId)) {
        saveHiddenGroups([...hidden, groupId]);
      }
    }

    function unhideGroup(groupId) {
      saveHiddenGroups(getHiddenGroups().filter((id) => id !== groupId));
    }

    function removeStorageForGroup(groupId) {
      delete exerciseData[groupId];
      delete exerciseDone[groupId];

      const nextGroupDone = { ...loadGroupDone() };
      delete nextGroupDone[groupId];
      saveGroupDone(nextGroupDone);
    }

    function updateGroupTitleState(groupId, title, isCustom) {
      if (isCustom) {
        saveCustomGroups(
          getCustomGroups().map((group) =>
            group.id === groupId ? { ...group, title } : group
          )
        );
      } else {
        defaultGroups = defaultGroups.map((group) =>
          group.id === groupId ? { ...group, title } : group
        );
      }
    }

    function makeMetric(label, value) {
      return `
        <div class="exercise-metric">
          <span class="exercise-metric-label">${label}</span>
          <span class="exercise-metric-value">${value || "-"}</span>
        </div>
      `;
    }

    function makeGroupMarkup(group, isCustom = false) {
      const details = document.createElement("details");
      details.className = "lift-group";
      details.dataset.groupId = group.id;
      details.dataset.groupTitle = group.title;
      details.dataset.isCustom = String(isCustom);

      details.innerHTML = `
        <summary>
          <div class="lift-group-summary">
            <div>
              <p class="kicker">Muscle Group</p>
              <h2 class="section-title group-title">${escapeHtml(group.title)}</h2>
            </div>

            <div class="group-summary-actions" onclick="event.stopPropagation();">
              <button
                type="button"
                class="secondary-btn compact-btn"
                data-toggle-section-editor="${group.id}"
              >
                Edit section
              </button>

              <label class="group-hit-toggle">
                <input
                  type="checkbox"
                  class="group-hit-checkbox"
                  data-group-hit="${group.id}"
                  aria-label="Mark ${escapeHtml(group.title)} for today"
                />
                <span>Today</span>
              </label>
            </div>
          </div>
        </summary>

        <div class="lift-group-body">
          <div class="section-editor" data-section-editor="${group.id}" hidden>
            <h3 class="card-title">Edit section</h3>

            <div class="mind-form-grid">
              <label>
                <span>Section name</span>
                <input
                  type="text"
                  class="text-input"
                  data-group-title-input="${group.id}"
                  value="${escapeHtml(group.title)}"
                  placeholder="Section name"
                />
              </label>
            </div>

            <div class="mind-form-actions">
              <button
                type="button"
                class="secondary-btn"
                data-save-group-title="${group.id}"
              >
                Save name
              </button>

              <button
                type="button"
                class="secondary-btn"
                data-restore-group-defaults="${group.id}"
                data-is-custom="${String(isCustom)}"
              >
                ${isCustom ? "Clear custom section" : "Restore default section"}
              </button>

              <button
                type="button"
                class="danger-btn"
                data-delete-section="${group.id}"
                data-is-custom="${String(isCustom)}"
              >
                Delete section
              </button>
            </div>
          </div>

          <details class="add-exercise-panel">
            <summary class="secondary-btn add-exercise-toggle">Add exercise</summary>

            <form class="lift-exercise-form" data-exercise-form="${group.id}">
              <h3 class="card-title">Add Exercise</h3>

              <div class="mind-form-grid">
                <label>
                  <span>Name</span>
                  <input
                    type="text"
                    name="name"
                    placeholder="Ex: Incline Dumbbell Press"
                    required
                  />
                </label>

                <label>
                  <span>Video URL</span>
                  <input
                    type="text"
                    name="video"
                    placeholder="Paste YouTube link or embed code (optional)"
                  />
                </label>

                <label>
                  <span>Weight</span>
                  <input type="text" name="weight" placeholder="Ex: 50 lb" />
                </label>

                <label>
                  <span>Sets</span>
                  <input type="text" name="sets" placeholder="Ex: 3-4" required />
                </label>

                <label>
                  <span>Reps</span>
                  <input type="text" name="reps" placeholder="Ex: 8-12" required />
                </label>

                <label>
                  <span>Weeks since increase</span>
                  <input
                    type="text"
                    name="weeksSinceIncrease"
                    placeholder="Ex: 2"
                  />
                </label>
              </div>

              <div class="mind-form-actions">
                <button type="submit" class="secondary-btn">Add Exercise</button>

                <button
                  type="button"
                  class="secondary-btn"
                  data-restore-exercises="${group.id}"
                  data-is-custom="${String(isCustom)}"
                >
                  ${isCustom ? "Clear all exercises" : "Restore default exercises"}
                </button>
              </div>
            </form>
          </details>

          <div
            class="exercise-grid"
            id="group-${group.id}"
            data-group-id="${group.id}"
            data-default-exercises='${JSON.stringify(group.exercises || [])}'
          ></div>
        </div>
      `;

      return details;
    }

    function updateGroupDom(groupEl, group) {
      groupEl.dataset.groupTitle = group.title;

      const titleEl = groupEl.querySelector(".group-title");
      if (titleEl) titleEl.textContent = group.title;

      const titleInput = groupEl.querySelector(`[data-group-title-input="${group.id}"]`);
      if (titleInput instanceof HTMLInputElement) {
        titleInput.value = group.title;
      }

      const checkbox = groupEl.querySelector("[data-group-hit]");
      if (checkbox instanceof HTMLInputElement) {
        checkbox.setAttribute("aria-label", `Mark ${group.title} for today`);
      }

      const grid = groupEl.querySelector(".exercise-grid");
      if (grid instanceof HTMLElement) {
        grid.dataset.defaultExercises = JSON.stringify(group.exercises || []);
      }
    }

    function renderGroup(groupEl) {
      const groupId = groupEl.dataset.groupId;
      const grid = document.getElementById(`group-${groupId}`);
      if (!grid) return;

      const defaults = JSON.parse(grid.dataset.defaultExercises || "[]").map(normalizeExercise);
      const exercises = getExercises(groupId, defaults);
      const doneMap = getExerciseDone(groupId);

      grid.innerHTML = "";

      exercises.forEach((exercise, index) => {
        const safeVideo = normalizeYouTubeEmbed(exercise.video || "");
        const article = document.createElement("article");
        article.className = "exercise-card" + (doneMap[index] ? " is-done" : "");

        article.innerHTML = `
          <div class="exercise-header">
            <div>
              <h3 class="card-title">${escapeHtml(exercise.name)}</h3>
            </div>
            <label class="exercise-check">
              <input type="checkbox" ${doneMap[index] ? "checked" : ""} data-exercise-check="${groupId}" data-index="${index}" />
              <span>Done</span>
            </label>
          </div>

          <div class="exercise-metrics">
            ${makeMetric("Weight", escapeHtml(exercise.weight))}
            ${makeMetric("Sets", escapeHtml(exercise.sets))}
            ${makeMetric("Reps", escapeHtml(exercise.reps))}
            ${makeMetric("Weeks since increase", escapeHtml(exercise.weeksSinceIncrease))}
          </div>

          ${
            safeVideo
              ? `
            <div class="exercise-video-shell">
              <iframe
                src="${safeVideo}"
                title="${escapeHtml(exercise.name)}"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
          `
              : ""
          }

          <div class="exercise-actions">
            <button
              type="button"
              class="secondary-btn compact-btn edit-exercise-btn"
              data-edit-exercise="${groupId}"
              data-index="${index}"
            >
              Edit
            </button>

            <button
              type="button"
              class="danger-btn compact-btn delete-exercise-btn"
              data-delete-group="${groupId}"
              data-index="${index}"
            >
              Delete
            </button>
          </div>

          <form class="exercise-edit-form" data-exercise-edit-form="${groupId}" data-index="${index}" hidden>
            <h4 class="card-title">Edit exercise</h4>

            <div class="mind-form-grid">
              <label>
                <span>Name</span>
                <input type="text" name="name" value="${escapeHtml(exercise.name)}" required />
              </label>

              <label>
                <span>Video URL</span>
                <input type="text" name="video" value="${escapeHtml(exercise.video)}" />
              </label>

              <label>
                <span>Weight</span>
                <input type="text" name="weight" value="${escapeHtml(exercise.weight)}" />
              </label>

              <label>
                <span>Sets</span>
                <input type="text" name="sets" value="${escapeHtml(exercise.sets)}" required />
              </label>

              <label>
                <span>Reps</span>
                <input type="text" name="reps" value="${escapeHtml(exercise.reps)}" required />
              </label>

              <label>
                <span>Weeks since increase</span>
                <input
                  type="text"
                  name="weeksSinceIncrease"
                  value="${escapeHtml(exercise.weeksSinceIncrease)}"
                />
              </label>
            </div>

            <div class="mind-form-actions">
              <button type="submit" class="secondary-btn compact-btn">Save</button>
              <button
                type="button"
                class="secondary-btn compact-btn"
                data-cancel-exercise-edit="${groupId}"
                data-index="${index}"
              >
                Cancel
              </button>
            </div>
          </form>
        `;

        grid.appendChild(article);
      });

      grid.querySelectorAll("[data-exercise-check]").forEach((checkbox) => {
        checkbox.addEventListener("change", async (e) => {
          const target = e.currentTarget;
          const idx = Number(target.dataset.index);
          const next = { ...getExerciseDone(groupId) };
          next[idx] = target.checked;
          saveExerciseDone(groupId, next);
          renderGroup(groupEl);
          await saveState();
        });
      });

      grid.querySelectorAll("[data-delete-group]").forEach((btn) => {
        btn.addEventListener("click", async (e) => {
          const idx = Number(e.currentTarget.dataset.index);
          const nextExercises = getExercises(groupId, defaults).filter((_, i) => i !== idx);
          saveExercises(groupId, nextExercises);

          const oldDone = getExerciseDone(groupId);
          const nextDone = {};
          nextExercises.forEach((_, newIndex) => {
            const oldIndex = newIndex >= idx ? newIndex + 1 : newIndex;
            nextDone[newIndex] = !!oldDone[oldIndex];
          });
          saveExerciseDone(groupId, nextDone);

          renderGroup(groupEl);
          await saveState();
        });
      });

      grid.querySelectorAll("[data-edit-exercise]").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const idx = Number(e.currentTarget.dataset.index);
          const form = grid.querySelector(
            `[data-exercise-edit-form="${groupId}"][data-index="${idx}"]`
          );
          if (form instanceof HTMLElement) {
            form.hidden = false;
          }
        });
      });

      grid.querySelectorAll("[data-cancel-exercise-edit]").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const idx = Number(e.currentTarget.dataset.index);
          const form = grid.querySelector(
            `[data-exercise-edit-form="${groupId}"][data-index="${idx}"]`
          );
          if (form instanceof HTMLElement) {
            form.hidden = true;
          }
        });
      });

      grid.querySelectorAll(`[data-exercise-edit-form="${groupId}"]`).forEach((form) => {
        form.addEventListener("submit", async (event) => {
          event.preventDefault();

          const idx = Number(form.dataset.index);
          const currentExercises = getExercises(groupId, defaults);
          const formData = new FormData(form);

          const name = String(formData.get("name") || "").trim();
          const weight = String(formData.get("weight") || "").trim();
          const sets = String(formData.get("sets") || "").trim();
          const reps = String(formData.get("reps") || "").trim();
          const weeksSinceIncrease = String(formData.get("weeksSinceIncrease") || "").trim();
          const video = String(formData.get("video") || "").trim();

          if (!name || !sets || !reps) {
            window.alert("Please fill out name, sets, and reps.");
            return;
          }

          currentExercises[idx] = normalizeExercise({
            name,
            weight,
            sets,
            reps,
            weeksSinceIncrease,
            video,
          });

          saveExercises(groupId, currentExercises);
          renderGroup(groupEl);
          await saveState();
        });
      });
    }

    function wireGroupDoneCheckbox(groupEl) {
      const groupDoneMap = loadGroupDone();
      const checkbox = groupEl.querySelector("[data-group-hit]");
      if (!(checkbox instanceof HTMLInputElement)) return;

      const groupId = checkbox.dataset.groupHit;
      checkbox.checked = !!groupDoneMap[groupId];

      checkbox.addEventListener("change", async () => {
        const next = { ...loadGroupDone() };
        next[groupId] = checkbox.checked;
        saveGroupDone(next);
        await saveState();
      });
    }

    function setupExerciseForm(groupEl) {
      const form = groupEl.querySelector("[data-exercise-form]");
      if (!(form instanceof HTMLFormElement)) return;

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        try {
          const groupId = form.getAttribute("data-exercise-form");
          if (!groupId) return;

          const grid = document.getElementById(`group-${groupId}`);
          if (!grid) return;

          const defaults = JSON.parse(grid.dataset.defaultExercises || "[]").map(normalizeExercise);
          const exercises = getExercises(groupId, defaults);

          const formData = new FormData(form);

          const name = String(formData.get("name") || "").trim();
          const weight = String(formData.get("weight") || "").trim();
          const sets = String(formData.get("sets") || "").trim();
          const reps = String(formData.get("reps") || "").trim();
          const weeksSinceIncrease = String(formData.get("weeksSinceIncrease") || "").trim();
          const video = String(formData.get("video") || "").trim();

          if (!name) {
            window.alert("Please enter an exercise name.");
            return;
          }

          if (!sets || !reps) {
            window.alert("Please fill out sets and reps.");
            return;
          }

          const newExercise = normalizeExercise({
            name,
            weight,
            sets,
            reps,
            weeksSinceIncrease,
            video,
          });

          saveExercises(groupId, [...exercises, newExercise]);
          form.reset();

          const panel = form.closest(".add-exercise-panel");
          if (panel instanceof HTMLDetailsElement) {
            panel.open = false;
          }

          renderGroup(groupEl);
          await saveState();
        } catch (error) {
          console.error("Failed to add exercise:", error);
          window.alert("Could not add exercise. Check console for the exact error.");
        }
      });
    }

    function wireDeleteGroupButton(groupEl) {
      const btn = groupEl.querySelector("[data-delete-section]");
      if (!(btn instanceof HTMLElement)) return;

      btn.addEventListener("click", async () => {
        const groupId = btn.dataset.deleteSection;
        const isCustom = btn.dataset.isCustom === "true";
        const confirmed = window.confirm("Delete this entire section?");
        if (!confirmed) return;

        if (isCustom) {
          const nextGroups = getCustomGroups().filter((group) => group.id !== groupId);
          saveCustomGroups(nextGroups);
          removeStorageForGroup(groupId);
        } else {
          hideGroup(groupId);
        }

        groupEl.remove();
        renderHiddenDefaultGroups();
        await saveState();
      });
    }

    function wireSectionEditor(groupEl) {
      const groupId = groupEl.dataset.groupId;
      const isCustom = groupEl.dataset.isCustom === "true";

      const toggleBtn = groupEl.querySelector(`[data-toggle-section-editor="${groupId}"]`);
      const editor = groupEl.querySelector(`[data-section-editor="${groupId}"]`);
      const titleInput = groupEl.querySelector(`[data-group-title-input="${groupId}"]`);
      const saveBtn = groupEl.querySelector(`[data-save-group-title="${groupId}"]`);
      const restoreGroupBtn = groupEl.querySelector(`[data-restore-group-defaults="${groupId}"]`);
      const restoreExercisesBtn = groupEl.querySelector(`[data-restore-exercises="${groupId}"]`);

      if (toggleBtn instanceof HTMLElement && editor instanceof HTMLElement) {
        toggleBtn.addEventListener("click", () => {
          editor.hidden = !editor.hidden;
        });
      }

      if (saveBtn instanceof HTMLElement && titleInput instanceof HTMLInputElement) {
        saveBtn.addEventListener("click", async () => {
          const nextTitle = titleInput.value.trim();
          if (!nextTitle) {
            window.alert("Please enter a section name.");
            return;
          }

          updateGroupTitleState(groupId, nextTitle, isCustom);

          const nextGroup = isCustom ? getCustomGroup(groupId) : getMutableDefaultGroup(groupId);
          if (nextGroup) {
            updateGroupDom(groupEl, nextGroup);
          }

          await saveState();
        });
      }

      if (restoreGroupBtn instanceof HTMLElement) {
        restoreGroupBtn.addEventListener("click", async () => {
          if (isCustom) {
            const confirmed = window.confirm("Clear this custom section back to empty?");
            if (!confirmed) return;

            saveExercises(groupId, []);
            saveExerciseDone(groupId, {});
            renderGroup(groupEl);
            await saveState();
            return;
          }

          const source = getDefaultSourceGroup(groupId);
          if (!source) return;

          defaultGroups = defaultGroups.map((group) =>
            group.id === groupId ? normalizeGroup(source) : group
          );

          clearSavedExercises(groupId);

          const nextDone = { ...loadGroupDone() };
          delete nextDone[groupId];
          saveGroupDone(nextDone);

          updateGroupDom(groupEl, normalizeGroup(source));
          renderGroup(groupEl);
          await saveState();
        });
      }

      if (restoreExercisesBtn instanceof HTMLElement) {
        restoreExercisesBtn.addEventListener("click", async () => {
          if (isCustom) {
            const confirmed = window.confirm("Remove all exercises from this custom section?");
            if (!confirmed) return;

            saveExercises(groupId, []);
            saveExerciseDone(groupId, {});
            renderGroup(groupEl);
            await saveState();
            return;
          }

          const source = getDefaultSourceGroup(groupId);
          if (!source) return;

          saveExercises(groupId, source.exercises.map(normalizeExercise));
          saveExerciseDone(groupId, {});
          renderGroup(groupEl);
          await saveState();
        });
      }
    }

    function setupGroup(groupEl) {
      renderGroup(groupEl);
      wireGroupDoneCheckbox(groupEl);
      setupExerciseForm(groupEl);
      wireDeleteGroupButton(groupEl);
      wireSectionEditor(groupEl);
    }

    function syncExistingDefaultGroupMarkup() {
      document.querySelectorAll('.lift-group[data-is-custom="false"]').forEach((groupEl) => {
        const groupId = groupEl.dataset.groupId;
        const group = getMutableDefaultGroup(groupId);
        if (!group) return;
        updateGroupDom(groupEl, group);
      });
    }

    function hideDefaultGroupsMarkedHidden() {
      const hidden = getHiddenGroups();
      hidden.forEach((groupId) => {
        const existing = document.querySelector(`.lift-group[data-group-id="${groupId}"]`);
        if (existing) existing.remove();
      });
    }

    function renderCustomGroups() {
      const container = document.getElementById("weightlifting-groups");
      if (!container) return;

      const custom = getCustomGroups();
      const hidden = getHiddenGroups();

      custom.forEach((group) => {
        if (hidden.includes(group.id)) return;
        if (container.querySelector(`[data-group-id="${group.id}"]`)) return;

        const groupEl = makeGroupMarkup(group, true);
        container.appendChild(groupEl);
        setupGroup(groupEl);
      });
    }

    function renderHiddenDefaultGroups() {
      const container = document.getElementById("hidden-default-groups");
      if (!container) return;

      const hiddenDefaults = getHiddenGroups()
        .map((id) => getDefaultSourceGroup(id))
        .filter(Boolean);

      if (!hiddenDefaults.length) {
        container.innerHTML = "";
        return;
      }

      container.innerHTML = `
        <div class="hidden-default-groups-card">
          <h3 class="card-title">Hidden default sections</h3>
          <p class="section-subtitle">Restore any built-in section you deleted.</p>

          <div class="hidden-default-groups-list">
            ${hiddenDefaults
              .map(
                (group) => `
                  <div class="hidden-default-group-row">
                    <span>${escapeHtml(group.title)}</span>
                    <button
                      type="button"
                      class="secondary-btn compact-btn"
                      data-restore-hidden-group="${group.id}"
                    >
                      Restore
                    </button>
                  </div>
                `
              )
              .join("")}
          </div>
        </div>
      `;

      container.querySelectorAll("[data-restore-hidden-group]").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const groupId = btn.dataset.restoreHiddenGroup;
          const source = getDefaultSourceGroup(groupId);
          if (!source) return;

          defaultGroups = defaultGroups.map((group) =>
            group.id === groupId ? normalizeGroup(source) : group
          );

          clearSavedExercises(groupId);
          unhideGroup(groupId);

          const weightliftingGroups = document.getElementById("weightlifting-groups");
          if (!weightliftingGroups) return;

          const existing = weightliftingGroups.querySelector(`[data-group-id="${groupId}"]`);
          if (!existing) {
            const groupEl = makeGroupMarkup(source, false);
            weightliftingGroups.appendChild(groupEl);
            setupGroup(groupEl);
          }

          renderHiddenDefaultGroups();
          await saveState();
        });
      });
    }

    function setupCreateGroup() {
      const btn = document.getElementById("create-group-btn");
      const input = document.getElementById("new-group-title");

      if (!(btn instanceof HTMLElement) || !(input instanceof HTMLInputElement)) return;

      btn.addEventListener("click", async () => {
        const rawTitle = input.value.trim();
        if (!rawTitle) return;

        const baseId = slugify(rawTitle);
        const allExistingIds = [
          ...defaultGroups.map((group) => group.id),
          ...getCustomGroups().map((group) => group.id),
        ];

        let nextId = baseId || `group-${Date.now()}`;
        let counter = 2;

        while (allExistingIds.includes(nextId)) {
          nextId = `${baseId}-${counter}`;
          counter += 1;
        }

        const newGroup = normalizeGroup({
          id: nextId,
          title: rawTitle,
          exercises: [],
        });

        saveCustomGroups([...getCustomGroups(), newGroup]);
        unhideGroup(nextId);

        const container = document.getElementById("weightlifting-groups");
        if (!container) return;

        const groupEl = makeGroupMarkup(newGroup, true);
        container.appendChild(groupEl);
        setupGroup(groupEl);
        groupEl.open = true;

        input.value = "";
        await saveState();
      });
    }

    function setupWeightTraining() {
      syncExistingDefaultGroupMarkup();
      hideDefaultGroupsMarkedHidden();

      document.querySelectorAll(".lift-group").forEach((groupEl) => {
        setupGroup(groupEl);
      });

      renderCustomGroups();
      renderHiddenDefaultGroups();
      setupCreateGroup();
    }

    async function init() {
      const saved = normalizeData(await loadState());

      defaultGroups =
        Array.isArray(saved.groups) && saved.groups.length
          ? saved.groups.map(normalizeGroup)
          : sourceDefaultGroups.map(normalizeGroup);

      hiddenGroupIds = Array.isArray(saved.hiddenGroupIds) ? saved.hiddenGroupIds : [];
      customGroups = Array.isArray(saved.customGroups) ? saved.customGroups.map(normalizeGroup) : [];
      groupDone = saved.groupDone && typeof saved.groupDone === "object" ? saved.groupDone : {};
      exerciseData = saved.exerciseData && typeof saved.exerciseData === "object" ? saved.exerciseData : {};
      exerciseDone = saved.exerciseDone && typeof saved.exerciseDone === "object" ? saved.exerciseDone : {};

      hasLoadedInitialState = true;
      setupWeightTraining();
    }

    init();
  </script>
</BaseLayout>