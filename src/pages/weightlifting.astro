---
import BaseLayout from "../layouts/BaseLayout.astro";
import { liftingGroups } from "../data/weightlifting";

const defaultWeightliftingData = JSON.stringify({
  groups: liftingGroups,
  hiddenGroupIds: [],
  customGroups: [],
  groupDone: {},
  exerciseData: {},
  exerciseDone: {},
});
---

<BaseLayout title="Weight Training | Lifestyle App" description="Weight training dashboard">
  <section class="hero">
    <div class="hero-card">
      <p class="kicker">Weight Training</p>
      <h1>Train by muscle group.</h1>
      <p>
        Keep your defaults, add your own sections, add workouts to any section,
        and remove any section you do not want showing.
      </p>
    </div>
  </section>

  <section class="section">
    <article class="card soft">
      <div class="section-header">
        <div>
          <h2 class="section-title">Custom Sections</h2>
          <p class="section-subtitle">Create your own muscle groups or workout buckets.</p>
        </div>
      </div>

      <div class="custom-group-form">
        <input
          id="new-group-title"
          class="text-input"
          type="text"
          placeholder="New section name (ex. Triceps, Forearms, Full Body)"
        />
        <button type="button" class="secondary-btn" id="create-group-btn">
          Add section
        </button>
      </div>
    </article>
  </section>

  <section class="section">
    <div class="grid one" id="weightlifting-groups">
      {liftingGroups.map((group) => (
        <details
          class="lift-group"
          data-group-id={group.id}
          data-group-title={group.title}
          data-is-custom="false"
        >
          <summary>
            <div class="lift-group-summary">
              <div>
                <p class="kicker">Muscle Group</p>
                <h2 class="section-title">{group.title}</h2>
              </div>
              <label class="group-hit-toggle" onclick="event.stopPropagation();">
                <input
                  type="checkbox"
                  class="group-hit-checkbox"
                  data-group-hit={group.id}
                  aria-label={`Mark ${group.title} for today`}
                />
                <span>Today</span>
              </label>
            </div>
          </summary>

          <div class="lift-group-body">
            <div class="lift-group-tools">
              <button
                type="button"
                class="secondary-btn add-exercise-btn"
                data-add-group={group.id}
              >
                Add exercise
              </button>
            </div>

            <div
              class="exercise-grid"
              id={`group-${group.id}`}
              data-group-id={group.id}
              data-default-exercises={JSON.stringify(group.exercises)}
            ></div>

            <div class="group-bottom-actions">
              <button
                type="button"
                class="danger-btn delete-group-btn"
                data-delete-section={group.id}
                data-is-custom="false"
              >
                Delete section
              </button>
            </div>
          </div>
        </details>
      ))}
    </div>
  </section>

  <script define:vars={{ defaultWeightliftingData }}>
    const pageKey = "weightlifting";

    function cloneDefaults() {
      return JSON.parse(defaultWeightliftingData);
    }

    function slugify(value) {
      return value
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "");
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function parseYouTubeTimeToSeconds(value) {
      if (!value) return 0;

      if (/^\d+$/.test(value)) return Number(value);

      const match = value.match(/(?:(\d+)h)?(?:(\d+)m)?(?:(\d+)s)?/i);
      if (!match) return 0;

      const hours = Number(match[1] || 0);
      const minutes = Number(match[2] || 0);
      const seconds = Number(match[3] || 0);

      return hours * 3600 + minutes * 60 + seconds;
    }

    function normalizeYouTubeEmbed(input) {
      if (!input) return "";

      const raw = String(input).trim();
      let candidate = raw;

      if (raw.includes("<iframe")) {
        const srcMatch = raw.match(/src=["']([^"']+)["']/i);
        candidate = srcMatch?.[1]?.trim() || "";
      }

      if (!candidate) return "";

      let url;
      try {
        url = new URL(candidate);
      } catch {
        return "";
      }

      const host = url.hostname.replace(/^www\./, "");
      let videoId = "";
      let startSeconds = 0;

      if (host === "youtube.com" || host === "m.youtube.com") {
        if (url.pathname === "/watch") {
          videoId = url.searchParams.get("v") || "";
          startSeconds = parseYouTubeTimeToSeconds(url.searchParams.get("t") || "");
        } else if (url.pathname.startsWith("/embed/")) {
          videoId = url.pathname.split("/embed/")[1]?.split("/")[0] || "";
          startSeconds = parseYouTubeTimeToSeconds(url.searchParams.get("start") || "");
        } else if (url.pathname.startsWith("/shorts/")) {
          videoId = url.pathname.split("/shorts/")[1]?.split("/")[0] || "";
        } else if (url.pathname.startsWith("/live/")) {
          videoId = url.pathname.split("/live/")[1]?.split("/")[0] || "";
        }
      } else if (host === "youtu.be") {
        videoId = url.pathname.replace(/^\/+/, "").split("/")[0] || "";
        startSeconds = parseYouTubeTimeToSeconds(url.searchParams.get("t") || "");
      }

      if (!videoId) return "";

      const embedUrl = new URL(`https://www.youtube.com/embed/${videoId}`);
      if (startSeconds > 0) {
        embedUrl.searchParams.set("start", String(startSeconds));
      }

      return embedUrl.toString();
    }

    function normalizeExercise(exercise) {
      return {
        name: exercise?.name || "Untitled Exercise",
        weight: exercise?.weight || "",
        sets: exercise?.sets || "",
        reps: exercise?.reps || "",
        weeksSinceIncrease: exercise?.weeksSinceIncrease || "",
        video: normalizeYouTubeEmbed(exercise?.video || ""),
      };
    }

    function normalizeGroup(group) {
      return {
        id: group?.id || `group-${Date.now()}-${Math.random().toString(16).slice(2)}`,
        title: group?.title || "Untitled Group",
        exercises: Array.isArray(group?.exercises) ? group.exercises.map(normalizeExercise) : [],
      };
    }

    function normalizeData(raw) {
      const defaults = cloneDefaults();
      const parsed = raw && typeof raw === "object" ? raw : {};

      const defaultGroups = Array.isArray(defaults.groups) ? defaults.groups.map(normalizeGroup) : [];

      return {
        groups: Array.isArray(parsed.groups) ? parsed.groups.map(normalizeGroup) : defaultGroups,
        hiddenGroupIds: Array.isArray(parsed.hiddenGroupIds) ? parsed.hiddenGroupIds : [],
        customGroups: Array.isArray(parsed.customGroups) ? parsed.customGroups.map(normalizeGroup) : [],
        groupDone: parsed.groupDone && typeof parsed.groupDone === "object" ? parsed.groupDone : {},
        exerciseData: parsed.exerciseData && typeof parsed.exerciseData === "object" ? parsed.exerciseData : {},
        exerciseDone: parsed.exerciseDone && typeof parsed.exerciseDone === "object" ? parsed.exerciseDone : {},
      };
    }

    async function loadState() {
      try {
        const res = await fetch(`/api/state?pageKey=${encodeURIComponent(pageKey)}`, {
          credentials: "include",
          cache: "no-store",
        });

        if (!res.ok) return null;

        const data = await res.json();
        return data?.state ?? null;
      } catch (error) {
        console.error("Failed to load weightlifting state:", error);
        return null;
      }
    }

    let isSaving = false;
    let pendingSave = false;
    let hasLoadedInitialState = false;

    async function saveState() {
      if (!hasLoadedInitialState) return;

      if (isSaving) {
        pendingSave = true;
        return;
      }

      isSaving = true;

      try {
        await fetch("/api/state", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            pageKey,
            state: {
              groups: defaultGroups,
              hiddenGroupIds,
              customGroups,
              groupDone,
              exerciseData,
              exerciseDone,
            },
          }),
        });
      } catch (error) {
        console.error("Failed to save weightlifting state:", error);
      } finally {
        isSaving = false;

        if (pendingSave) {
          pendingSave = false;
          await saveState();
        }
      }
    }

    let defaultGroups = cloneDefaults().groups.map(normalizeGroup);
    let hiddenGroupIds = [];
    let customGroups = [];
    let groupDone = {};
    let exerciseData = {};
    let exerciseDone = {};

    function getExercises(groupId, defaults) {
      const saved = exerciseData[groupId];
      return Array.isArray(saved) ? saved.map(normalizeExercise) : defaults.map(normalizeExercise);
    }

    function saveExercises(groupId, exercises) {
      exerciseData[groupId] = exercises.map(normalizeExercise);
    }

    function getExerciseDone(groupId) {
      const saved = exerciseDone[groupId];
      return saved && typeof saved === "object" ? saved : {};
    }

    function saveExerciseDone(groupId, value) {
      exerciseDone[groupId] = value;
    }

    function getCustomGroups() {
      return customGroups;
    }

    function saveCustomGroups(groups) {
      customGroups = groups.map(normalizeGroup);
    }

    function getHiddenGroups() {
      return hiddenGroupIds;
    }

    function saveHiddenGroups(groupIds) {
      hiddenGroupIds = [...groupIds];
    }

    function loadGroupDone() {
      return groupDone;
    }

    function saveGroupDone(value) {
      groupDone = { ...value };
    }

    function hideGroup(groupId) {
      const hidden = getHiddenGroups();
      if (!hidden.includes(groupId)) {
        saveHiddenGroups([...hidden, groupId]);
      }
    }

    function unhideGroup(groupId) {
      saveHiddenGroups(getHiddenGroups().filter((id) => id !== groupId));
    }

    function removeStorageForGroup(groupId) {
      delete exerciseData[groupId];
      delete exerciseDone[groupId];

      const nextGroupDone = { ...loadGroupDone() };
      delete nextGroupDone[groupId];
      saveGroupDone(nextGroupDone);
    }

    function makeMetric(label, value) {
      return `
        <div class="exercise-metric">
          <span class="exercise-metric-label">${label}</span>
          <span class="exercise-metric-value">${value || "-"}</span>
        </div>
      `;
    }

    function makeGroupMarkup(group, isCustom = false) {
      const details = document.createElement("details");
      details.className = "lift-group";
      details.dataset.groupId = group.id;
      details.dataset.groupTitle = group.title;
      details.dataset.isCustom = String(isCustom);

      details.innerHTML = `
        <summary>
          <div class="lift-group-summary">
            <div>
              <p class="kicker">Muscle Group</p>
              <h2 class="section-title">${escapeHtml(group.title)}</h2>
            </div>
            <label class="group-hit-toggle" onclick="event.stopPropagation();">
              <input
                type="checkbox"
                class="group-hit-checkbox"
                data-group-hit="${group.id}"
                aria-label="Mark ${escapeHtml(group.title)} for today"
              />
              <span>Today</span>
            </label>
          </div>
        </summary>

        <div class="lift-group-body">
          <div class="lift-group-tools">
            <button
              type="button"
              class="secondary-btn add-exercise-btn"
              data-add-group="${group.id}"
            >
              Add exercise
            </button>
          </div>

          <div
            class="exercise-grid"
            id="group-${group.id}"
            data-group-id="${group.id}"
            data-default-exercises='${JSON.stringify(group.exercises || [])}'
          ></div>

          <div class="group-bottom-actions">
            <button
              type="button"
              class="danger-btn delete-group-btn"
              data-delete-section="${group.id}"
              data-is-custom="${String(isCustom)}"
            >
              Delete section
            </button>
          </div>
        </div>
      `;

      return details;
    }

    function renderGroup(groupEl) {
      const groupId = groupEl.dataset.groupId;
      const grid = document.getElementById(`group-${groupId}`);
      const defaults = JSON.parse(grid.dataset.defaultExercises || "[]").map(normalizeExercise);
      const exercises = getExercises(groupId, defaults);
      const doneMap = getExerciseDone(groupId);

      grid.innerHTML = "";

      exercises.forEach((exercise, index) => {
        const safeVideo = normalizeYouTubeEmbed(exercise.video || "");
        const article = document.createElement("article");
        article.className = "exercise-card" + (doneMap[index] ? " is-done" : "");

        article.innerHTML = `
          <div class="exercise-header">
            <div>
              <h3 class="card-title">${escapeHtml(exercise.name)}</h3>
            </div>
            <label class="exercise-check">
              <input type="checkbox" ${doneMap[index] ? "checked" : ""} data-exercise-check="${groupId}" data-index="${index}" />
              <span>Done</span>
            </label>
          </div>

          <div class="exercise-metrics">
            ${makeMetric("Weight", escapeHtml(exercise.weight))}
            ${makeMetric("Sets", escapeHtml(exercise.sets))}
            ${makeMetric("Reps", escapeHtml(exercise.reps))}
            ${makeMetric("Weeks since increase", escapeHtml(exercise.weeksSinceIncrease))}
          </div>

          ${
            safeVideo
              ? `
            <div class="exercise-video-shell">
              <iframe
                src="${safeVideo}"
                title="${escapeHtml(exercise.name)}"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
          `
              : ""
          }

          <div class="exercise-actions">
            <button type="button" class="secondary-btn delete-exercise-btn" data-delete-group="${groupId}" data-index="${index}">
              Delete exercise
            </button>
          </div>
        `;

        grid.appendChild(article);
      });

      grid.querySelectorAll("[data-exercise-check]").forEach((checkbox) => {
        checkbox.addEventListener("change", async (e) => {
          const target = e.currentTarget;
          const idx = Number(target.dataset.index);
          const next = { ...getExerciseDone(groupId) };
          next[idx] = target.checked;
          saveExerciseDone(groupId, next);
          renderGroup(groupEl);
          await saveState();
        });
      });

      grid.querySelectorAll("[data-delete-group]").forEach((btn) => {
        btn.addEventListener("click", async (e) => {
          const idx = Number(e.currentTarget.dataset.index);
          const nextExercises = getExercises(groupId, defaults).filter((_, i) => i !== idx);
          saveExercises(groupId, nextExercises);

          const oldDone = getExerciseDone(groupId);
          const nextDone = {};
          nextExercises.forEach((_, newIndex) => {
            const oldIndex = newIndex >= idx ? newIndex + 1 : newIndex;
            nextDone[newIndex] = !!oldDone[oldIndex];
          });
          saveExerciseDone(groupId, nextDone);

          renderGroup(groupEl);
          await saveState();
        });
      });
    }

    function wireGroupDoneCheckbox(groupEl) {
      const groupDoneMap = loadGroupDone();
      const checkbox = groupEl.querySelector("[data-group-hit]");
      if (!checkbox) return;

      const groupId = checkbox.dataset.groupHit;
      checkbox.checked = !!groupDoneMap[groupId];

      checkbox.addEventListener("change", async () => {
        const next = { ...loadGroupDone() };
        next[groupId] = checkbox.checked;
        saveGroupDone(next);
        await saveState();
      });
    }

    function wireAddExerciseButton(groupEl) {
      const btn = groupEl.querySelector("[data-add-group]");
      if (!btn) return;

      btn.addEventListener("click", async () => {
        const groupId = btn.dataset.addGroup;
        const grid = document.getElementById(`group-${groupId}`);
        const defaults = JSON.parse(grid.dataset.defaultExercises || "[]").map(normalizeExercise);
        const exercises = getExercises(groupId, defaults);

        const name = window.prompt("Exercise name:");
        if (!name) return;

        const weight = window.prompt("Weight:", "") ?? "";
        const sets = window.prompt("Sets:", "3-4") ?? "";
        const reps = window.prompt("Reps:", "8-12") ?? "";
        const weeksSinceIncrease = window.prompt("Weeks since increase:", "") ?? "";
        const video = window.prompt("YouTube link or embed code:", "") ?? "";

        exercises.push(
          normalizeExercise({
            name,
            weight,
            sets,
            reps,
            weeksSinceIncrease,
            video,
          })
        );

        saveExercises(groupId, exercises);
        renderGroup(groupEl);
        await saveState();
      });
    }

    function wireDeleteGroupButton(groupEl) {
      const btn = groupEl.querySelector("[data-delete-section]");
      if (!btn) return;

      btn.addEventListener("click", async () => {
        const groupId = btn.dataset.deleteSection;
        const isCustom = btn.dataset.isCustom === "true";
        const confirmed = window.confirm("Delete this entire section?");
        if (!confirmed) return;

        if (isCustom) {
          const nextGroups = getCustomGroups().filter((group) => group.id !== groupId);
          saveCustomGroups(nextGroups);
          removeStorageForGroup(groupId);
        } else {
          hideGroup(groupId);
        }

        groupEl.remove();
        await saveState();
      });
    }

    function setupGroup(groupEl) {
      renderGroup(groupEl);
      wireGroupDoneCheckbox(groupEl);
      wireAddExerciseButton(groupEl);
      wireDeleteGroupButton(groupEl);
    }

    function hideDefaultGroupsMarkedHidden() {
      const hidden = getHiddenGroups();
      hidden.forEach((groupId) => {
        const existing = document.querySelector(`.lift-group[data-group-id="${groupId}"]`);
        if (existing) existing.remove();
      });
    }

    function renderCustomGroups() {
      const container = document.getElementById("weightlifting-groups");
      const custom = getCustomGroups();
      const hidden = getHiddenGroups();

      custom.forEach((group) => {
        if (hidden.includes(group.id)) return;
        if (container.querySelector(`[data-group-id="${group.id}"]`)) return;
        const groupEl = makeGroupMarkup(group, true);
        container.appendChild(groupEl);
        setupGroup(groupEl);
      });
    }

    function setupCreateGroup() {
      const btn = document.getElementById("create-group-btn");
      const input = document.getElementById("new-group-title");

      btn.addEventListener("click", async () => {
        const rawTitle = input.value.trim();
        if (!rawTitle) return;

        const baseId = slugify(rawTitle);
        const allExistingIds = [
          ...defaultGroups.map((group) => group.id),
          ...getCustomGroups().map((group) => group.id),
        ];

        let nextId = baseId || `group-${Date.now()}`;
        let counter = 2;

        while (allExistingIds.includes(nextId)) {
          nextId = `${baseId}-${counter}`;
          counter += 1;
        }

        const newGroup = normalizeGroup({
          id: nextId,
          title: rawTitle,
          exercises: [],
        });

        saveCustomGroups([...getCustomGroups(), newGroup]);
        unhideGroup(nextId);

        const container = document.getElementById("weightlifting-groups");
        const groupEl = makeGroupMarkup(newGroup, true);
        container.appendChild(groupEl);
        setupGroup(groupEl);
        groupEl.open = true;

        input.value = "";
        await saveState();
      });
    }

    function setupWeightTraining() {
      hideDefaultGroupsMarkedHidden();

      document.querySelectorAll(".lift-group").forEach((groupEl) => {
        setupGroup(groupEl);
      });

      renderCustomGroups();
      setupCreateGroup();
    }

    async function init() {
      const saved = normalizeData(await loadState());

      defaultGroups =
        Array.isArray(saved.groups) && saved.groups.length
          ? saved.groups.map(normalizeGroup)
          : cloneDefaults().groups.map(normalizeGroup);

      hiddenGroupIds = Array.isArray(saved.hiddenGroupIds) ? saved.hiddenGroupIds : [];
      customGroups = Array.isArray(saved.customGroups) ? saved.customGroups.map(normalizeGroup) : [];
      groupDone = saved.groupDone && typeof saved.groupDone === "object" ? saved.groupDone : {};
      exerciseData = saved.exerciseData && typeof saved.exerciseData === "object" ? saved.exerciseData : {};
      exerciseDone = saved.exerciseDone && typeof saved.exerciseDone === "object" ? saved.exerciseDone : {};

      hasLoadedInitialState = true;
      setupWeightTraining();
    }

    init();
  </script>
</BaseLayout>