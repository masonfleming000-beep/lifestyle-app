---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Career Portfolio | Lifestyle App" description="Public-facing portfolio">
  <section class="hero">
    <div class="hero-card">
      <p class="kicker">Career / Portfolio</p>
      <h1>Selected public portfolio</h1>
      <p>
        This page only shows the items marked visible from the Information page.
      </p>
    </div>
  </section>

  <div id="portfolio-root" class="grid one"></div>

  <script is:inline>
    const sourcePageKey = "career-information";

    const defaultData = {
      projects: [],
      school: [],
      experience: [],
      about: [],
      looking: [],
      pitch: [],
      stats: [],
      contact: [],
      resume: [],
      timelineItems: [],
      recommendations: [],
      star: [],
    };

    function cloneDefaults() {
      return JSON.parse(JSON.stringify(defaultData));
    }

    function normalizeData(raw) {
      const parsed = raw && typeof raw === "object" ? raw : {};
      return {
        ...cloneDefaults(),
        ...parsed,
        projects: Array.isArray(parsed.projects) ? parsed.projects : [],
        school: Array.isArray(parsed.school) ? parsed.school : [],
        experience: Array.isArray(parsed.experience) ? parsed.experience : [],
        about: Array.isArray(parsed.about) ? parsed.about : [],
        looking: Array.isArray(parsed.looking) ? parsed.looking : [],
        pitch: Array.isArray(parsed.pitch) ? parsed.pitch : [],
        stats: Array.isArray(parsed.stats) ? parsed.stats : [],
        contact: Array.isArray(parsed.contact) ? parsed.contact : [],
        resume: Array.isArray(parsed.resume) ? parsed.resume : [],
        timelineItems: Array.isArray(parsed.timelineItems) ? parsed.timelineItems : [],
        recommendations: Array.isArray(parsed.recommendations) ? parsed.recommendations : [],
        star: Array.isArray(parsed.star) ? parsed.star : [],
      };
    }

    async function loadState() {
      try {
        const res = await fetch(`/api/state?pageKey=${encodeURIComponent(sourcePageKey)}`, {
          credentials: "include",
          cache: "no-store",
        });

        if (!res.ok) return null;

        const payload = await res.json();
        return payload?.state ?? null;
      } catch (error) {
        console.error("Failed to load portfolio source state:", error);
        return null;
      }
    }

    function escapeHtml(value) {
      return String(value || "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function titleMap(section) {
      const map = {
        projects: "Projects",
        school: "School Development",
        experience: "Work Experience",
        about: "About / Story",
        looking: "What I'm Looking For",
        pitch: "Pitch",
        stats: "Stats",
        contact: "Contact Info",
        resume: "Resume",
        timelineItems: "Timeline",
        recommendations: "Recommendations",
        star: "STAR Moments",
      };
      return map[section] || section;
    }

    function visibleItems(data, section) {
      return (data[section] || []).filter((item) => item.visible);
    }

    function formatDate(dateStr) {
      if (!dateStr) return "";
      const date = new Date(dateStr + "T00:00:00");
      if (Number.isNaN(date.getTime())) return dateStr;
      return date.toLocaleDateString("en-US", {
        month: "short",
        day: "numeric",
        year: "numeric",
      });
    }

    function renderTextSection(title, items) {
      return `
        <section class="section">
          <details class="card dropdown-card" open>
            <summary class="dropdown-summary">
              <div>
                <h2 class="section-title">${escapeHtml(title)}</h2>
                <p class="section-subtitle">${items.length} selected item(s)</p>
              </div>
            </summary>
            <div class="dropdown-body">
              <div class="grid one">
                ${items
                  .map(
                    (item) => `
                    <article class="card soft">
                      <h3 class="card-title">${escapeHtml(item.title || "")}</h3>
                      ${item.subtitle ? `<p class="meta">${escapeHtml(item.subtitle)}</p>` : ""}
                      ${item.body ? `<p>${escapeHtml(item.body)}</p>` : ""}
                    </article>
                  `
                  )
                  .join("")}
              </div>
            </div>
          </details>
        </section>
      `;
    }

    function renderProjectLikeSection(title, items, type) {
      return `
        <section class="section">
          <details class="card dropdown-card" open>
            <summary class="dropdown-summary">
              <div>
                <h2 class="section-title">${escapeHtml(title)}</h2>
                <p class="section-subtitle">${items.length} selected item(s)</p>
              </div>
            </summary>
            <div class="dropdown-body">
              <div class="grid two">
                ${items
                  .map((item) => {
                    if (type === "projects") {
                      return `
                        <article class="card">
                          <h3 class="card-title">${escapeHtml(item.title || "Untitled")}</h3>
                          <p class="meta">
                            ${escapeHtml(item.stage || "")}
                            ${item.timeline ? ` · ${escapeHtml(item.timeline)}` : ""}
                            ${item.completed ? ` · ${escapeHtml(item.completed)}` : ""}
                          </p>

                          ${item.description ? `<p>${escapeHtml(item.description)}</p>` : ""}

                          <div class="entry-meta-grid">
                            ${item.impact ? `<div><strong>Impact:</strong> ${escapeHtml(item.impact)}</div>` : ""}
                            ${item.members ? `<div><strong>Members:</strong> ${escapeHtml(item.members)}</div>` : ""}
                            ${item.parts ? `<div><strong>Parts / Tools:</strong> ${escapeHtml(item.parts)}</div>` : ""}
                            ${item.specifications ? `<div><strong>Specs:</strong> ${escapeHtml(item.specifications)}</div>` : ""}
                          </div>

                          ${item.depth ? `<p><strong>Technical depth:</strong> ${escapeHtml(item.depth)}</p>` : ""}
                          ${item.issues ? `<p><strong>Issues:</strong> ${escapeHtml(item.issues)}</p>` : ""}
                          ${item.visuals ? `<p><strong>Visuals:</strong> ${escapeHtml(item.visuals)}</p>` : ""}
                          ${item.diagrams ? `<p><strong>Diagrams:</strong> ${escapeHtml(item.diagrams)}</p>` : ""}

                          ${
                            item.link
                              ? `<p><a href="${escapeHtml(item.link)}" target="_blank" rel="noreferrer">Open link</a></p>`
                              : ""
                          }
                        </article>
                      `;
                    }

                    if (type === "school") {
                      return `
                        <article class="card">
                          <h3 class="card-title">${escapeHtml(item.title || "School Item")}</h3>
                          <p class="meta">
                            ${escapeHtml(item.prof || "")}
                            ${item.stage ? ` · ${escapeHtml(item.stage)}` : ""}
                          </p>
                          ${item.helped ? `<p><strong>Helped with:</strong> ${escapeHtml(item.helped)}</p>` : ""}
                          ${item.relevance ? `<p><strong>Relevance:</strong> ${escapeHtml(item.relevance)}</p>` : ""}
                          ${item.notes ? `<p><strong>Notes:</strong> ${escapeHtml(item.notes)}</p>` : ""}
                        </article>
                      `;
                    }

                    return `
                      <article class="card">
                        <h3 class="card-title">${escapeHtml(item.title || "Experience")}</h3>
                        <p class="meta">
                          ${escapeHtml(item.boss || "")}
                          ${item.date ? ` · ${escapeHtml(item.date)}` : ""}
                        </p>

                        ${item.impact ? `<p><strong>Impact:</strong> ${escapeHtml(item.impact)}</p>` : ""}
                        ${item.pictures ? `<p><strong>Pictures / visuals:</strong> ${escapeHtml(item.pictures)}</p>` : ""}

                        ${
                          Array.isArray(item.responsibilities) && item.responsibilities.length
                            ? `<ul class="list-clean">${item.responsibilities
                                .map((bullet) => `<li>${escapeHtml(bullet)}</li>`)
                                .join("")}</ul>`
                            : ""
                        }
                      </article>
                    `;
                  })
                  .join("")}
              </div>
            </div>
          </details>
        </section>
      `;
    }

    function renderStatsSection(title, items) {
      return `
        <section class="section">
          <details class="card dropdown-card" open>
            <summary class="dropdown-summary">
              <div>
                <h2 class="section-title">${escapeHtml(title)}</h2>
                <p class="section-subtitle">${items.length} selected item(s)</p>
              </div>
            </summary>
            <div class="dropdown-body">
              <div class="metric-grid">
                ${items
                  .map(
                    (item) => `
                    <article class="metric">
                      <p class="metric-label">${escapeHtml(item.title || "Stat")}</p>
                      <p class="big-number">${escapeHtml(item.impact || "--")}</p>
                      ${item.description ? `<p>${escapeHtml(item.description)}</p>` : ""}
                    </article>
                  `
                  )
                  .join("")}
              </div>
            </div>
          </details>
        </section>
      `;
    }

    function renderContactSection(title, items) {
      return `
        <section class="section">
          <details class="card dropdown-card" open>
            <summary class="dropdown-summary">
              <div>
                <h2 class="section-title">${escapeHtml(title)}</h2>
              </div>
            </summary>
            <div class="dropdown-body">
              <div class="grid one">
                ${items
                  .map(
                    (item) => `
                    <article class="card soft">
                      <h3 class="card-title">${escapeHtml(item.title || "Contact Info")}</h3>
                      ${item.github ? `<p><strong>GitHub:</strong> ${escapeHtml(item.github)}</p>` : ""}
                      ${item.email ? `<p><strong>Email:</strong> ${escapeHtml(item.email)}</p>` : ""}
                      ${item.phone ? `<p><strong>Phone:</strong> ${escapeHtml(item.phone)}</p>` : ""}
                      ${
                        item.link
                          ? `<p><strong>Link:</strong> <a href="${escapeHtml(item.link)}" target="_blank" rel="noreferrer">${escapeHtml(item.link)}</a></p>`
                          : ""
                      }
                    </article>
                  `
                  )
                  .join("")}
              </div>
            </div>
          </details>
        </section>
      `;
    }

    function renderResumeSection(title, items) {
      return `
        <section class="section">
          <details class="card dropdown-card" open>
            <summary class="dropdown-summary">
              <div>
                <h2 class="section-title">${escapeHtml(title)}</h2>
              </div>
            </summary>
            <div class="dropdown-body">
              <div class="grid one">
                ${items
                  .map((item) => {
                    const isPdf =
                      item.fileType === "application/pdf" ||
                      (item.fileName || "").toLowerCase().endsWith(".pdf");

                    return `
                      <article class="card soft">
                        <h3 class="card-title">${escapeHtml(item.title || "Resume")}</h3>
                        ${item.fileName ? `<p><strong>File:</strong> ${escapeHtml(item.fileName)}</p>` : ""}

                        ${
                          isPdf && item.fileDataUrl
                            ? `
                              <div class="resume-preview-wrap">
                                <iframe
                                  src="${item.fileDataUrl}"
                                  title="${escapeHtml(item.title || "Resume Preview")}"
                                  class="resume-preview-frame"
                                ></iframe>
                              </div>
                            `
                            : `
                              <p class="section-subtitle">
                                Preview is available for PDF resumes. For this file type, use the button below to open or download it.
                              </p>
                            `
                        }

                        ${
                          item.fileDataUrl
                            ? `
                              <div class="resume-actions">
                                <a
                                  href="${item.fileDataUrl}"
                                  target="_blank"
                                  rel="noreferrer"
                                  class="edu-button"
                                >
                                  Open Resume
                                </a>
                                <a
                                  href="${item.fileDataUrl}"
                                  download="${escapeHtml(item.fileName || "resume")}"
                                  class="edu-button secondary-button"
                                >
                                  Download Resume
                                </a>
                              </div>
                            `
                            : ""
                        }
                      </article>
                    `;
                  })
                  .join("")}
              </div>
            </div>
          </details>
        </section>
      `;
    }
    function renderTimelineSection(title, items) {
      const sorted = [...items].sort((a, b) => {
        const aDate = a.date || "9999-12-31";
        const bDate = b.date || "9999-12-31";
        return aDate.localeCompare(bDate);
      });

      return `
        <section class="section">
          <details class="card dropdown-card" open>
            <summary class="dropdown-summary">
              <div>
                <h2 class="section-title">${escapeHtml(title)}</h2>
              </div>
            </summary>
            <div class="dropdown-body">
              <div class="timeline-list">
                ${sorted
                  .map(
                    (item) => `
                    <article class="timeline-item">
                      <div class="timeline-dot"></div>
                      <div class="timeline-content">
                        <p class="timeline-date">${escapeHtml(formatDate(item.date))}</p>
                        <h3 class="card-title">${escapeHtml(item.title || "")}</h3>
                        ${item.description ? `<p>${escapeHtml(item.description)}</p>` : ""}
                      </div>
                    </article>
                  `
                  )
                  .join("")}
              </div>
            </div>
          </details>
        </section>
      `;
    }

    function renderRecommendationsSection(title, items) {
      return `
        <section class="section">
          <details class="card dropdown-card" open>
            <summary class="dropdown-summary">
              <div>
                <h2 class="section-title">${escapeHtml(title)}</h2>
              </div>
            </summary>
            <div class="dropdown-body">
              <div class="grid one">
                ${items
                  .map(
                    (item) => `
                    <article class="card quote-card soft">
                      <p class="quote-text">“${escapeHtml(item.body || item.title || "")}”</p>
                      <span class="quote-author">${escapeHtml(item.owner || "Recommendation")}</span>
                    </article>
                  `
                  )
                  .join("")}
              </div>
            </div>
          </details>
        </section>
      `;
    }

    function renderStarSection(title, items) {
      return `
        <section class="section">
          <details class="card dropdown-card" open>
            <summary class="dropdown-summary">
              <div>
                <h2 class="section-title">${escapeHtml(title)}</h2>
              </div>
            </summary>
            <div class="dropdown-body">
              <div class="grid one">
                ${items
                  .map(
                    (item) => `
                    <article class="card">
                      <h3 class="card-title">${escapeHtml(item.title || "STAR Entry")}</h3>
                      <div class="star-grid">
                        <div><strong>Situation</strong><p>${escapeHtml(item.situation || "-")}</p></div>
                        <div><strong>Task</strong><p>${escapeHtml(item.task || "-")}</p></div>
                        <div><strong>Action</strong><p>${escapeHtml(item.action || "-")}</p></div>
                        <div><strong>Result</strong><p>${escapeHtml(item.result || "-")}</p></div>
                      </div>
                    </article>
                  `
                  )
                  .join("")}
              </div>
            </div>
          </details>
        </section>
      `;
    }

    function hasVisibleItems(data) {
      return Object.values(data).some(
        (arr) => Array.isArray(arr) && arr.some((item) => item.visible)
      );
    }

    function renderPortfolio(data) {
      const root = document.getElementById("portfolio-root");
      if (!root) return;

      let html = "";

      const about = visibleItems(data, "about");
      const looking = visibleItems(data, "looking");
      const pitch = visibleItems(data, "pitch");
      const projects = visibleItems(data, "projects");
      const school = visibleItems(data, "school");
      const experience = visibleItems(data, "experience");
      const stats = visibleItems(data, "stats");
      const contact = visibleItems(data, "contact");
      const resume = visibleItems(data, "resume");
      const timelineItems = visibleItems(data, "timelineItems");
      const recommendations = visibleItems(data, "recommendations");
      const star = visibleItems(data, "star");

      if (!hasVisibleItems(data)) {
        html = `
          <section class="section">
            <article class="card">
              <h2 class="section-title">Nothing selected yet</h2>
              <p>
                Go to <a href="/career/information">Career Information</a> and mark entries
                as visible in portfolio.
              </p>
            </article>
          </section>
        `;
        root.innerHTML = html;
        return;
      }

      if (about.length) html += renderTextSection(titleMap("about"), about);
      if (looking.length) html += renderTextSection(titleMap("looking"), looking);
      if (pitch.length) html += renderTextSection(titleMap("pitch"), pitch);

      if (projects.length) html += renderProjectLikeSection(titleMap("projects"), projects, "projects");
      if (school.length) html += renderProjectLikeSection(titleMap("school"), school, "school");
      if (experience.length) html += renderProjectLikeSection(titleMap("experience"), experience, "experience");

      if (stats.length) html += renderStatsSection(titleMap("stats"), stats);
      if (timelineItems.length) html += renderTimelineSection(titleMap("timelineItems"), timelineItems);
      if (recommendations.length) html += renderRecommendationsSection(titleMap("recommendations"), recommendations);
      if (star.length) html += renderStarSection(titleMap("star"), star);
      if (contact.length) html += renderContactSection(titleMap("contact"), contact);
      if (resume.length) html += renderResumeSection(titleMap("resume"), resume);

      root.innerHTML = html;
    }

    async function init() {
      const saved = await loadState();
      const data = normalizeData(saved);
      renderPortfolio(data);
    }

    init();
  </script>
</BaseLayout>