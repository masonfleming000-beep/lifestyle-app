---
import BaseLayout from "../../layouts/BaseLayout.astro";

const defaultCareerData = JSON.stringify({
  projects: [],
  school: [],
  experience: [],
  about: [],
  looking: [],
  pitch: [],
  stats: [],
  contact: [],
  timelineItems: [],
  recommendations: [],
  star: [],
  resume: [],
});
---

<BaseLayout title="Career Information | Lifestyle App" description="Private information builder">
  <section class="hero">
    <div class="hero-card">
      <p class="kicker">Career</p>
      <h1>Information Builder</h1>
      <p>
        Add and organize your private career information here. Each section gets its
        own form layout, and only items marked visible will appear in the portfolio.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="career-topbar">
      <a href="/career" class="ghost-link">← Back to Career</a>
      <a href="/career/portfolio" class="edu-button">Go to Portfolio</a>
    </div>
  </section>

  <section class="section">
    <div class="career-shell">
      <article class="card career-panel-card">
        <div class="career-panel-header">
          <div>
            <h2 class="section-title">Add New Entry</h2>
            <p class="section-subtitle">
              Pick a section first. The form changes based on what you're adding.
            </p>
          </div>
        </div>

        <div class="dynamic-builder-shell">
          <label class="edu-label">
            <span>Section</span>
            <select id="dynamic-section-select" class="form-input">
              <option value="projects">Projects</option>
              <option value="school">School Development</option>
              <option value="experience">Work Experience</option>
              <option value="about">About / Story</option>
              <option value="looking">What I'm Looking For</option>
              <option value="pitch">Pitch</option>
              <option value="stats">Stats</option>
              <option value="contact">Contact Info</option>
              <option value="resume">Resume Upload</option>
              <option value="timeline">Timeline</option>
              <option value="recommendations">Recommendations</option>
              <option value="star">STAR Moments</option>
            </select>
          </label>

          <div id="dynamic-form-area"></div>
        </div>
      </article>

      <article class="card career-panel-card">
        <div class="career-panel-header">
          <div>
            <h2 class="section-title">Saved Entries</h2>
            <p class="section-subtitle">
              Everything stays private here until marked visible for portfolio.
            </p>
          </div>
        </div>

        <div class="saved-sections">
          <details class="saved-dropdown" open>
            <summary>Projects <span id="count-projects">0</span></summary>
            <div id="info-projects" class="grid one"></div>
          </details>

          <details class="saved-dropdown">
            <summary>School Development <span id="count-school">0</span></summary>
            <div id="info-school" class="grid one"></div>
          </details>

          <details class="saved-dropdown">
            <summary>Work Experience <span id="count-experience">0</span></summary>
            <div id="info-experience" class="grid one"></div>
          </details>

          <details class="saved-dropdown">
            <summary>About / Story <span id="count-about">0</span></summary>
            <div id="info-about" class="grid one"></div>
          </details>

          <details class="saved-dropdown">
            <summary>What I'm Looking For <span id="count-looking">0</span></summary>
            <div id="info-looking" class="grid one"></div>
          </details>

          <details class="saved-dropdown">
            <summary>Pitch <span id="count-pitch">0</span></summary>
            <div id="info-pitch" class="grid one"></div>
          </details>

          <details class="saved-dropdown">
            <summary>Stats <span id="count-stats">0</span></summary>
            <div id="info-stats" class="grid one"></div>
          </details>

          <details class="saved-dropdown">
            <summary>Contact Info <span id="count-contact">0</span></summary>
            <div id="info-contact" class="grid one"></div>
          </details>

          <details class="saved-dropdown">
            <summary>Resume Upload <span id="count-resume">0</span></summary>
            <div id="info-resume" class="grid one"></div>
          </details>

          <details class="saved-dropdown">
            <summary>Timeline <span id="count-timeline">0</span></summary>
            <div id="info-timeline" class="grid one"></div>
          </details>

          <details class="saved-dropdown">
            <summary>Recommendations <span id="count-recommendations">0</span></summary>
            <div id="info-recommendations" class="grid one"></div>
          </details>

          <details class="saved-dropdown">
            <summary>STAR Moments <span id="count-star">0</span></summary>
            <div id="info-star" class="grid one"></div>
          </details>
        </div>
      </article>

      <article class="card career-panel-card">
        <div class="career-panel-header">
          <div>
            <h2 class="section-title">Actions</h2>
          </div>
        </div>

        <button class="delete-mini-button danger-big" id="clear-all-btn" type="button">
          Clear Everything
        </button>
      </article>
    </div>
  </section>

  <script define:vars={{ defaultCareerData }}>
    const pageKey = "career-information";

    function cloneDefaults() {
      return JSON.parse(defaultCareerData);
    }

    function normalizeData(raw) {
      const parsed = raw && typeof raw === "object" ? raw : {};
      return {
        ...cloneDefaults(),
        ...parsed,
        projects: Array.isArray(parsed.projects) ? parsed.projects : [],
        school: Array.isArray(parsed.school) ? parsed.school : [],
        experience: Array.isArray(parsed.experience) ? parsed.experience : [],
        about: Array.isArray(parsed.about) ? parsed.about : [],
        looking: Array.isArray(parsed.looking) ? parsed.looking : [],
        pitch: Array.isArray(parsed.pitch) ? parsed.pitch : [],
        stats: Array.isArray(parsed.stats) ? parsed.stats : [],
        contact: Array.isArray(parsed.contact) ? parsed.contact : [],
        resume: Array.isArray(parsed.resume) ? parsed.resume : [],
        timelineItems: Array.isArray(parsed.timelineItems) ? parsed.timelineItems : [],
        recommendations: Array.isArray(parsed.recommendations) ? parsed.recommendations : [],
        star: Array.isArray(parsed.star) ? parsed.star : [],
      };
    }

    function makeId() {
      if (window.crypto && typeof window.crypto.randomUUID === "function") {
        return window.crypto.randomUUID();
      }
      return "id-" + Date.now() + "-" + Math.random().toString(16).slice(2);
    }

    let data = cloneDefaults();
    let hasLoadedInitialState = false;
    let isSaving = false;
    let pendingSave = false;

    async function loadState() {
      try {
        const res = await fetch(`/api/state?pageKey=${encodeURIComponent(pageKey)}`, {
          credentials: "include",
          cache: "no-store",
        });

        if (!res.ok) return null;

        const payload = await res.json();
        return payload?.state ?? null;
      } catch (error) {
        console.error("Failed to load state:", error);
        return null;
      }
    }

    async function saveState() {
      if (!hasLoadedInitialState) return;

      if (isSaving) {
        pendingSave = true;
        return;
      }

      isSaving = true;

      try {
        await fetch("/api/state", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ pageKey, state: data }),
        });
      } catch (error) {
        console.error("Failed to save state:", error);
      } finally {
        isSaving = false;

        if (pendingSave) {
          pendingSave = false;
          await saveState();
        }
      }
    }

    function escapeHtml(value) {
      return String(value || "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function getValue(id) {
      const el = document.getElementById(id);
      return el ? el.value.trim() : "";
    }

    function getChecked(id) {
      const el = document.getElementById(id);
      return !!el?.checked;
    }

    function formatDate(dateStr) {
      if (!dateStr) return "—";
      const date = new Date(dateStr + "T00:00:00");
      if (Number.isNaN(date.getTime())) return dateStr;
      return date.toLocaleDateString("en-US", {
        month: "short",
        day: "numeric",
        year: "numeric",
      });
    }

    function setCount(id, count) {
      const el = document.getElementById(id);
      if (el) el.textContent = String(count);
    }

    async function persistAndRefresh() {
      renderSavedEntries();
      await saveState();
    }

    async function deleteItem(group, id) {
      data[group] = data[group].filter((item) => item.id !== id);
      await persistAndRefresh();
    }

    async function toggleVisible(group, id) {
      data[group] = data[group].map((item) =>
        item.id === id ? { ...item, visible: !item.visible } : item
      );
      await persistAndRefresh();
    }

    async function fileToDataUrl(file) {
      return await new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(reader.result);
        reader.onerror = reject;
        reader.readAsDataURL(file);
      });
    }

