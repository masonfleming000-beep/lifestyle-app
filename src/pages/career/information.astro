---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import SurfaceCard from "../../components/SurfaceCard.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import Button from "../../components/Button.astro";
import ActionBar from "../../components/ActionBar.astro";
import PageActions from "../../components/ui/PageActions.astro";
import CountedExpandablePanel from "../../components/primitives/CountedExpandablePanel.astro";
import {
  careerBuilderOptions,
  careerInformationDefaults,
  careerInformationHeroActions,
  careerInformationPageKey,
  careerInformationSections,
} from "../../config/pages/careerShared";
---

<BaseLayout title="Career Information | Lifestyle App" description="Private information builder">
  <PageHero
    kicker="Career"
    title="Information Builder"
    description="Add and organize your private career information here. This now includes profile basics, external links, leadership, organizations, honors, licenses, and contact preferences, alongside the existing sections."
  >
    <PageActions>
      {careerInformationHeroActions.map((action) => (
        <Button href={action.href} variant={action.variant || "secondary"}>{action.label}</Button>
      ))}
    </PageActions>
  </PageHero>

  <section class="section">
    <div class="career-shell">
      <SurfaceCard className="career-panel-card">
        <SectionHeader
          title="Add New Entry"
          subtitle="Pick a section first. The form changes based on what you're adding, including the new profile and portfolio sections."
        >
          <div id="save-status" class="save-status neutral">Loading...</div>
        </SectionHeader>

        <div class="dynamic-builder-shell">
          <label class="edu-label">
            <span>Section</span>
            <select id="dynamic-section-select" class="form-input">
              {careerBuilderOptions.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>

          <div id="dynamic-form-area"></div>
        </div>
      </SurfaceCard>

      <SurfaceCard className="career-panel-card">
        <SectionHeader
          title="Saved Entries"
          subtitle="Everything stays private here until marked visible for portfolio preview."
        />

        <div class="saved-sections">
          {careerInformationSections.map((section) => (
            <CountedExpandablePanel
              title={section.title}
              countId={section.countId}
              containerId={section.containerId}
              emptyTitle={section.emptyTitle}
              emptyText={section.emptyText}
              open={Boolean(section.open)}
              bodyClass="career-expand-body"
            />
          ))}
        </div>
      </SurfaceCard>

      <SurfaceCard className="career-panel-card">
        <SectionHeader
          title="Actions"
          subtitle="Use this carefully. This clears every saved section on the page."
        />
        <ActionBar align="start">
          <Button id="clear-all-btn" type="button" variant="danger">
            Clear Everything
          </Button>
        </ActionBar>
      </SurfaceCard>
    </div>
  </section>

  <script
    id="career-information-page-config"
    type="application/json"
    set:html={JSON.stringify({
      pageKey: careerInformationPageKey,
      defaults: careerInformationDefaults,
      sections: careerInformationSections,
    })}
  />

  <script>
    import { initCareerInformationPage } from "../../lib/client/careerInformationPage";

    const configElement = document.getElementById("career-information-page-config");
    const config = JSON.parse(configElement?.textContent || "{}");

    initCareerInformationPage(config);
  </script>

  <style>
    .career-shell {
      display: grid;
      gap: 1.25rem;
    }

    .career-panel-card {
      border-radius: 1.25rem;
    }

    .career-panel-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .grid.one {
      grid-template-columns: 1fr;
    }

    .edu-label {
      display: grid;
      gap: 0.45rem;
      margin-bottom: 0.95rem;
    }

    .edu-label span {
      font-weight: 600;
    }

    .check-row {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      margin-bottom: 1rem;
      font-weight: 600;
    }

    .career-inline-button {
      white-space: nowrap;
    }

    .career-inline-button-mini {
      padding: 0.6rem 0.9rem;
      font-size: 0.92rem;
    }

    .assignment-card {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem;
      border-radius: 1rem;
      border: 1px solid var(--border-soft);
      background: var(--card-surface-color);
      margin-bottom: 0.85rem;
    }

    .assignment-main {
      flex: 1;
      min-width: 0;
    }

    .assignment-actions {
      display: flex;
      gap: 0.55rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .edit-mode-banner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-bottom: 0.9rem;
      padding: 0.8rem 0.95rem;
      border: 1px solid var(--border-soft);
      border-radius: 0.9rem;
      background: rgba(59, 130, 246, 0.08);
      font-weight: 600;
    }


    .custom-field-manager {
      display: grid;
      gap: 0.9rem;
      margin-top: 0.5rem;
      padding-top: 0.25rem;
      border-top: 1px solid var(--border-soft);
    }

    .custom-field-toolbar {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 0.85rem;
      flex-wrap: wrap;
    }

    .custom-field-toolbar-actions {
      display: flex;
      gap: 0.65rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .custom-field-picker {
      min-width: 13rem;
    }

    .custom-field-list {
      display: grid;
      gap: 0.85rem;
    }

    .custom-field-card {
      border: 1px solid var(--border-soft);
      border-radius: 1rem;
      padding: 0.9rem;
      background: rgba(148, 163, 184, 0.06);
    }

    .custom-field-card-top {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
      gap: 0.85rem;
      align-items: end;
    }

    .custom-field-remove-wrap {
      display: flex;
      justify-content: flex-end;
      align-items: end;
      padding-bottom: 0.95rem;
    }

    .custom-field-empty,
    .custom-field-helper {
      margin: 0;
    }

    .custom-field-output {
      display: grid;
      gap: 0.85rem;
      margin-top: 1rem;
      padding-top: 0.85rem;
      border-top: 1px solid var(--border-soft);
    }

    .custom-field-output-item p {
      margin: 0.2rem 0;
    }

    .custom-field-media-grid {
      display: flex;
      gap: 0.65rem;
      flex-wrap: wrap;
      margin-top: 0.35rem;
    }

    .custom-field-media {
      width: min(100%, 14rem);
      border-radius: 0.9rem;
      border: 1px solid var(--border-soft);
      object-fit: cover;
      background: var(--embed-surface-color);
    }

    .custom-field-video {
      aspect-ratio: 16 / 9;
    }

    .custom-field-file-grid {
      align-items: stretch;
    }

    .custom-field-file-card,
    .custom-field-upload-item-file {
      display: flex;
      justify-content: space-between;
      gap: 0.85rem;
      align-items: center;
      width: min(100%, 22rem);
      padding: 0.9rem 1rem;
      border-radius: 1rem;
      border: 1px solid var(--border-soft);
      background: var(--card-surface-color);
    }

    .custom-field-upload-wrap {
      display: grid;
      gap: 0.75rem;
    }

    .custom-field-upload-toolbar {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .custom-field-hidden-value {
      display: none;
    }

    .custom-field-upload-list {
      display: grid;
      gap: 0.8rem;
    }

    .custom-field-upload-item {
      border: 1px solid var(--border-soft);
      border-radius: 1rem;
      background: var(--dropdown-card-surface-color);
      padding: 0.85rem;
      display: grid;
      gap: 0.75rem;
    }

    .custom-field-upload-item-image,
    .custom-field-upload-item-video {
      justify-items: start;
    }

    .custom-field-upload-preview {
      width: min(100%, 18rem);
      display: block;
      border-radius: 0.95rem;
      border: 1px solid var(--border-soft);
      background: var(--embed-surface-color);
    }

    .custom-field-upload-preview-image,
    .custom-field-upload-preview-video {
      aspect-ratio: 16 / 9;
      object-fit: cover;
    }

    .custom-field-upload-preview-image {
      aspect-ratio: 1;
    }

    .custom-field-upload-meta-row {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
    }

    .custom-field-upload-file-name {
      margin: 0 0 0.35rem;
      font-weight: 700;
      word-break: break-word;
    }

    .selector-state {
      display: inline-flex;
      align-items: center;
      padding: 0.3rem 0.65rem;
      border-radius: 999px;
      font-size: 0.8rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
      background: rgba(107, 114, 128, 0.12);
      color: #4b5563;
    }

    .selector-state.selected {
      background: rgba(22, 163, 74, 0.12);
      color: #15803d;
    }

    .saved-sections {
      display: grid;
      gap: 0.9rem;
    }

    .saved-dropdown {
      border: 1px solid var(--border-soft);
      border-radius: 1rem;
      background: var(--dropdown-card-surface-color);
      overflow: hidden;
    }

    .saved-dropdown summary {
      cursor: pointer;
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      padding: 1rem 1.1rem;
      font-weight: 700;
    }

    .saved-dropdown summary::-webkit-details-marker {
      display: none;
    }

    .saved-dropdown > div {
      padding: 0 1rem 1rem;
    }

    .dynamic-builder-shell {
      display: grid;
      gap: 1rem;
    }

    .dynamic-form-card {
      padding: 1rem;
      border-radius: 1rem;
      background: var(--card-surface-color);
      border: 1px solid var(--border-soft);
    }

    .dynamic-form-grid {
      display: grid;
      gap: 0.9rem;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .dynamic-form-grid.one {
      grid-template-columns: 1fr;
    }

    .dynamic-form-full {
      grid-column: 1 / -1;
    }

    .section-helper {
      margin: 0 0 0.8rem;
      color: #6b7280;
    }

    .field-hint {
      margin: 0;
      color: #6b7280;
      font-size: 0.95rem;
    }

    .portfolio-inline-preview {
      display: grid;
      gap: 0.55rem;
      padding: 0.85rem;
      border-radius: 1rem;
      border: 1px solid var(--border-soft);
      background: var(--dropdown-card-surface-color);
    }

    .portfolio-inline-photo-frame {
      width: 124px;
      aspect-ratio: 1;
      overflow: hidden;
      border-radius: 1rem;
      border: 1px solid var(--border-soft);
      background: var(--embed-surface-color);
    }

    .portfolio-inline-photo {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .empty-state {
      margin: 0;
      color: #6b7280;
    }

    .list-clean {
      margin-top: 0.5rem;
    }

    .save-status {
      display: inline-flex;
      align-items: center;
      padding: 0.45rem 0.8rem;
      border-radius: 999px;
      font-size: 0.85rem;
      font-weight: 700;
    }

    .save-status.neutral {
      background: rgba(107, 114, 128, 0.12);
      color: #4b5563;
    }

    .save-status.success {
      background: rgba(22, 163, 74, 0.12);
      color: #15803d;
    }

    .save-status.error {
      background: rgba(220, 38, 38, 0.12);
      color: #b91c1c;
    }

    .resume-link-row {
      display: flex;
      gap: 0.6rem;
      flex-wrap: wrap;
      margin-top: 0.85rem;
      margin-bottom: 0.85rem;
    }

    .resume-download-btn {
      background: rgba(47, 93, 98, 0.12);
      color: #2f5d62;
    }

    .resume-preview-wrap {
      margin-top: 0.9rem;
      border: 1px solid rgba(47, 93, 98, 0.12);
      border-radius: 1rem;
      overflow: hidden;
      background: var(--embed-surface-color);
    }

    .resume-preview-frame {
      width: 100%;
      min-height: 640px;
      border: 0;
      display: block;
      background: var(--card-surface-color);
    }

    .project-card-toggle-group {
      margin: 0;
      border: 1px solid var(--border-soft);
      border-radius: 1rem;
      padding: 0.9rem 1rem;
      display: grid;
      gap: 0.85rem;
    }

    .project-card-toggle-group legend {
      padding: 0 0.35rem;
      font-weight: 700;
    }

    .project-card-toggle-grid,
    .project-card-display-list,
    .project-page-section-actions {
      display: flex;
      gap: 0.65rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .check-row.compact {
      margin: 0;
      font-weight: 500;
    }

    .project-form-note,
    .project-settings-block {
      margin-top: 1rem;
      padding: 0.95rem 1rem;
      border: 1px solid var(--border-soft);
      border-radius: 1rem;
      background: var(--embed-surface-color);
      display: grid;
      gap: 1rem;
    }

    .project-form-note p,
    .project-settings-title,
    .project-page-section-title,
    .project-page-section-value {
      margin: 0;
    }

    .project-cover-preview-wrap {
      width: min(100%, 24rem);
      border-radius: 1rem;
      overflow: hidden;
      border: 1px solid var(--border-soft);
      margin-bottom: 0.85rem;
      background: var(--embed-surface-color);
    }

    .project-cover-preview {
      display: block;
      width: 100%;
      aspect-ratio: 16 / 9;
      object-fit: cover;
    }

    .project-page-section-list {
      display: grid;
      gap: 0.75rem;
    }

    .project-page-section-row {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: center;
      padding: 0.85rem 0.9rem;
      border: 1px solid var(--border-soft);
      border-radius: 0.9rem;
      background: var(--card-surface-color);
    }

    .project-page-section-title {
      font-weight: 700;
      color: var(--text-main);
    }

    .project-page-section-value {
      color: var(--text-muted);
      font-size: 0.94rem;
      margin-top: 0.2rem;
    }

    @media (max-width: 900px) {
      .assignment-card {
        flex-direction: column;
      }

      .assignment-actions {
        width: 100%;
        justify-content: flex-start;
      }

      .resume-preview-frame {
        min-height: 480px;
      }
    }

    @media (max-width: 800px) {
      .dynamic-form-grid {
        grid-template-columns: 1fr;
      }
    }


    .career-expand-body {
      display: grid;
      gap: 1rem;
    }

    .saved-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 2rem;
      min-height: 2rem;
      padding: 0.2rem 0.6rem;
      border-radius: 999px;
      background: var(--resolved-section-color, rgba(255,255,255,0.65));
      border: 1px solid var(--border-soft, rgba(15,23,42,0.08));
      font-weight: 700;
      font-size: 0.92rem;
      color: var(--text-main);
    }

  </style>
</BaseLayout>
