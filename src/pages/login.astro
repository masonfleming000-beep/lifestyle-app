---
import BaseLayout from "../layouts/BaseLayout.astro";

const message = Astro.url.searchParams.get("message");
---

<BaseLayout title="Login | Lifestyle App" description="Sign in to Lifestyle App">

  <!-- ================= AUTH UI ================= -->
  <section class="auth-page">
    <div class="auth-shell">

      <!-- Left Intro -->
      <div class="auth-intro">
        <p class="kicker">Lifestyle App</p>
        <h1>Build structure. Track progress.</h1>
        <p>
          Sign in to access your personal dashboard for habits, fitness,
          nutrition, goals, education, career, and hobbies.
        </p>
      </div>

      <!-- Login Card -->
      <div class="auth-card">
        <h2 class="auth-title">Welcome back</h2>
        <p class="auth-subtitle">
          Use your email and password to sign in.
        </p>

        <!-- Status Messages -->
        {message === "check-email" && (
          <p class="auth-note">Check your email to confirm your account.</p>
        )}

        {message === "confirmed" && (
          <p class="auth-note">Email confirmed. You can sign in now.</p>
        )}

        <p id="login-message" class="auth-note" style="display:none;"></p>

        <!-- Login Form -->
        <form id="login-form" class="auth-form">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required />

          <label for="password">Password</label>
          <input id="password" name="password" type="password" required />

          <button type="submit" class="auth-button">
            Sign in
          </button>
        </form>

        <p class="auth-footer">
          Don’t have an account?
          <a href="/signup">Create one</a>
        </p>

        <!-- Google Sign-In -->
        <div id="g_id_onload"
          data-client_id={import.meta.env.PUBLIC_GOOGLE_CLIENT_ID}
          data-callback="handleGoogleLogin">
        </div>

        <div class="g_id_signin"></div>

      </div>
    </div>
  </section>

  <!-- ================= GOOGLE SCRIPT ================= -->
  <script src="https://accounts.google.com/gsi/client" async defer></script>

<div
  id="g_id_onload"
  data-client_id={import.meta.env.PUBLIC_GOOGLE_CLIENT_ID}
  data-callback="handleGoogleLogin">
</div>

<div
  class="g_id_signin"
  data-type="standard"
  data-size="large"
  data-theme="outline"
  data-text="continue_with"
  data-shape="rectangular"
  data-logo_alignment="left">
</div>

<script src="https://accounts.google.com/gsi/client" async defer></script>

<script is:inline>
  window.handleGoogleLogin = async (response) => {
    const loginMessage = document.getElementById("login-message");

    const setMessage = (text, isError = false) => {
      if (!loginMessage) return;
      loginMessage.textContent = text;
      loginMessage.style.display = text ? "block" : "none";
      loginMessage.style.color = isError ? "#b42318" : "";
    };

    try {
      setMessage("");

      const res = await fetch("/api/auth/google", {
        method: "POST",
        credentials: "include",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          credential: response.credential,
        }),
      });

      const data = await res.json().catch(() => ({}));

      console.log("Google response status:", res.status);
      console.log("Google response data:", data);

      if (!res.ok || !data.user) {
        setMessage(data.error || "Google sign-in failed.", true);
        return;
      }

      setMessage("Google login successful. Redirecting...");
      window.location.href = "/today";
    } catch (err) {
      console.error("Google login error:", err);
      setMessage("Google login request failed.", true);
    }
  };
</script>

</BaseLayout>