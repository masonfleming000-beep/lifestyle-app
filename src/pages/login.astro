---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import SurfaceCard from "../components/SurfaceCard.astro";

const message = Astro.url.searchParams.get("message");
---

<BaseLayout title="Login | Lifestyle App" description="Sign in to Lifestyle App">
  <section class="auth-page">
    <div class="auth-shell">
      <PageHero
        kicker="Lifestyle App"
        title="Build structure. Track progress."
        description="Sign in to access your personal dashboard for habits, fitness, nutrition, goals, education, career, and hobbies."
      />

      <SurfaceCard className="auth-card auth-surface-card">
        <SectionHeader
          title="Welcome back"
          subtitle="Sign in with email and password or continue with Google."
          align="start"
        />

        <p id="login-message" class="auth-note" style={message ? "" : "display:none;"}>
          {message || ""}
        </p>

        <form id="login-form" class="auth-form auth-form-stack">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required />

          <label for="password">Password</label>
          <input id="password" name="password" type="password" required />

          <Button type="submit" variant="primary" className="auth-submit-button">
            Sign in
          </Button>
        </form>

        <Button href="/api/auth/google/start" variant="secondary" className="google-button auth-oauth-button">
          Continue with Google
        </Button>

        <p class="auth-footer">
          Don’t have an account?
          <a href="/signup">Create one</a>
        </p>

        <p class="auth-footer">
          <a href="/forgot-password">Forgot password?</a>
        </p>
      </SurfaceCard>
    </div>
  </section>

  <script is:inline>
    const loginForm = document.getElementById("login-form");
    const loginMessage = document.getElementById("login-message");

    function setMessage(text, isError = false) {
      if (!loginMessage) return;
      loginMessage.textContent = text;
      loginMessage.style.display = text ? "block" : "none";
      loginMessage.style.color = isError ? "#b42318" : "";
    }

    loginForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      setMessage("");

      const formData = new FormData(loginForm);
      const email = String(formData.get("email") || "").trim();
      const password = String(formData.get("password") || "");

      if (!email || !password) {
        setMessage("Email and password are required.", true);
        return;
      }

      const submitButton = loginForm.querySelector('button[type="submit"]');
      if (submitButton) submitButton.disabled = true;

      try {
        const response = await fetch("/api/auth/login", {
          method: "POST",
          credentials: "include",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ email, password }),
        });

        const data = await response.json().catch(() => ({}));

        if (!response.ok || !data.ok) {
          setMessage(data.error || "Login failed.", true);
          return;
        }

        setMessage("Login successful. Redirecting...");
        window.location.href = "/";
      } catch (error) {
        console.error("Login request failed:", error);
        setMessage("Unable to reach the server.", true);
      } finally {
        if (submitButton) submitButton.disabled = false;
      }
    });
  </script>

  <style>
    .auth-surface-card {
      display: grid;
      gap: 1rem;
    }

    .auth-form-stack {
      gap: 0.8rem;
    }

    .auth-submit-button,
    .auth-oauth-button {
      width: 100%;
      justify-content: center;
    }

    .auth-oauth-button {
      text-decoration: none;
    }
  </style>
</BaseLayout>
