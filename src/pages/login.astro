---
import BaseLayout from "../layouts/BaseLayout.astro";

const message = Astro.url.searchParams.get("message");
---

<BaseLayout title="Login | Lifestyle App" description="Sign in to Lifestyle App">

  <!-- ================= AUTH UI ================= -->
  <section class="auth-page">
    <div class="auth-shell">

      <!-- Left Intro -->
      <div class="auth-intro">
        <p class="kicker">Lifestyle App</p>
        <h1>Build structure. Track progress.</h1>
        <p>
          Sign in to access your personal dashboard for habits, fitness,
          nutrition, goals, education, career, and hobbies.
        </p>
      </div>

      <!-- Login Card -->
      <div class="auth-card">
        <h2 class="auth-title">Welcome back</h2>
        <p class="auth-subtitle">
          Use your email and password to sign in.
        </p>

        <!-- Status Messages -->
        {message === "check-email" && (
          <p class="auth-note">Check your email to confirm your account.</p>
        )}

        {message === "confirmed" && (
          <p class="auth-note">Email confirmed. You can sign in now.</p>
        )}

        <p id="login-message" class="auth-note" style="display:none;"></p>

        <!-- Login Form -->
        <form id="login-form" class="auth-form">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required />

          <label for="password">Password</label>
          <input id="password" name="password" type="password" required />

          <button type="submit" class="auth-button">
            Sign in
          </button>
        </form>

        <p class="auth-footer">
          Don’t have an account?
          <a href="/signup">Create one</a>
        </p>

        <!-- Google Sign-In -->
        <div id="g_id_onload"
          data-client_id={import.meta.env.PUBLIC_GOOGLE_CLIENT_ID}
          data-callback="handleGoogleLogin">
        </div>

        <div class="g_id_signin"></div>

      </div>
    </div>
  </section>

  <!-- ================= GOOGLE SCRIPT ================= -->
  <script src="https://accounts.google.com/gsi/client" async defer></script>

  <script>
    async function handleGoogleLogin(response) {
      try {
        const res = await fetch("/api/auth/google", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            credential: response.credential
          }),
        });

        const data = await res.json();

        if (data.user) {
          window.location.href = "/dashboard";
        } else {
          console.error("Google login failed:", data);
        }
      } catch (err) {
        console.error("Google login error:", err);
      }
    }
  </script>

  <!-- ================= EMAIL LOGIN SCRIPT ================= -->
  <script>
    const loginForm = document.getElementById("login-form");
    const loginMessage = document.getElementById("login-message");

    function setMessage(text, isError = false) {
      if (!loginMessage) return;

      loginMessage.textContent = text;
      loginMessage.style.display = text ? "block" : "none";
      loginMessage.style.color = isError ? "#b42318" : "";
    }

    loginForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      setMessage("");

      const formData = new FormData(loginForm);
      const email = String(formData.get("email") || "").trim();
      const password = String(formData.get("password") || "");

      if (!email || !password) {
        setMessage("Email and password are required.", true);
        return;
      }

      const submitButton = loginForm.querySelector(
        'button[type="submit"]'
      );

      if (submitButton) submitButton.disabled = true;

      try {
        const response = await fetch("/api/auth/login", {
          method: "POST",
          credentials: "include",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ email, password }),
        });

        const data = await response.json().catch(() => ({}));

        if (!response.ok || !data.ok) {
          setMessage(data.error || "Login failed.", true);
          return;
        }

        setMessage("Login successful. Redirecting...");
        window.location.href = "/today";

      } catch (error) {
        console.error("Login request failed:", error);
        setMessage("Unable to reach the server.", true);
      } finally {
        if (submitButton) submitButton.disabled = false;
      }
    });
  </script>

</BaseLayout>