---
/**
 * Education page.
 * Used to manage school-related work such as classes,
 * assignments, deadlines, sections, and academic tasks.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SurfaceCard from "../components/SurfaceCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import FormCard from "../components/FormCard.astro";
import Button from "../components/Button.astro";

const defaultEducationData = JSON.stringify({
  classes: [
    { id: "ece-39595", name: "ECE 39595", color: "#2f5d62" },
    { id: "ece-30200", name: "ECE 30200", color: "#7a4b2a" },
    { id: "ece-36800", name: "ECE 36800", color: "#6a3fa0" },
  ],
  assignments: [],
});
---

<BaseLayout title="Education | Lifestyle App" description="Education dashboard">
  <PageHero
    kicker="Education"
    title="Academic dashboard"
    description="Track classes, assignments, due dates, grade weight, and what needs attention first."
  />

  <section class="section">
    <div class="education-shell">
      <details class="dropdown-card surface-dropdown education-panel" open>
        <summary>
          <div>
            <h2 class="section-title">Due This Week</h2>
            <p class="section-subtitle">Closest deadlines first.</p>
          </div>
          <span class="dropdown-arrow">⌄</span>
        </summary>
        <div class="dropdown-content">
          <div id="due-this-week" class="education-list"></div>
        </div>
      </details>

      <details class="dropdown-card surface-dropdown education-panel" open>
        <summary>
          <div>
            <h2 class="section-title">All Upcoming</h2>
            <p class="section-subtitle">Sorted by due date.</p>
          </div>
          <span class="dropdown-arrow">⌄</span>
        </summary>
        <div class="dropdown-content">
          <div id="all-upcoming" class="education-list"></div>
        </div>
      </details>

      <FormCard
        title="Add Assignment"
        subtitle="Add work by class and due date."
        formId="assignment-form"
        submitLabel="Add Assignment"
      >
        <div class="edu-form-grid">
          <label class="edu-label">
            <span>Assignment name</span>
            <input type="text" id="assignment-name" required placeholder="Homework 4" />
          </label>

          <label class="edu-label">
            <span>Due date</span>
            <input type="date" id="assignment-due" required />
          </label>

          <label class="edu-label">
            <span>Class</span>
            <select id="assignment-class" required>
              <option value="">Select a class</option>
            </select>
          </label>

          <label class="edu-label">
            <span>Percent of grade (optional)</span>
            <input
              type="number"
              id="assignment-weight"
              min="0"
              max="100"
              step="0.1"
              placeholder="10"
            />
          </label>
        </div>
      </FormCard>

      <SurfaceCard className="education-panel">
        <SectionHeader
          title="Classes"
          subtitle="Create classes with color tags."
        >
          <Button id="restore-classes-btn" type="button">Restore Defaults</Button>
        </SectionHeader>

        <FormCard formId="class-form" submitLabel="Add Class" compact={true}>
          <div class="edu-form-grid class-grid">
            <label class="edu-label">
              <span>Class name</span>
              <input type="text" id="class-name" required placeholder="ECE 30200" />
            </label>

            <div class="edu-label">
              <span>Color</span>
              <input type="hidden" id="class-color" value="#2f5d62" />

              <div class="color-picker-row" id="class-color-picker">
                <button type="button" class="color-swatch is-selected" data-color="#2f5d62" style="background:#2f5d62;"></button>
                <button type="button" class="color-swatch" data-color="#111827" style="background:#111827;"></button>
                <button type="button" class="color-swatch" data-color="#6b7280" style="background:#6b7280;"></button>
                <button type="button" class="color-swatch" data-color="#2563eb" style="background:#2563eb;"></button>
                <button type="button" class="color-swatch" data-color="#38bdf8" style="background:#38bdf8;"></button>
                <button type="button" class="color-swatch" data-color="#16a34a" style="background:#16a34a;"></button>
                <button type="button" class="color-swatch" data-color="#4ade80" style="background:#4ade80;"></button>
                <button type="button" class="color-swatch" data-color="#dc2626" style="background:#dc2626;"></button>
                <button type="button" class="color-swatch" data-color="#f87171" style="background:#f87171;"></button>
                <button type="button" class="color-swatch" data-color="#ea580c" style="background:#ea580c;"></button>
                <button type="button" class="color-swatch" data-color="#fb923c" style="background:#fb923c;"></button>
                <button type="button" class="color-swatch" data-color="#fde047" style="background:#fde047;"></button>
                <button type="button" class="color-swatch" data-color="#6a3fa0" style="background:#6a3fa0;"></button>
                <button type="button" class="color-swatch" data-color="#a78bfa" style="background:#a78bfa;"></button>
                <button type="button" class="color-swatch" data-color="#db2777" style="background:#db2777;"></button>
                <button type="button" class="color-swatch" data-color="#7a4b2a" style="background:#7a4b2a;"></button>
              </div>
            </div>
          </div>
        </FormCard>

        <div id="class-list" class="class-list"></div>
      </SurfaceCard>

      <details class="card education-panel completed-panel">
        <summary class="completed-summary">
          <span>Completed</span>
          <span id="completed-count" class="completed-count">0</span>
        </summary>
        <div id="completed-list" class="education-list completed-list"></div>
      </details>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ defaultEducationData }}>
  const pageKey = "education";

  function makeId() {
    if (window.crypto && typeof window.crypto.randomUUID === "function") {
      return window.crypto.randomUUID();
    }
    return "id-" + Date.now() + "-" + Math.random().toString(16).slice(2);
  }

  function cloneDefaults() {
    return JSON.parse(defaultEducationData);
  }

  function uniqueStrings(items = []) {
    return [...new Set(items.filter(Boolean))];
  }

  function mergeDefaultClasses(savedClasses, defaultClasses, removedClassIds = []) {
    const removedSet = new Set(removedClassIds || []);
    const merged = [...(savedClasses || [])];

    defaultClasses.forEach((defaultClass) => {
      const exists = merged.some((item) => item.id === defaultClass.id);
      if (!exists && !removedSet.has(defaultClass.id)) {
        merged.push({ ...defaultClass });
      }
    });

    return merged;
  }

  function normalizeEducationData(raw) {
    const defaults = cloneDefaults();
    const parsed = raw && typeof raw === "object" ? raw : {};

    return {
      classes: Array.isArray(parsed.classes) ? parsed.classes : defaults.classes,
      assignments: Array.isArray(parsed.assignments) ? parsed.assignments : defaults.assignments,
      removedDefaults:
        parsed && typeof parsed.removedDefaults === "object" && parsed.removedDefaults
          ? parsed.removedDefaults
          : { classes: [] },
    };
  }

  async function loadState() {
    try {
      const res = await fetch(`/api/state?pageKey=${encodeURIComponent(pageKey)}`, {
        credentials: "include",
        cache: "no-store",
      });

      if (!res.ok) return null;

      const data = await res.json();
      return data?.state ?? null;
    } catch (error) {
      console.error("Failed to load education state:", error);
      return null;
    }
  }

  let isSaving = false;
  let pendingSave = false;
  let hasLoadedInitialState = false;

  async function saveState() {
    if (!hasLoadedInitialState) return;

    if (isSaving) {
      pendingSave = true;
      return;
    }

    isSaving = true;

    try {
      await fetch("/api/state", {
        method: "POST",
        credentials: "include",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          pageKey,
          state: {
            classes,
            assignments,
            removedDefaults,
          },
        }),
      });
    } catch (error) {
      console.error("Failed to save education state:", error);
    } finally {
      isSaving = false;

      if (pendingSave) {
        pendingSave = false;
        await saveState();
      }
    }
  }

  let classes = cloneDefaults().classes;
  let assignments = cloneDefaults().assignments;
  let removedDefaults = {
    classes: [],
  };

  const assignmentForm = document.getElementById("assignment-form");
  const classForm = document.getElementById("class-form");

  const assignmentNameInput = document.getElementById("assignment-name");
  const assignmentDueInput = document.getElementById("assignment-due");
  const assignmentClassSelect = document.getElementById("assignment-class");
  const assignmentWeightInput = document.getElementById("assignment-weight");

  const classNameInput = document.getElementById("class-name");
  const classColorInput = document.getElementById("class-color");
  const classColorPicker = document.getElementById("class-color-picker");
  const restoreClassesBtn = document.getElementById("restore-classes-btn");

  const classList = document.getElementById("class-list");
  const dueThisWeekEl = document.getElementById("due-this-week");
  const allUpcomingEl = document.getElementById("all-upcoming");
  const completedListEl = document.getElementById("completed-list");
  const completedCountEl = document.getElementById("completed-count");

  const defaultClassIds = new Set(cloneDefaults().classes.map((item) => item.id));

  function getClassById(classId) {
    return classes.find((c) => c.id === classId);
  }

  function markDefaultClassDeleted(classId) {
    if (!defaultClassIds.has(classId)) return;

    const arr = removedDefaults.classes || [];
    if (!arr.includes(classId)) {
      removedDefaults.classes = [...arr, classId];
    }
  }

  function startOfToday() {
    const now = new Date();
    now.setHours(0, 0, 0, 0);
    return now;
  }

  function parseDate(dateStr) {
    const date = new Date(dateStr + "T00:00:00");
    return isNaN(date.getTime()) ? null : date;
  }

  function daysUntil(dateStr) {
    const today = startOfToday();
    const due = parseDate(dateStr);
    if (!due) return null;
    return Math.ceil((due - today) / (1000 * 60 * 60 * 24));
  }

  function formatDate(dateStr) {
    const date = parseDate(dateStr);
    if (!date) return "No date";
    return date.toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
    });
  }

  function sortAssignments(items) {
    return [...items].sort((a, b) => {
      const aTime = parseDate(a.dueDate)?.getTime() ?? Number.MAX_SAFE_INTEGER;
      const bTime = parseDate(b.dueDate)?.getTime() ?? Number.MAX_SAFE_INTEGER;
      return aTime - bTime;
    });
  }

  function getUpcomingAssignments() {
    return sortAssignments(assignments.filter((a) => !a.completed));
  }

  function getCompletedAssignments() {
    return sortAssignments(assignments.filter((a) => a.completed)).reverse();
  }

  function getDueThisWeekAssignments() {
    return getUpcomingAssignments().filter((item) => {
      const diff = daysUntil(item.dueDate);
      return diff !== null && diff >= 0 && diff <= 7;
    });
  }

  function populateClassSelect() {
    assignmentClassSelect.innerHTML = '<option value="">Select a class</option>';

    classes.forEach((cls) => {
      const option = document.createElement("option");
      option.value = cls.id;
      option.textContent = cls.name;
      assignmentClassSelect.appendChild(option);
    });
  }

  function setSelectedColor(color) {
    classColorInput.value = color;

    if (!classColorPicker) return;

    classColorPicker.querySelectorAll("[data-color]").forEach((swatch) => {
      swatch.classList.remove("is-selected");
      if (swatch.getAttribute("data-color") === color) {
        swatch.classList.add("is-selected");
      }
    });
  }

  function bindColorPicker() {
    if (!classColorPicker) return;

    classColorPicker.querySelectorAll("[data-color]").forEach((button) => {
      button.addEventListener("click", () => {
        const color = button.getAttribute("data-color") || "#2f5d62";
        setSelectedColor(color);
      });
    });
  }

  function restoreDefaultClasses() {
    const defaults = cloneDefaults().classes.map((item) => ({
      id: item.id,
      name: item.name,
      color: item.color || "#2f5d62",
    }));

    removedDefaults.classes = [];

    defaults.forEach((defaultClass) => {
      const exists = classes.some((item) => item.id === defaultClass.id);
      if (!exists) {
        classes.push(defaultClass);
      }
    });
  }

  function renderClasses() {
    classList.innerHTML = "";

    if (!classes.length) {
      classList.innerHTML = '<p class="empty-state">No classes yet.</p>';
      populateClassSelect();
      return;
    }

    classes.forEach((cls) => {
      const item = document.createElement("div");
      item.className = "class-chip-row";
      item.innerHTML = `
        <div class="class-chip-display">
          <span class="class-dot" style="background:${cls.color}"></span>
          <span>${cls.name}</span>
        </div>
        <button type="button" class="delete-mini-button" data-class-id="${cls.id}">
          Remove
        </button>
      `;
      classList.appendChild(item);
    });

    populateClassSelect();

    classList.querySelectorAll("[data-class-id]").forEach((button) => {
      button.addEventListener("click", async () => {
        const classId = button.getAttribute("data-class-id");

        markDefaultClassDeleted(classId);

        classes = classes.filter((c) => c.id !== classId);
        assignments = assignments.filter((a) => a.classId !== classId);

        renderAll();
        await saveState();
      });
    });
  }

  function createAssignmentCard(item) {
    const cls = getClassById(item.classId);
    const card = document.createElement("article");
    card.className = "assignment-card";

    const dueDiff = daysUntil(item.dueDate);
    let dueText = formatDate(item.dueDate);

    if (dueDiff === 0) dueText = "Due today";
    else if (dueDiff === 1) dueText = "Due tomorrow";
    else if (dueDiff !== null && dueDiff > 1) dueText = `Due in ${dueDiff} days`;
    else if (dueDiff !== null && dueDiff < 0) dueText = `${Math.abs(dueDiff)} day(s) late`;

    card.innerHTML = `
      <label class="assignment-check-wrap">
        <input type="checkbox" class="assignment-check" ${item.completed ? "checked" : ""} />
        <span></span>
      </label>

      <div class="assignment-main">
        <div class="assignment-topline">
          <h3 class="assignment-title">${item.name}</h3>
          ${
            cls
              ? `<span class="assignment-class-tag" style="background:${cls.color}22; color:${cls.color}; border-color:${cls.color}55">${cls.name}</span>`
              : ""
          }
        </div>

        <div class="assignment-meta">
          <span>${dueText}</span>
          <span>${formatDate(item.dueDate)}</span>
          ${item.weight ? `<span>${item.weight}% of grade</span>` : ""}
        </div>
      </div>

      <button type="button" class="delete-mini-button assignment-delete">Delete</button>
    `;

    const checkbox = card.querySelector(".assignment-check");
    const deleteButton = card.querySelector(".assignment-delete");

    checkbox.addEventListener("change", async () => {
      assignments = assignments.map((a) =>
        a.id === item.id ? { ...a, completed: checkbox.checked } : a
      );
      renderAssignments();
      await saveState();
    });

    deleteButton.addEventListener("click", async () => {
      assignments = assignments.filter((a) => a.id !== item.id);
      renderAssignments();
      await saveState();
    });

    return card;
  }

  function renderAssignments() {
    const dueThisWeek = getDueThisWeekAssignments();
    const upcoming = getUpcomingAssignments();
    const completed = getCompletedAssignments();

    dueThisWeekEl.innerHTML = "";
    allUpcomingEl.innerHTML = "";
    completedListEl.innerHTML = "";

    if (!dueThisWeek.length) {
      dueThisWeekEl.innerHTML = '<p class="empty-state">Nothing due this week.</p>';
    } else {
      dueThisWeek.forEach((item) => {
        dueThisWeekEl.appendChild(createAssignmentCard(item));
      });
    }

    if (!upcoming.length) {
      allUpcomingEl.innerHTML = '<p class="empty-state">No upcoming assignments.</p>';
    } else {
      upcoming.forEach((item) => {
        allUpcomingEl.appendChild(createAssignmentCard(item));
      });
    }

    if (!completed.length) {
      completedListEl.innerHTML = '<p class="empty-state">No completed assignments yet.</p>';
    } else {
      completed.forEach((item) => {
        completedListEl.appendChild(createAssignmentCard(item));
      });
    }

    completedCountEl.textContent = String(completed.length);
  }

  function renderAll() {
    renderClasses();
    renderAssignments();
  }

  async function init() {
    bindColorPicker();
    setSelectedColor(classColorInput.value || "#2f5d62");

    renderAll();

    const saved = normalizeEducationData(await loadState());
    const defaults = cloneDefaults();

    removedDefaults = {
      classes: uniqueStrings(saved?.removedDefaults?.classes),
    };

    classes = mergeDefaultClasses(
      Array.isArray(saved.classes)
        ? saved.classes.map((item) => ({
            id: item.id,
            name: item.name,
            color: item.color || "#2f5d62",
          }))
        : [],
      defaults.classes.map((item) => ({
        id: item.id,
        name: item.name,
        color: item.color || "#2f5d62",
      })),
      removedDefaults.classes
    );

    assignments = (saved.assignments || []).map((item) => ({
      id: item.id,
      name: item.name,
      dueDate: item.dueDate,
      classId: item.classId,
      weight: item.weight ?? null,
      completed: !!item.completed,
      createdAt: item.createdAt || new Date().toISOString(),
    }));

    hasLoadedInitialState = true;
    renderAll();
  }

  assignmentForm.addEventListener("submit", async (event) => {
    event.preventDefault();

    const name = assignmentNameInput.value.trim();
    const dueDate = assignmentDueInput.value;
    const classId = assignmentClassSelect.value;
    const weight = assignmentWeightInput.value.trim();

    if (!name || !dueDate || !classId) return;

    assignments.push({
      id: makeId(),
      name,
      dueDate,
      classId,
      weight: weight ? Number(weight) : null,
      completed: false,
      createdAt: new Date().toISOString(),
    });

    assignmentForm.reset();
    renderAssignments();
    await saveState();
  });

  classForm.addEventListener("submit", async (event) => {
    event.preventDefault();

    const name = classNameInput.value.trim();
    const color = classColorInput.value || "#2f5d62";

    if (!name) return;

    classes.push({
      id: makeId(),
      name,
      color,
      createdAt: new Date().toISOString(),
    });

    classForm.reset();
    setSelectedColor("#2f5d62");
    renderClasses();
    await saveState();
  });

  restoreClassesBtn?.addEventListener("click", async () => {
    restoreDefaultClasses();
    renderClasses();
    await saveState();
  });

  init();
</script>