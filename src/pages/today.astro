---
/**
 * Daily routine page.
 * Helps the user track habits, checklists, and tasks
 * for the current day in a focused dashboard view.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import SurfaceCard from "../components/SurfaceCard.astro";

const defaultMorning = [
  "Brush teeth",
  "Wash face",
  "Stretch",
  "Journal / reflect",
  "Exercise",
  "Create to-do list",
  "Update calendar",
];

const defaultNight = [
  "Clean room",
  "Shower",
  "Floss",
  "Set bedtime",
  "Create calm environment",
  "Journal / reflect",
  "Stretch / yoga",
  "Turn off phone 30–60 mins before bed",
  "Prepare for tomorrow",
  "Read",
];

const starterTodos = [
  { text: "Review calendar", done: false },
  { text: "Complete highest-priority work", done: false },
  { text: "Exercise", done: false },
];

const defaultCalendarEmbed = "";

const defaultTodos = JSON.stringify(starterTodos);
const defaultMorningItems = JSON.stringify(defaultMorning);
const defaultNightItems = JSON.stringify(defaultNight);
const defaultCalendar = JSON.stringify(defaultCalendarEmbed);
---

<BaseLayout title="Today | Lifestyle App">
  <PageHero
    kicker="Today"
    title="Run the day with clarity."
    description="Track your calendar, priorities, and routine checklists from one focused dashboard."
  />

  <section class="section">
    <SurfaceCard className="today-surface-card">
      <SectionHeader
        title="Calendar"
        subtitle="Add a Google Calendar embed to keep the day visible at a glance."
        align="center"
      >
        <Button id="calendar-edit-btn" type="button" variant="secondary">Edit</Button>
      </SectionHeader>

      <form id="calendar-form" class="todo-form today-form today-form-hidden">
        <input
          id="calendar-input"
          type="text"
          class="todo-input text-input today-input"
          placeholder="Paste Google Calendar embed URL..."
        />
        <Button type="submit" variant="primary">Save</Button>
      </form>

      <div id="calendar-delete-wrap" class="today-action-row today-form-hidden">
        <Button id="calendar-delete-btn" type="button" variant="danger">Remove Calendar</Button>
      </div>

      <p id="calendar-instructions" class="muted today-calendar-help today-form-hidden">
        Log into Google Calendar, go to Settings → Settings for my calendars →
        select your calendar, then paste the public embed URL here.
      </p>

      <div id="calendar-container" class="calendar-embed"></div>
    </SurfaceCard>
  </section>

  <section class="section">
    <SurfaceCard className="today-surface-card">
      <SectionHeader
        title="Today"
        subtitle="Capture tasks, mark them done, or restore the starter list."
        align="center"
      >
        <Button id="todo-restore-btn" type="button" variant="secondary">Restore</Button>
        <Button id="todo-edit-btn" type="button" variant="secondary">Edit</Button>
      </SectionHeader>

      <form id="todo-form" class="todo-form today-form today-form-hidden">
        <input
          id="todo-input"
          type="text"
          class="todo-input text-input today-input"
          placeholder="Add a task..."
        />
        <Button type="submit" variant="primary">Add</Button>
      </form>

      <ul id="todo-list" class="todo-list today-list"></ul>
    </SurfaceCard>
  </section>

  <section class="section">
    <div class="grid two">
      <SurfaceCard className="today-surface-card today-checklist-card today-morning">
        <SectionHeader
          title="Morning"
          subtitle="Reset, move, and prepare before the day accelerates."
          align="center"
        >
          <Button id="morning-restore-btn" type="button" variant="secondary">Restore</Button>
          <Button id="morning-edit-btn" type="button" variant="secondary">Edit</Button>
        </SectionHeader>

        <form id="morning-form" class="todo-form today-form today-form-hidden">
          <input
            id="morning-input"
            type="text"
            class="todo-input text-input today-input"
            placeholder="Add morning routine item..."
          />
          <Button type="submit" variant="primary">Add</Button>
        </form>

        <ul id="morning-list" class="routine-list today-list"></ul>
      </SurfaceCard>

      <SurfaceCard className="today-surface-card today-checklist-card today-night">
        <SectionHeader
          title="Night"
          subtitle="Close the day well and set up tomorrow with less friction."
          align="center"
        >
          <Button id="night-restore-btn" type="button" variant="secondary">Restore</Button>
          <Button id="night-edit-btn" type="button" variant="secondary">Edit</Button>
        </SectionHeader>

        <form id="night-form" class="todo-form today-form today-form-hidden">
          <input
            id="night-input"
            type="text"
            class="todo-input text-input today-input"
            placeholder="Add night routine item..."
          />
          <Button type="submit" variant="primary">Add</Button>
        </form>

        <ul id="night-list" class="routine-list today-list"></ul>
      </SurfaceCard>
    </div>
  </section>

  <script
    define:vars={{
      defaultTodos,
      defaultMorningItems,
      defaultNightItems,
      defaultCalendar,
    }}
  >
    const pageKey = "today";

    async function loadRemotePageState(pageKey) {
      try {
        const res = await fetch(`/api/state?pageKey=${encodeURIComponent(pageKey)}`, {
          credentials: "include",
          cache: "no-store",
        });

        if (!res.ok) return null;

        const data = await res.json();
        return data?.state ?? null;
      } catch (error) {
        console.error("Failed to load state:", error);
        return null;
      }
    }

    async function saveRemotePageState(pageKey, state) {
      try {
        await fetch("/api/state", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ pageKey, state }),
        });
      } catch (error) {
        console.error("Failed to save state:", error);
      }
    }

    const todoListEl = document.getElementById("todo-list");
    const todoForm = document.getElementById("todo-form");
    const todoInput = document.getElementById("todo-input");
    const todoEditBtn = document.getElementById("todo-edit-btn");
    const todoRestoreBtn = document.getElementById("todo-restore-btn");

    const morningListEl = document.getElementById("morning-list");
    const nightListEl = document.getElementById("night-list");

    const morningForm = document.getElementById("morning-form");
    const nightForm = document.getElementById("night-form");
    const morningInput = document.getElementById("morning-input");
    const nightInput = document.getElementById("night-input");
    const morningEditBtn = document.getElementById("morning-edit-btn");
    const nightEditBtn = document.getElementById("night-edit-btn");
    const morningRestoreBtn = document.getElementById("morning-restore-btn");
    const nightRestoreBtn = document.getElementById("night-restore-btn");

    const calendarForm = document.getElementById("calendar-form");
    const calendarInput = document.getElementById("calendar-input");
    const calendarContainer = document.getElementById("calendar-container");
    const calendarInstructions = document.getElementById("calendar-instructions");
    const calendarDeleteBtn = document.getElementById("calendar-delete-btn");
    const calendarDeleteWrap = document.getElementById("calendar-delete-wrap");
    const calendarEditBtn = document.getElementById("calendar-edit-btn");

    const defaultTodoItems = JSON.parse(defaultTodos);
    const defaultMorningRoutineItems = JSON.parse(defaultMorningItems);
    const defaultNightRoutineItems = JSON.parse(defaultNightItems);
    const defaultCalendarEmbed = JSON.parse(defaultCalendar);

    const defaultTodoTexts = new Set(defaultTodoItems.map((item) => item.text));
    const defaultMorningTexts = new Set(defaultMorningRoutineItems);
    const defaultNightTexts = new Set(defaultNightRoutineItems);

    let editModes = {
      calendar: false,
      todo: false,
      morning: false,
      night: false,
    };

    let state = {
      calendarEmbed: defaultCalendarEmbed,
      todos: [...defaultTodoItems],
      morning: defaultMorningRoutineItems.map((text) => ({ text, done: false })),
      night: defaultNightRoutineItems.map((text) => ({ text, done: false })),
      removedDefaults: {
        todos: [],
        morning: [],
        night: [],
      },
    };

    let hasLoadedInitialState = false;
    let isSaving = false;
    let pendingSave = false;

    function uniqueStrings(items = []) {
      return [...new Set(items.filter(Boolean))];
    }

    function mergeDefaults(savedItems, defaultItems, keyFn, removedKeys = []) {
      const removedSet = new Set(removedKeys || []);
      const merged = [...(savedItems || [])];

      defaultItems.forEach((defaultItem) => {
        const key = keyFn(defaultItem);
        const exists = merged.some((item) => keyFn(item) === key);

        if (!exists && !removedSet.has(key)) {
          merged.push(defaultItem);
        }
      });

      return merged;
    }

    function markDefaultDeleted(section, text) {
      const arr = state.removedDefaults?.[section] || [];
      if (!arr.includes(text)) {
        state.removedDefaults[section] = [...arr, text];
      }
    }

    function unmarkDefaultDeleted(section, text) {
      const arr = state.removedDefaults?.[section] || [];
      state.removedDefaults[section] = arr.filter((item) => item !== text);
    }

    async function saveState() {
      if (!hasLoadedInitialState) return;

      if (isSaving) {
        pendingSave = true;
        return;
      }

      isSaving = true;

      try {
        await saveRemotePageState(pageKey, state);
      } finally {
        isSaving = false;

        if (pendingSave) {
          pendingSave = false;
          await saveState();
        }
      }
    }

    function setVisible(el, visible, displayValue = "flex") {
      if (!el) return;
      el.style.display = visible ? displayValue : "none";
    }

    function updateEditUI() {
      if (calendarEditBtn) {
        calendarEditBtn.textContent = editModes.calendar ? "Done" : "Edit";
      }
      if (todoEditBtn) {
        todoEditBtn.textContent = editModes.todo ? "Done" : "Edit";
      }
      if (morningEditBtn) {
        morningEditBtn.textContent = editModes.morning ? "Done" : "Edit";
      }
      if (nightEditBtn) {
        nightEditBtn.textContent = editModes.night ? "Done" : "Edit";
      }

      setVisible(calendarForm, editModes.calendar, "flex");
      setVisible(calendarDeleteWrap, editModes.calendar, "flex");
      setVisible(todoForm, editModes.todo, "flex");
      setVisible(morningForm, editModes.morning, "flex");
      setVisible(nightForm, editModes.night, "flex");
    }

    function createDeleteButton(onClick, isVisible) {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.textContent = "Delete";
      btn.className = "danger-btn today-delete-btn";
      btn.style.display = isVisible ? "inline-flex" : "none";
      btn.addEventListener("click", onClick);
      return btn;
    }

    function createCheckbox(textValue, checked, onChange) {
      const label = document.createElement("label");
      label.className = "today-item-main";

      const checkbox = document.createElement("input");
      checkbox.type = "checkbox";
      checkbox.className = "today-checkbox";
      checkbox.checked = !!checked;
      checkbox.addEventListener("change", onChange);

      const text = document.createElement("span");
      text.className = "today-item-text";
      text.textContent = textValue;

      label.appendChild(checkbox);
      label.appendChild(text);

      return label;
    }

    function renderCalendar() {
      if (!calendarContainer) return;

      calendarContainer.innerHTML = "";

      const hasEmbed = !!state.calendarEmbed?.trim();

      if (calendarInstructions) {
        calendarInstructions.style.display =
          !hasEmbed && editModes.calendar ? "block" : "none";
      }

      if (!hasEmbed) {
        const empty = document.createElement("div");
        empty.className = "today-empty-state";
        empty.textContent = "No calendar added yet. Paste a Google Calendar embed URL above.";
        calendarContainer.appendChild(empty);
        return;
      }

      const iframe = document.createElement("iframe");
      iframe.src = state.calendarEmbed;
      iframe.style.border = "0";
      iframe.loading = "lazy";
      iframe.width = "100%";
      iframe.height = "600";
      iframe.className = "today-calendar-frame";

      calendarContainer.appendChild(iframe);
    }

    function renderTodos() {
      if (!todoListEl) return;
      todoListEl.innerHTML = "";

      state.todos.forEach((todo, index) => {
        const li = document.createElement("li");
        li.className = "today-list-item" + (todo.done ? " is-done" : "");

        const row = document.createElement("div");
        row.className = "today-item-row";

        const main = createCheckbox(todo.text, todo.done, async () => {
          state.todos[index].done = !state.todos[index].done;
          renderTodos();
          await saveState();
        });

        const deleteBtn = createDeleteButton(async () => {
          const removed = state.todos[index];

          if (defaultTodoTexts.has(removed.text)) {
            markDefaultDeleted("todos", removed.text);
          }

          state.todos.splice(index, 1);
          renderTodos();
          await saveState();
        }, editModes.todo);

        row.appendChild(main);
        row.appendChild(deleteBtn);
        li.appendChild(row);
        todoListEl.appendChild(li);
      });
    }

    function renderRoutine(listEl, key) {
      if (!listEl) return;
      listEl.innerHTML = "";

      const sectionIsEditing = editModes[key];

      state[key].forEach((item, index) => {
        const li = document.createElement("li");
        li.className = "today-list-item today-routine-item" + (item.done ? " is-done" : "");

        const row = document.createElement("div");
        row.className = "today-item-row";

        const main = createCheckbox(item.text, item.done, async () => {
          state[key][index].done = !state[key][index].done;
          renderRoutine(listEl, key);
          await saveState();
        });

        const deleteBtn = createDeleteButton(async () => {
          const removed = state[key][index];

          if (key === "morning" && defaultMorningTexts.has(removed.text)) {
            markDefaultDeleted("morning", removed.text);
          }

          if (key === "night" && defaultNightTexts.has(removed.text)) {
            markDefaultDeleted("night", removed.text);
          }

          state[key].splice(index, 1);
          renderRoutine(listEl, key);
          await saveState();
        }, sectionIsEditing);

        row.appendChild(main);
        row.appendChild(deleteBtn);
        li.appendChild(row);
        listEl.appendChild(li);
      });
    }

    function restoreSection(section) {
      if (section === "todos") {
        state.removedDefaults.todos = [];
        state.todos = mergeDefaults(
          state.todos,
          defaultTodoItems,
          (item) => item.text,
          []
        ).map((item) => ({
          text: item.text,
          done: !!item.done,
        }));
        renderTodos();
        return;
      }

      if (section === "morning") {
        state.removedDefaults.morning = [];
        state.morning = mergeDefaults(
          state.morning,
          defaultMorningRoutineItems.map((text) => ({ text, done: false })),
          (item) => item.text,
          []
        ).map((item) => ({
          text: item.text,
          done: !!item.done,
        }));
        renderRoutine(morningListEl, "morning");
        return;
      }

      if (section === "night") {
        state.removedDefaults.night = [];
        state.night = mergeDefaults(
          state.night,
          defaultNightRoutineItems.map((text) => ({ text, done: false })),
          (item) => item.text,
          []
        ).map((item) => ({
          text: item.text,
          done: !!item.done,
        }));
        renderRoutine(nightListEl, "night");
      }
    }

    calendarEditBtn?.addEventListener("click", () => {
      editModes.calendar = !editModes.calendar;
      updateEditUI();
      renderCalendar();
    });

    todoEditBtn?.addEventListener("click", () => {
      editModes.todo = !editModes.todo;
      updateEditUI();
      renderTodos();
    });

    morningEditBtn?.addEventListener("click", () => {
      editModes.morning = !editModes.morning;
      updateEditUI();
      renderRoutine(morningListEl, "morning");
    });

    nightEditBtn?.addEventListener("click", () => {
      editModes.night = !editModes.night;
      updateEditUI();
      renderRoutine(nightListEl, "night");
    });

    todoRestoreBtn?.addEventListener("click", async () => {
      restoreSection("todos");
      await saveState();
    });

    morningRestoreBtn?.addEventListener("click", async () => {
      restoreSection("morning");
      await saveState();
    });

    nightRestoreBtn?.addEventListener("click", async () => {
      restoreSection("night");
      await saveState();
    });

    todoForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const value = todoInput.value.trim();
      if (!value) return;

      unmarkDefaultDeleted("todos", value);

      state.todos.unshift({ text: value, done: false });
      todoInput.value = "";
      renderTodos();
      await saveState();
    });

    morningForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const value = morningInput.value.trim();
      if (!value) return;

      unmarkDefaultDeleted("morning", value);

      state.morning.unshift({ text: value, done: false });
      morningInput.value = "";
      renderRoutine(morningListEl, "morning");
      await saveState();
    });

    nightForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const value = nightInput.value.trim();
      if (!value) return;

      unmarkDefaultDeleted("night", value);

      state.night.unshift({ text: value, done: false });
      nightInput.value = "";
      renderRoutine(nightListEl, "night");
      await saveState();
    });

    calendarForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const value = calendarInput.value.trim();
      if (!value) return;

      state.calendarEmbed = value;
      calendarInput.value = "";
      renderCalendar();
      await saveState();
    });

    calendarDeleteBtn?.addEventListener("click", async () => {
      state.calendarEmbed = "";
      renderCalendar();
      await saveState();
    });

    async function init() {
      updateEditUI();
      renderCalendar();
      renderTodos();
      renderRoutine(morningListEl, "morning");
      renderRoutine(nightListEl, "night");

      const saved = await loadRemotePageState(pageKey);

      const removedDefaults = {
        todos: uniqueStrings(saved?.removedDefaults?.todos),
        morning: uniqueStrings(saved?.removedDefaults?.morning),
        night: uniqueStrings(saved?.removedDefaults?.night),
      };

      state = {
        calendarEmbed: saved?.calendarEmbed ?? "",
        removedDefaults,
        todos: mergeDefaults(
          saved?.todos,
          defaultTodoItems,
          (item) => item.text,
          removedDefaults.todos
        ).map((item) => ({
          text: item.text,
          done: !!item.done,
        })),
        morning: mergeDefaults(
          saved?.morning,
          defaultMorningRoutineItems.map((text) => ({ text, done: false })),
          (item) => item.text,
          removedDefaults.morning
        ).map((item) => ({
          text: item.text,
          done: !!item.done,
        })),
        night: mergeDefaults(
          saved?.night,
          defaultNightRoutineItems.map((text) => ({ text, done: false })),
          (item) => item.text,
          removedDefaults.night
        ).map((item) => ({
          text: item.text,
          done: !!item.done,
        })),
      };

      hasLoadedInitialState = true;

      updateEditUI();
      renderCalendar();
      renderTodos();
      renderRoutine(morningListEl, "morning");
      renderRoutine(nightListEl, "night");
    }

    init();
  </script>

  <style>
    .today-surface-card {
      display: grid;
      gap: 1rem;
    }

    .today-form {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .today-form-hidden {
      display: none;
    }

    .today-action-row {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .today-input {
      flex: 1 1 320px;
      min-height: 48px;
    }

    .today-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 0.8rem;
    }

    .today-list-item {
      list-style: none;
      margin: 0;
      padding: 0;
      background: rgba(255, 255, 255, 0.26);
      border: 1px solid rgba(20, 30, 50, 0.08);
      border-radius: 16px;
      overflow: hidden;
    }

    .today-item-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.9rem;
      width: 100%;
      padding: 0.95rem 1rem;
    }

    .today-item-main {
      display: flex !important;
      flex-direction: row !important;
      align-items: center !important;
      justify-content: flex-start !important;
      gap: 0.9rem !important;
      flex: 1 1 auto;
      min-width: 0;
      width: 100%;
      margin: 0;
      text-align: left;
      cursor: pointer;
    }

    .today-checkbox {
      appearance: none;
      -webkit-appearance: none;
      display: inline-block !important;
      vertical-align: middle;
      width: 1.45rem !important;
      height: 1.45rem !important;
      min-width: 1.45rem !important;
      min-height: 1.45rem !important;
      margin: 0 !important;
      flex: 0 0 1.45rem !important;
      border: 2px solid rgba(20, 30, 50, 0.35);
      border-radius: 0.38rem;
      background: #fff;
      position: relative;
      cursor: pointer;
    }

    .today-checkbox:hover {
      border-color: rgba(20, 30, 50, 0.55);
    }

    .today-checkbox:checked {
      background: #111c44;
      border-color: #111c44;
    }

    .today-checkbox:checked::after {
      content: "";
      position: absolute;
      left: 0.42rem;
      top: 0.14rem;
      width: 0.33rem;
      height: 0.72rem;
      border: solid #fff;
      border-width: 0 2px 2px 0;
      transform: rotate(45deg);
    }

    .today-item-text {
      display: block;
      flex: 1 1 auto;
      min-width: 0;
      font-size: 1rem;
      line-height: 1.45;
      color: rgba(20, 30, 50, 0.88);
      word-break: break-word;
      text-align: left;
    }

    .today-list-item.is-done .today-item-text {
      text-decoration: line-through;
      opacity: 0.58;
    }

    .today-delete-btn {
      flex: 0 0 auto;
      min-height: 36px;
      padding: 0.55rem 0.8rem;
      font-size: 0.88rem;
      border-radius: 12px;
    }

    .today-empty-state {
      padding: 1rem 1.1rem;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.28);
      border: 1px dashed rgba(20, 30, 50, 0.18);
    }

    .today-calendar-help {
      margin: 0;
      line-height: 1.5;
    }

    .today-calendar-frame {
      border-radius: 18px;
      background: white;
    }

    .today-checklist-card .today-list-item {
      background: rgba(214, 153, 174, 0.22);
    }

    @media (max-width: 640px) {
      .today-item-row {
        align-items: flex-start;
      }

      .today-item-main {
        align-items: flex-start !important;
      }

      .today-delete-btn {
        align-self: center;
      }
    }
  </style>
</BaseLayout>
