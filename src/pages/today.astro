---
import BaseLayout from "../layouts/BaseLayout.astro";

const defaultMorning = [
  "Brush teeth",
  "Wash face",
  "Stretch",
  "Journal / reflect",
  "Exercise",
  "Create to-do list",
  "Update calendar",
];

const defaultNight = [
  "Clean room",
  "Shower",
  "Floss",
  "Set bedtime",
  "Create calm environment",
  "Journal / reflect",
  "Stretch / yoga",
  "Turn off phone 30–60 mins before bed",
  "Prepare for tomorrow",
  "Read",
];

const starterTodos = [
  { text: "Review calendar", done: false },
  { text: "Complete highest-priority work", done: false },
  { text: "Exercise", done: false },
];

const defaultCalendarEmbed = "";

const defaultTodos = JSON.stringify(starterTodos);
const defaultMorningItems = JSON.stringify(defaultMorning);
const defaultNightItems = JSON.stringify(defaultNight);
const defaultCalendar = JSON.stringify(defaultCalendarEmbed);
---

<BaseLayout title="Today | Lifestyle App">
  <!-- CALENDAR -->
  <section class="section">
    <article class="card">
      <div
        style="display:flex; justify-content:space-between; align-items:center; gap:1rem; flex-wrap:wrap;"
      >
        <h2 class="section-title">Calendar</h2>
        <button id="calendar-edit-btn" type="button" class="todo-add-btn">Edit</button>
      </div>

      <form
        id="calendar-form"
        class="todo-form"
        style="margin-bottom: 1rem; display: none;"
      >
        <input
          id="calendar-input"
          type="text"
          class="todo-input"
          placeholder="Paste Google Calendar embed URL..."
        />
        <button type="submit" class="todo-add-btn">Save</button>
      </form>

      <div
        id="calendar-delete-wrap"
        style="display:none; gap:.75rem; flex-wrap:wrap; margin-bottom:1rem;"
      >
        <button id="calendar-delete-btn" type="button" class="todo-add-btn">
          Remove Calendar
        </button>
      </div>

      <p
        id="calendar-instructions"
        class="muted"
        style="margin-bottom: 1rem; display: none;"
      >
        Login into Google Calendar, click Settings -> Settings for my calendar ->
        your calendar name and copy public URL code into this place.
      </p>

      <div id="calendar-container" class="calendar-embed"></div>
    </article>
  </section>

  <!-- TODO -->
  <section class="section">
    <article class="card">
      <div
        style="display:flex; justify-content:space-between; align-items:center; gap:1rem; flex-wrap:wrap;"
      >
        <h2 class="section-title">Today</h2>
        <div style="display:flex; gap:.5rem; flex-wrap:wrap;">
          <button id="todo-restore-btn" type="button" class="todo-add-btn">Restore</button>
          <button id="todo-edit-btn" type="button" class="todo-add-btn">Edit</button>
        </div>
      </div>

      <form id="todo-form" class="todo-form" style="display:none;">
        <input
          id="todo-input"
          type="text"
          class="todo-input"
          placeholder="Add a task..."
        />
        <button type="submit" class="todo-add-btn">Add</button>
      </form>

      <ul id="todo-list" class="todo-list"></ul>
    </article>
  </section>

  <!-- ROUTINES -->
  <section class="section">
    <div class="grid two">
      <article class="card today-checklist-card today-morning">
        <div
          style="display:flex; justify-content:space-between; align-items:center; gap:1rem; flex-wrap:wrap;"
        >
          <h2 class="section-title">Morning</h2>
          <div style="display:flex; gap:.5rem; flex-wrap:wrap;">
            <button id="morning-restore-btn" type="button" class="todo-add-btn">Restore</button>
            <button id="morning-edit-btn" type="button" class="todo-add-btn">Edit</button>
          </div>
        </div>

        <form
          id="morning-form"
          class="todo-form"
          style="margin-bottom: 1rem; display:none;"
        >
          <input
            id="morning-input"
            type="text"
            class="todo-input"
            placeholder="Add morning routine item..."
          />
          <button type="submit" class="todo-add-btn">Add</button>
        </form>

        <ul id="morning-list" class="routine-list"></ul>
      </article>

      <article class="card today-checklist-card today-night">
        <div
          style="display:flex; justify-content:space-between; align-items:center; gap:1rem; flex-wrap:wrap;"
        >
          <h2 class="section-title">Night</h2>
          <div style="display:flex; gap:.5rem; flex-wrap:wrap;">
            <button id="night-restore-btn" type="button" class="todo-add-btn">Restore</button>
            <button id="night-edit-btn" type="button" class="todo-add-btn">Edit</button>
          </div>
        </div>

        <form
          id="night-form"
          class="todo-form"
          style="margin-bottom: 1rem; display:none;"
        >
          <input
            id="night-input"
            type="text"
            class="todo-input"
            placeholder="Add night routine item..."
          />
          <button type="submit" class="todo-add-btn">Add</button>
        </form>

        <ul id="night-list" class="routine-list"></ul>
      </article>
    </div>
  </section>

  <script
    define:vars={{
      defaultTodos,
      defaultMorningItems,
      defaultNightItems,
      defaultCalendar,
    }}
  >
    const pageKey = "today";

    const todoListEl = document.getElementById("todo-list");
    const todoForm = document.getElementById("todo-form");
    const todoInput = document.getElementById("todo-input");
    const todoEditBtn = document.getElementById("todo-edit-btn");
    const todoRestoreBtn = document.getElementById("todo-restore-btn");

    const morningListEl = document.getElementById("morning-list");
    const nightListEl = document.getElementById("night-list");

    const morningForm = document.getElementById("morning-form");
    const nightForm = document.getElementById("night-form");
    const morningInput = document.getElementById("morning-input");
    const nightInput = document.getElementById("night-input");
    const morningEditBtn = document.getElementById("morning-edit-btn");
    const nightEditBtn = document.getElementById("night-edit-btn");
    const morningRestoreBtn = document.getElementById("morning-restore-btn");
    const nightRestoreBtn = document.getElementById("night-restore-btn");

    const calendarForm = document.getElementById("calendar-form");
    const calendarInput = document.getElementById("calendar-input");
    const calendarContainer = document.getElementById("calendar-container");
    const calendarInstructions = document.getElementById("calendar-instructions");
    const calendarDeleteBtn = document.getElementById("calendar-delete-btn");
    const calendarDeleteWrap = document.getElementById("calendar-delete-wrap");
    const calendarEditBtn = document.getElementById("calendar-edit-btn");

    const defaultTodoItems = JSON.parse(defaultTodos);
    const defaultMorningRoutineItems = JSON.parse(defaultMorningItems);
    const defaultNightRoutineItems = JSON.parse(defaultNightItems);
    const defaultCalendarEmbed = JSON.parse(defaultCalendar);

    const defaultTodoTexts = new Set(defaultTodoItems.map((item) => item.text));
    const defaultMorningTexts = new Set(defaultMorningRoutineItems);
    const defaultNightTexts = new Set(defaultNightRoutineItems);

    let editModes = {
      calendar: false,
      todo: false,
      morning: false,
      night: false,
    };

    let state = {
      calendarEmbed: defaultCalendarEmbed,
      todos: [...defaultTodoItems],
      morning: defaultMorningRoutineItems.map((text) => ({ text, done: false })),
      night: defaultNightRoutineItems.map((text) => ({ text, done: false })),
      removedDefaults: {
        todos: [],
        morning: [],
        night: [],
      },
    };

    let hasLoadedInitialState = false;
    let isSaving = false;
    let pendingSave = false;


    function uniqueStrings(items = []) {
      return [...new Set(items.filter(Boolean))];
    }

    function mergeDefaults(savedItems, defaultItems, keyFn, removedKeys = []) {
      const removedSet = new Set(removedKeys || []);
      const merged = [...(savedItems || [])];

      defaultItems.forEach((defaultItem) => {
        const key = keyFn(defaultItem);
        const exists = merged.some((item) => keyFn(item) === key);

        if (!exists && !removedSet.has(key)) {
          merged.push(defaultItem);
        }
      });

      return merged;
    }

    function markDefaultDeleted(section, text) {
      const arr = state.removedDefaults?.[section] || [];
      if (!arr.includes(text)) {
        state.removedDefaults[section] = [...arr, text];
      }
    }

    function unmarkDefaultDeleted(section, text) {
      const arr = state.removedDefaults?.[section] || [];
      state.removedDefaults[section] = arr.filter((item) => item !== text);
    }

    async function loadState() {
      try {
        const res = await fetch(`/api/state?pageKey=${encodeURIComponent(pageKey)}`, {
          credentials: "include",
          cache: "no-store",
        });

        if (!res.ok) return null;

        const data = await res.json();
        return data?.state ?? null;
      } catch (error) {
        console.error("Failed to load state:", error);
        return null;
      }
    }


    async function saveState() {
      if (!hasLoadedInitialState) return;

      if (isSaving) {
        pendingSave = true;
        return;
      }

      isSaving = true;

      try {
        await fetch("/api/state", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ pageKey, state }),
        });
      } catch (error) {
        console.error("Failed to save state:", error);
      } finally {
        isSaving = false;

        if (pendingSave) {
          pendingSave = false;
          await saveState();
        }
      }
    }

    function updateEditUI() {
      if (calendarEditBtn) {
        calendarEditBtn.textContent = editModes.calendar ? "Done" : "Edit";
      }
      if (todoEditBtn) {
        todoEditBtn.textContent = editModes.todo ? "Done" : "Edit";
      }
      if (morningEditBtn) {
        morningEditBtn.textContent = editModes.morning ? "Done" : "Edit";
      }
      if (nightEditBtn) {
        nightEditBtn.textContent = editModes.night ? "Done" : "Edit";
      }

      if (calendarForm) {
        calendarForm.style.display = editModes.calendar ? "flex" : "none";
      }
      if (calendarDeleteWrap) {
        calendarDeleteWrap.style.display = editModes.calendar ? "flex" : "none";
      }
      if (todoForm) {
        todoForm.style.display = editModes.todo ? "flex" : "none";
      }
      if (morningForm) {
        morningForm.style.display = editModes.morning ? "flex" : "none";
      }
      if (nightForm) {
        nightForm.style.display = editModes.night ? "flex" : "none";
      }
    }

    function createDeleteButton(onClick, isVisible) {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.textContent = "Delete";
      btn.className = "todo-add-btn";
      btn.style.marginLeft = "0.75rem";
      btn.style.display = isVisible ? "inline-block" : "none";
      btn.addEventListener("click", onClick);
      return btn;
    }

    function renderCalendar() {
      if (!calendarContainer) return;

      calendarContainer.innerHTML = "";

      const hasEmbed = !!state.calendarEmbed?.trim();

      if (calendarInstructions) {
        calendarInstructions.style.display =
          !hasEmbed && editModes.calendar ? "block" : "none";
      }

      if (!hasEmbed) {
        const empty = document.createElement("div");
        empty.className = "card";
        empty.style.padding = "1rem";
        empty.textContent =
          "No calendar added yet. Paste a Google Calendar embed URL above.";
        calendarContainer.appendChild(empty);
        return;
      }

      const iframe = document.createElement("iframe");
      iframe.src = state.calendarEmbed;
      iframe.style.border = "0";
      iframe.loading = "lazy";
      iframe.width = "100%";
      iframe.height = "600";

      calendarContainer.appendChild(iframe);
    }

    function renderTodos() {
      if (!todoListEl) return;
      todoListEl.innerHTML = "";

      state.todos.forEach((todo, index) => {
        const li = document.createElement("li");
        li.className = "todo-item" + (todo.done ? " is-done" : "");

        const row = document.createElement("div");
        row.style.display = "flex";
        row.style.alignItems = "center";
        row.style.justifyContent = "space-between";
        row.style.gap = "0.75rem";
        row.style.width = "100%";

        const label = document.createElement("label");
        label.className = "todo-left todo-left-custom";
        label.style.flex = "1";

        const checkWrap = document.createElement("span");
        checkWrap.className = "assignment-check-wrap today-check-wrap";

        const checkbox = document.createElement("input");
        checkbox.type = "checkbox";
        checkbox.className = "assignment-check";
        checkbox.checked = !!todo.done;

        checkbox.addEventListener("change", async () => {
          state.todos[index].done = checkbox.checked;
          renderTodos();
          await saveState();
        });

        const checkVisual = document.createElement("span");
        checkWrap.appendChild(checkbox);
        checkWrap.appendChild(checkVisual);

        const text = document.createElement("span");
        text.className = "today-check-text";
        text.textContent = todo.text;

        label.appendChild(checkWrap);
        label.appendChild(text);

        const deleteBtn = createDeleteButton(async () => {
          const removed = state.todos[index];

          if (defaultTodoTexts.has(removed.text)) {
            markDefaultDeleted("todos", removed.text);
          }

          state.todos.splice(index, 1);
          renderTodos();
          await saveState();
        }, editModes.todo);

        row.appendChild(label);
        row.appendChild(deleteBtn);
        li.appendChild(row);
        todoListEl.appendChild(li);
      });
    }

    function renderRoutine(listEl, key) {
      if (!listEl) return;
      listEl.innerHTML = "";

      const sectionIsEditing = editModes[key];

      state[key].forEach((item, index) => {
        const li = document.createElement("li");
        li.className = "routine-item" + (item.done ? " is-done" : "");

        const row = document.createElement("div");
        row.style.display = "flex";
        row.style.alignItems = "center";
        row.style.justifyContent = "space-between";
        row.style.gap = "0.75rem";
        row.style.width = "100%";

        const label = document.createElement("label");
        label.className = "routine-left todo-left-custom";
        label.style.flex = "1";

        const checkWrap = document.createElement("span");
        checkWrap.className = "assignment-check-wrap today-check-wrap";

        const cb = document.createElement("input");
        cb.type = "checkbox";
        cb.className = "assignment-check";
        cb.checked = !!item.done;

        cb.addEventListener("change", async () => {
          state[key][index].done = cb.checked;
          renderRoutine(listEl, key);
          await saveState();
        });

        const checkVisual = document.createElement("span");
        checkWrap.appendChild(cb);
        checkWrap.appendChild(checkVisual);

        const span = document.createElement("span");
        span.className = "today-check-text";
        span.textContent = item.text;

        label.appendChild(checkWrap);
        label.appendChild(span);

        const deleteBtn = createDeleteButton(async () => {
          const removed = state[key][index];

          if (key === "morning" && defaultMorningTexts.has(removed.text)) {
            markDefaultDeleted("morning", removed.text);
          }

          if (key === "night" && defaultNightTexts.has(removed.text)) {
            markDefaultDeleted("night", removed.text);
          }

          state[key].splice(index, 1);
          renderRoutine(listEl, key);
          await saveState();
        }, sectionIsEditing);

        row.appendChild(label);
        row.appendChild(deleteBtn);
        li.appendChild(row);
        listEl.appendChild(li);
      });
    }

    function restoreSection(section) {
      if (section === "todos") {
        state.removedDefaults.todos = [];
        state.todos = mergeDefaults(
          state.todos,
          defaultTodoItems,
          (item) => item.text,
          []
        ).map((item) => ({
          text: item.text,
          done: !!item.done,
        }));
        renderTodos();
        return;
      }

      if (section === "morning") {
        state.removedDefaults.morning = [];
        state.morning = mergeDefaults(
          state.morning,
          defaultMorningRoutineItems.map((text) => ({ text, done: false })),
          (item) => item.text,
          []
        ).map((item) => ({
          text: item.text,
          done: !!item.done,
        }));
        renderRoutine(morningListEl, "morning");
        return;
      }

      if (section === "night") {
        state.removedDefaults.night = [];
        state.night = mergeDefaults(
          state.night,
          defaultNightRoutineItems.map((text) => ({ text, done: false })),
          (item) => item.text,
          []
        ).map((item) => ({
          text: item.text,
          done: !!item.done,
        }));
        renderRoutine(nightListEl, "night");
      }
    }

    calendarEditBtn?.addEventListener("click", () => {
      editModes.calendar = !editModes.calendar;
      updateEditUI();
      renderCalendar();
    });

    todoEditBtn?.addEventListener("click", () => {
      editModes.todo = !editModes.todo;
      updateEditUI();
      renderTodos();
    });

    morningEditBtn?.addEventListener("click", () => {
      editModes.morning = !editModes.morning;
      updateEditUI();
      renderRoutine(morningListEl, "morning");
    });

    nightEditBtn?.addEventListener("click", () => {
      editModes.night = !editModes.night;
      updateEditUI();
      renderRoutine(nightListEl, "night");
    });

    todoRestoreBtn?.addEventListener("click", async () => {
      restoreSection("todos");
      await saveState();
    });

    morningRestoreBtn?.addEventListener("click", async () => {
      restoreSection("morning");
      await saveState();
    });

    nightRestoreBtn?.addEventListener("click", async () => {
      restoreSection("night");
      await saveState();
    });

    todoForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const value = todoInput.value.trim();
      if (!value) return;

      unmarkDefaultDeleted("todos", value);

      state.todos.unshift({ text: value, done: false });
      todoInput.value = "";
      renderTodos();
      await saveState();
    });

    morningForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const value = morningInput.value.trim();
      if (!value) return;

      unmarkDefaultDeleted("morning", value);

      state.morning.unshift({ text: value, done: false });
      morningInput.value = "";
      renderRoutine(morningListEl, "morning");
      await saveState();
    });

    nightForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const value = nightInput.value.trim();
      if (!value) return;

      unmarkDefaultDeleted("night", value);

      state.night.unshift({ text: value, done: false });
      nightInput.value = "";
      renderRoutine(nightListEl, "night");
      await saveState();
    });

    calendarForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const value = calendarInput.value.trim();
      if (!value) return;

      state.calendarEmbed = value;
      calendarInput.value = "";
      renderCalendar();
      await saveState();
    });

    calendarDeleteBtn?.addEventListener("click", async () => {
      state.calendarEmbed = "";
      renderCalendar();
      await saveState();
    });

    async function init() {
      updateEditUI();
      renderCalendar();
      renderTodos();
      renderRoutine(morningListEl, "morning");
      renderRoutine(nightListEl, "night");

      const saved = await loadState();

      const removedDefaults = {
        todos: uniqueStrings(saved?.removedDefaults?.todos),
        morning: uniqueStrings(saved?.removedDefaults?.morning),
        night: uniqueStrings(saved?.removedDefaults?.night),
      };

      state = {
        calendarEmbed: saved?.calendarEmbed ?? "",
        removedDefaults,
        todos: mergeDefaults(
          saved?.todos,
          defaultTodoItems,
          (item) => item.text,
          removedDefaults.todos
        ).map((item) => ({
          text: item.text,
          done: !!item.done,
        })),
        morning: mergeDefaults(
          saved?.morning,
          defaultMorningRoutineItems.map((text) => ({ text, done: false })),
          (item) => item.text,
          removedDefaults.morning
        ).map((item) => ({
          text: item.text,
          done: !!item.done,
        })),
        night: mergeDefaults(
          saved?.night,
          defaultNightRoutineItems.map((text) => ({ text, done: false })),
          (item) => item.text,
          removedDefaults.night
        ).map((item) => ({
          text: item.text,
          done: !!item.done,
        })),
      };

      hasLoadedInitialState = true;

      updateEditUI();
      renderCalendar();
      renderTodos();
      renderRoutine(morningListEl, "morning");
      renderRoutine(nightListEl, "night");
    }

    init();
  </script>


  <style>
    .todo-left-custom {
      align-items: center;
      gap: 0.9rem;
    }

    .today-check-wrap {
      margin-top: 0;
      flex: 0 0 auto;
    }

    .today-check-text {
      line-height: 1.45;
      font-size: 0.98rem;
    }
  </style>

</BaseLayout>