---
import BaseLayout from "../layouts/BaseLayout.astro";
import DeclarativePage from "../components/config/DeclarativePage.astro";
import {
  fitnessEditableSections,
  fitnessPageClientConfig,
  fitnessPageConfig,
} from "../config/pages/fitness";

const fitnessPageKey = fitnessPageClientConfig.pageKey;
const fitnessDefaults = JSON.stringify(fitnessPageClientConfig.defaults);
const fitnessSections = JSON.stringify(fitnessEditableSections);
---

<BaseLayout
  title={fitnessPageConfig.meta.title}
  description={fitnessPageConfig.meta.description}
>
  <DeclarativePage config={fitnessPageConfig} />

  <script define:vars={{ fitnessPageKey, fitnessDefaults, fitnessSections }}>
    import { initFitnessPage } from "../lib/client/fitnessPage";

    void initFitnessPage({
      pageKey: fitnessPageKey,
      defaults: JSON.parse(fitnessDefaults),
      sections: JSON.parse(fitnessSections),
    });
  </script>
</BaseLayout>
