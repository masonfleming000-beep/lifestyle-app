---
/**
 * Fitness dashboard page.
 * Acts as a central hub for workouts, cardio,
 * weightlifting, and other exercise-related features.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import PageHero from "../components/PageHero.astro";
import QuickLinkCard from "../components/QuickLinkCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import SurfaceCard from "../components/SurfaceCard.astro";
import { fitnessLinks, weeklySplit } from "../data/fitness";

const defaultWeeklySplit = JSON.stringify(weeklySplit);
---

<BaseLayout title="Fitness | Lifestyle App" description="Fitness landing page">
  <PageHero
    kicker="Fitness"
    title="Train for performance, discipline, and long-term health."
    description="Use this as the hub for running, weight training, and future tracked progress."
  />

  <section class="section">
    <div class="grid two">
      {fitnessLinks.map((item) => (
        <QuickLinkCard href={item.href} title={item.title} text={item.description} />
      ))}
    </div>
  </section>

  <section class="section">
    <SurfaceCard>
      <SectionHeader
        title="Weekly Training Notes"
        subtitle="Edit, add, delete, or restore your default weekly notes."
      >
        <Button id="weekly-notes-edit-btn" type="button" variant="secondary">
          Edit
        </Button>
      </SectionHeader>

      <ul id="weekly-notes-list" class="list-clean editable-list"></ul>
    </SurfaceCard>
  </section>

  <script define:vars={{ defaultWeeklySplit }}>
    const pageKey = "fitness";

    const weeklyNotesListEl = document.getElementById("weekly-notes-list");
    const weeklyNotesEditBtn = document.getElementById("weekly-notes-edit-btn");

    const defaultWeeklyNotesList = JSON.parse(defaultWeeklySplit);

    let editMode = {
      weeklyNotes: false,
    };

    let state = {
      weeklyNotes: [],
      removedDefaultWeeklyNotes: [],
      hasCustomizedWeeklyNotes: false,
    };

    let hasLoadedInitialState = false;
    let isSaving = false;
    let pendingSave = false;

    function normalizeNotesList(list) {
      if (!Array.isArray(list)) return [];
      return list
        .map((item) => (typeof item === "string" ? item.trim() : ""))
        .filter(Boolean);
    }

    function uniqueList(list) {
      return [...new Set(normalizeNotesList(list))];
    }

    function getNormalizedDefaults() {
      return normalizeNotesList(defaultWeeklyNotesList);
    }

    function buildWeeklyNotes(customNotes = [], removedDefaults = [], hasCustomized = false) {
      const normalizedDefaults = getNormalizedDefaults();
      const normalizedCustom = uniqueList(customNotes);
      const normalizedRemovedDefaults = uniqueList(removedDefaults);

      if (!hasCustomized) {
        return [...normalizedDefaults];
      }

      const keptDefaults = normalizedDefaults.filter(
        (item) => !normalizedRemovedDefaults.includes(item)
      );

      return uniqueList([...keptDefaults, ...normalizedCustom]);
    }

    function splitWeeklyNotesAgainstDefaults(notes) {
      const normalizedDefaults = getNormalizedDefaults();
      const normalizedNotes = uniqueList(notes);

      const removedDefaults = normalizedDefaults.filter(
        (defaultItem) => !normalizedNotes.includes(defaultItem)
      );

      const customNotes = normalizedNotes.filter(
        (item) => !normalizedDefaults.includes(item)
      );

      return {
        customNotes,
        removedDefaults,
      };
    }

    function normalizeSavedFitnessState(raw) {
      const defaults = getNormalizedDefaults();
      const parsed = raw && typeof raw === "object" ? raw : {};

      const savedWeeklyNotes = Array.isArray(parsed.weeklyNotes) ? parsed.weeklyNotes : null;
      const savedRemovedDefaults = Array.isArray(parsed.removedDefaultWeeklyNotes)
        ? parsed.removedDefaultWeeklyNotes
        : [];
      const savedHasCustomized = Boolean(parsed.hasCustomizedWeeklyNotes);

      if (!savedWeeklyNotes) {
        return {
          weeklyNotes: [...defaults],
          removedDefaultWeeklyNotes: [],
          hasCustomizedWeeklyNotes: false,
        };
      }

      const isNewShape =
        parsed?.hasCustomizedWeeklyNotes !== undefined ||
        Array.isArray(parsed?.removedDefaultWeeklyNotes);

      if (isNewShape) {
        const normalizedSavedNotes = uniqueList(savedWeeklyNotes);
        const customNotes = normalizedSavedNotes.filter(
          (item) => !defaults.includes(item)
        );
        const normalizedRemovedDefaults = uniqueList(savedRemovedDefaults);
        const hasCustomNotes = customNotes.length > 0;
        const hasRemovedDefaults = normalizedRemovedDefaults.length > 0;
        const hasCustomized = savedHasCustomized || hasCustomNotes || hasRemovedDefaults;

        return {
          weeklyNotes: buildWeeklyNotes(
            customNotes,
            normalizedRemovedDefaults,
            hasCustomized
          ),
          removedDefaultWeeklyNotes: normalizedRemovedDefaults,
          hasCustomizedWeeklyNotes: hasCustomized,
        };
      }

      const normalizedSaved = uniqueList(savedWeeklyNotes);
      const { customNotes, removedDefaults } =
        splitWeeklyNotesAgainstDefaults(normalizedSaved);

      return {
        weeklyNotes: buildWeeklyNotes(customNotes, removedDefaults, true),
        removedDefaultWeeklyNotes: removedDefaults,
        hasCustomizedWeeklyNotes: true,
      };
    }

    function restoreDefaultWeeklyNotes() {
      const { customNotes } = splitWeeklyNotesAgainstDefaults(state.weeklyNotes);
      const hasCustomNotes = customNotes.length > 0;

      state.weeklyNotes = buildWeeklyNotes(customNotes, [], hasCustomNotes);
      state.removedDefaultWeeklyNotes = [];
      state.hasCustomizedWeeklyNotes = hasCustomNotes;
    }

    async function loadState() {
      try {
        const res = await fetch(`/api/state?pageKey=${encodeURIComponent(pageKey)}`, {
          credentials: "include",
          cache: "no-store",
        });

        if (!res.ok) {
          console.log("[fitness] loadState res not ok:", res.status);
          return null;
        }

        const data = await res.json();
        console.log("[fitness] loaded raw api data:", data);
        return data?.state ?? null;
      } catch (error) {
        console.error("[fitness] Failed to load state:", error);
        return null;
      }
    }

    async function saveState() {
      if (!hasLoadedInitialState) {
        console.log("[fitness] save skipped: initial state not loaded yet");
        return;
      }

      if (isSaving) {
        pendingSave = true;
        console.log("[fitness] save queued while already saving");
        return;
      }

      isSaving = true;

      try {
        const payload = {
          weeklyNotes: normalizeNotesList(state.weeklyNotes),
          removedDefaultWeeklyNotes: uniqueList(state.removedDefaultWeeklyNotes),
          hasCustomizedWeeklyNotes: Boolean(state.hasCustomizedWeeklyNotes),
        };

        console.log("[fitness] saving state:", JSON.stringify(payload, null, 2));

        const res = await fetch("/api/state", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ pageKey, state: payload }),
        });

        console.log("[fitness] save response status:", res.status);
      } catch (error) {
        console.error("[fitness] Failed to save state:", error);
      } finally {
        isSaving = false;

        if (pendingSave) {
          pendingSave = false;
          await saveState();
        }
      }
    }

    function syncDerivedWeeklyNotesState() {
      const { customNotes, removedDefaults } = splitWeeklyNotesAgainstDefaults(state.weeklyNotes);
      const hasCustomNotes = customNotes.length > 0;
      const hasRemovedDefaults = removedDefaults.length > 0;
      const hasCustomized = hasCustomNotes || hasRemovedDefaults;

      state.weeklyNotes = buildWeeklyNotes(customNotes, removedDefaults, hasCustomized);
      state.removedDefaultWeeklyNotes = removedDefaults;
      state.hasCustomizedWeeklyNotes = hasCustomized;
    }

    function createDeleteButton(onClick) {
      const button = document.createElement("button");
      button.type = "button";
      button.className = "button-secondary routine-action-button";
      button.textContent = "Delete";
      button.addEventListener("click", onClick);
      return button;
    }

    function createAddButton(label, onClick) {
      const button = document.createElement("button");
      button.type = "button";
      button.className = "button-primary routine-action-button";
      button.textContent = label;
      button.addEventListener("click", onClick);
      return button;
    }

    function createRestoreButton(onClick) {
      const button = document.createElement("button");
      button.type = "button";
      button.className = "button-secondary routine-action-button";
      button.textContent = "Restore Defaults";
      button.addEventListener("click", onClick);
      return button;
    }

    function renderWeeklyNotes() {
      if (!weeklyNotesListEl) return;

      weeklyNotesListEl.innerHTML = "";
      const isEditing = editMode.weeklyNotes;

      state.weeklyNotes.forEach((itemText, itemIndex) => {
        const li = document.createElement("li");
        li.className = "routine-item";

        const row = document.createElement("div");
        row.className = "routine-row";

        const left = document.createElement("div");
        left.className = "routine-left";

        if (isEditing) {
          const input = document.createElement("input");
          input.type = "text";
          input.className = "routine-inline-input";
          input.value = itemText;

          input.addEventListener("change", async () => {
            state.weeklyNotes[itemIndex] = input.value.trim();
            syncDerivedWeeklyNotesState();
            console.log("[fitness] edited note:", itemIndex, state.weeklyNotes[itemIndex]);
            renderWeeklyNotes();
            await saveState();
          });

          left.appendChild(input);
        } else {
          const text = document.createElement("div");
          text.className = "routine-static-text";
          text.textContent = itemText;
          left.appendChild(text);
        }

        row.appendChild(left);

        if (isEditing) {
          row.appendChild(
            createDeleteButton(async () => {
              console.log("[fitness] deleting note before:", [...state.weeklyNotes]);
              state.weeklyNotes.splice(itemIndex, 1);
              syncDerivedWeeklyNotesState();
              console.log("[fitness] deleting note after:", [...state.weeklyNotes]);
              renderWeeklyNotes();
              await saveState();
            })
          );
        }

        li.appendChild(row);
        weeklyNotesListEl.appendChild(li);
      });

      if (isEditing) {
        const actionsLi = document.createElement("li");
        actionsLi.className = "routine-item";

        const row = document.createElement("div");
        row.className = "routine-row routine-row-actions";

        const left = document.createElement("div");
        left.className = "routine-left";
        row.appendChild(left);

        const actions = document.createElement("div");
        actions.className = "routine-actions-group";

        actions.appendChild(
          createAddButton("Add", async () => {
            state.weeklyNotes.push("");
            state.hasCustomizedWeeklyNotes = true;
            console.log("[fitness] added blank note:", [...state.weeklyNotes]);
            renderWeeklyNotes();

            const inputs = weeklyNotesListEl.querySelectorAll("input");
            const lastInput = inputs[inputs.length - 1];
            if (lastInput) lastInput.focus();

            await saveState();
          })
        );

        actions.appendChild(
          createRestoreButton(async () => {
            restoreDefaultWeeklyNotes();
            console.log("[fitness] restored defaults while keeping customs:", [
              ...state.weeklyNotes,
            ]);
            renderWeeklyNotes();
            await saveState();
          })
        );

        row.appendChild(actions);
        actionsLi.appendChild(row);
        weeklyNotesListEl.appendChild(actionsLi);
      }
    }

    function renderAll() {
      renderWeeklyNotes();

      if (weeklyNotesEditBtn) {
        weeklyNotesEditBtn.textContent = editMode.weeklyNotes ? "Done" : "Edit";
      }

      console.log("[fitness] renderAll state:", JSON.stringify(state, null, 2));
    }

    function bindEditButtons() {
      if (weeklyNotesEditBtn) {
        weeklyNotesEditBtn.addEventListener("click", () => {
          editMode.weeklyNotes = !editMode.weeklyNotes;
          console.log("[fitness] toggled edit mode:", editMode.weeklyNotes);
          renderAll();
        });
      }
    }

    async function init() {
      renderAll();

      const saved = await loadState();
      console.log("[fitness] saved state from api:", saved);
      console.log("[fitness] defaults from file:", defaultWeeklyNotesList);

      state = normalizeSavedFitnessState(saved);

      console.log("[fitness] initialized final state:", state);

      hasLoadedInitialState = true;
      renderAll();
      bindEditButtons();
    }

    init();
  </script>

  <style>
    .editable-list {
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
      padding: 0;
      margin: 1rem 0 0 0;
      list-style: none;
    }

    .routine-item {
      margin-bottom: 0;
    }

    .routine-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      width: 100%;
    }

    .routine-row-actions {
      margin-top: 0.5rem;
    }

    .routine-left {
      flex: 1;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      min-width: 0;
    }

    .routine-inline-input,
    .routine-static-text {
      width: 100%;
      border: 1px solid var(--border-color, #d9d9d9);
      border-radius: 12px;
      padding: 0.8rem 0.95rem;
      background: var(--card-background, #fff);
      color: inherit;
      font: inherit;
      line-height: 1.45;
      box-sizing: border-box;
    }

    .routine-inline-input {
      min-height: 48px;
    }

    .routine-static-text {
      min-height: 48px;
      display: flex;
      align-items: center;
    }

    .routine-actions-group {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .routine-action-button {
      white-space: nowrap;
    }
  </style>
</BaseLayout>
