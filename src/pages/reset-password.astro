---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import FormCard from "../components/FormCard.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import SurfaceCard from "../components/SurfaceCard.astro";

const token = Astro.url.searchParams.get("token") || "";
---

<BaseLayout title="Reset Password | Lifestyle App" description="Choose a new password">
  <section class="auth-page">
    <div class="auth-shell">
      <PageHero
        kicker="Lifestyle App"
        title="Choose a new password."
        description="Enter a strong new password for your account to finish the reset process."
      />

      <SurfaceCard className="auth-card auth-surface-card">
        <SectionHeader
          title="Reset password"
          subtitle="Set a new password with at least 12 characters, then return to sign in."
          align="start"
        />

        <p id="reset-message" class="auth-note" style="display:none;"></p>

        <FormCard
          formId="reset-form"
          compact={true}
          className="auth-form-card"
          formClass="auth-form auth-form-stack"
        >
          <input type="hidden" name="token" value={token} />

          <label for="password">New password</label>
          <input id="password" name="password" type="password" minlength="12" required />

          <Fragment slot="actions">
            <Button type="submit" variant="primary" className="auth-submit-button">
              Reset password
            </Button>
          </Fragment>
        </FormCard>

        <p class="auth-footer">
          <a href="/login">Back to login</a>
        </p>
      </SurfaceCard>
    </div>
  </section>

  <script is:inline>
    const resetForm = document.getElementById("reset-form");
    const resetMessage = document.getElementById("reset-message");

    function setMessage(text, isError = false) {
      if (!resetMessage) return;
      resetMessage.textContent = text;
      resetMessage.style.display = text ? "block" : "none";
      resetMessage.style.color = isError ? "#b42318" : "";
    }

    resetForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      setMessage("");

      const formData = new FormData(resetForm);
      const token = String(formData.get("token") || "");
      const password = String(formData.get("password") || "");

      const submitButton = resetForm.querySelector('button[type="submit"]');
      if (submitButton) submitButton.disabled = true;

      try {
        const response = await fetch("/api/auth/reset-password", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ token, password }),
        });

        const data = await response.json().catch(() => ({}));

        if (!response.ok || !data.ok) {
          setMessage(data.error || "Reset failed.", true);
          return;
        }

        setMessage(data.message || "Password reset successful. You can now sign in.");
      } catch (error) {
        console.error("Reset password request failed:", error);
        setMessage("Unable to reach the server.", true);
      } finally {
        if (submitButton) submitButton.disabled = false;
      }
    });
  </script>

  <style>
    .auth-surface-card {
      display: grid;
      gap: 1rem;
    }

    .auth-form-card {
      padding: 0;
      background: transparent;
      border: 0;
      box-shadow: none;
    }

    .auth-form-stack {
      gap: 0.8rem;
    }

    .auth-submit-button {
      width: 100%;
      justify-content: center;
    }
  </style>
</BaseLayout>
