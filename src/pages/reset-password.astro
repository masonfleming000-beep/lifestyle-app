---
import BaseLayout from "../layouts/BaseLayout.astro";
import AuthPage from "../components/auth/AuthPage.astro";
import { resetPasswordClientConfig, resetPasswordPageConfig } from "../config/pages/auth";

const token = Astro.url.searchParams.get("token") || "";
const pageConfig = resetPasswordPageConfig(token);
---

<BaseLayout title={pageConfig.title} description={pageConfig.description}>
  <AuthPage config={pageConfig} />

  <script id="reset-password-page-config" type="application/json" set:html={JSON.stringify(resetPasswordClientConfig)} />

  <script>
    import { initAuthFormPage } from "../lib/client/authForms";

    const configElement = document.getElementById("reset-password-page-config");
    const config = JSON.parse(configElement?.textContent || "{}");

    initAuthFormPage(config);
  </script>
</BaseLayout>
