---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import ProfileLoadingState from "../../components/primitives/ProfileLoadingState.astro";
import { createPublicProfileClientConfig } from "../../config/pages/publicProfile";

const username = Astro.params.username ?? "";
const publicProfileClientConfig = createPublicProfileClientConfig(username);
---

<BaseLayout title={`${username} | Public Profile`} description="Public profile page">
  <div id="public-profile-page" data-username={username}>
    <PageHero
      kicker="Public Profile"
      title="Profile"
      description="A clean public view of work, highlights, achievements, and recent activity."
    />

    <section class="section">
      <div id="public-profile-root" class="grid one">
        <ProfileLoadingState
          title="Loading profile"
          subtitle="Fetching public profile data and public activity."
          message="Loading public profile..."
        />
      </div>
    </section>
  </div>

    <script id="public-profile-config" type="application/json" set:html={JSON.stringify(publicProfileClientConfig)} />

  <script>
    import { initPublicProfilePage } from "../../lib/client/publicProfilePage";

    const configElement = document.getElementById("public-profile-config");
    const config = JSON.parse(configElement?.textContent || "{}");

    initPublicProfilePage(config);
  </script>

  <style>
    .public-profile-shell {
      overflow: hidden;
      border-radius: 28px;
      background: rgba(255, 255, 255, 0.84);
      border: 1px solid rgba(15, 23, 42, 0.08);
      box-shadow: 0 14px 40px rgba(15, 23, 42, 0.08);
    }

    .profile-banner {
      min-height: 220px;
      background: linear-gradient(135deg, #cfdef3 0%, #e0f2fe 50%, #f8fafc 100%);
      background-size: cover;
      background-position: center;
    }

    .profile-identity-body {
      display: flex;
      gap: 1.25rem;
      padding: 1.5rem;
      margin-top: -58px;
      align-items: flex-end;
      flex-wrap: wrap;
    }

    .profile-avatar-wrap {
      display: flex;
      flex: 0 0 auto;
    }

    .profile-avatar-wrap.left {
      justify-content: flex-start;
    }

    .profile-avatar-wrap.center {
      justify-content: center;
    }

    .profile-avatar-wrap.right {
      justify-content: flex-end;
    }

    .profile-avatar-frame {
      overflow: hidden;
      border: 4px solid #fff;
      box-shadow: 0 8px 28px rgba(15, 23, 42, 0.14);
      background: #dbeafe;
      position: relative;
      flex: 0 0 auto;
    }

    .profile-avatar-frame.circle {
      border-radius: 50%;
    }

    .profile-avatar-frame.square {
      border-radius: 20px;
    }

    .profile-avatar-image,
    .profile-avatar-fallback {
      position: absolute;
      inset: 0;
    }

    .profile-avatar-image {
      background-repeat: no-repeat;
    }

    .profile-avatar-fallback {
      display: grid;
      place-items: center;
      font-size: 2rem;
      font-weight: 800;
      color: #0f172a;
    }

    .profile-identity-copy {
      flex: 1;
      min-width: 260px;
    }

    .profile-name-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .profile-name-row h2,
    .profile-headline,
    .profile-bio {
      margin: 0;
    }

    .profile-handle {
      display: inline-flex;
      align-items: center;
      padding: 0.4rem 0.7rem;
      border-radius: 999px;
      background: rgba(255,255,255,0.82);
      border: 1px solid rgba(15, 23, 42, 0.08);
      font-size: 0.92rem;
      color: #475569;
    }

    .profile-headline {
      margin-top: 0.35rem;
      font-size: 1.05rem;
      color: #243447;
    }

    .profile-bio {
      margin-top: 0.75rem;
      color: #4f6275;
      max-width: 70ch;
      line-height: 1.6;
    }

    .profile-stat-card,
    .chart-card,
    .summary-card {
      border-radius: 20px;
      padding: 1rem 1.1rem;
      background: rgba(255,255,255,0.76);
      border: 1px solid rgba(15, 23, 42, 0.08);
    }

    .chart-card {
      color: #2f5d62;
    }

    .chart-header,
    .control-grid {
      display: grid;
      gap: 1rem;
    }

    .control-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-bottom: 1rem;
    }

    .field-group {
      display: grid;
      gap: 0.45rem;
    }

    .field-label {
      font-size: 0.92rem;
      font-weight: 700;
      color: #334155;
    }

    .ui-select {
      width: 100%;
      border-radius: 14px;
      border: 1px solid rgba(15, 23, 42, 0.1);
      background: rgba(255, 255, 255, 0.9);
      padding: 0.85rem 1rem;
      font: inherit;
      color: #0f172a;
    }

    .sparkline {
      width: 100%;
      height: 120px;
      display: block;
      margin-top: 0.5rem;
    }

    .chart-axis-row {
      display: flex;
      justify-content: space-between;
      font-size: 0.8rem;
      color: #64748b;
      margin-top: 0.35rem;
    }

    .badge-row,
    .activity-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .profile-badge {
      border: 1px solid rgba(15, 23, 42, 0.08);
      background: rgba(255,255,255,0.82);
      border-radius: 999px;
      padding: 0.65rem 0.95rem;
      white-space: nowrap;
    }

    .portfolio-link-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      padding: 0.8rem 1.1rem;
      background: #2f5d62;
      color: white;
      text-decoration: none;
      font-weight: 700;
    }

    .empty-profile-card {
      text-align: center;
      padding: 2rem;
    }

    .top-gap-sm {
      margin-top: 0.65rem;
    }

    @media (max-width: 900px) {
      .control-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 720px) {
      .profile-identity-body {
        margin-top: -40px;
        padding: 1rem;
      }

      .profile-banner {
        min-height: 170px;
      }

      .profile-avatar-fallback {
        font-size: 1.6rem;
      }
    }
  </style>
</BaseLayout>