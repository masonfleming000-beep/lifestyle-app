---
import BaseLayout from "../layouts/BaseLayout.astro";
import AuthPage from "../components/auth/AuthPage.astro";
import { signupClientConfig, signupPageConfig } from "../config/pages/auth";
---

<BaseLayout title={signupPageConfig.title} description={signupPageConfig.description}>
  <AuthPage config={signupPageConfig} />

  <script id="signup-page-config" type="application/json" set:html={JSON.stringify(signupClientConfig)} />

  <script>
    import { initAuthFormPage } from "../lib/client/authForms";

    const configElement = document.getElementById("signup-page-config");
    const config = JSON.parse(configElement?.textContent || "{}");

    initAuthFormPage(config);
  </script>
</BaseLayout>
