---
/**
 * Mind and wellness page.
 * Focused on mental health, mindfulness, calming routines,
 * yoga, reflection, or other mental wellness tools.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { yogaItems, soothingTechniques } from "../data/mind";

const defaultMindData = JSON.stringify({
  defaultYogaItems: yogaItems.map((item, index) => ({
    ...item,
    id: `default-yoga-${index}`,
    isDefault: true,
  })),
  defaultSoothingTechniques: soothingTechniques.map((item, index) => ({
    ...item,
    id: `default-technique-${index}`,
    isDefault: true,
  })),
  customYogaItems: [],
  customTechniques: [],
  hiddenDefaultYogaIds: [],
  hiddenDefaultTechniqueIds: [],
});
---

<BaseLayout title="Mind | Lifestyle App" description="Mind and recovery page">
    <PageHero
    kicker="Mind"
    title="Recover, reset, and calm the system."
    description="A cleaner version of your old mind page with yoga / rehab and soothing   techniques organized into dropdown sections."
  />

  <section class="section">
    <article class="card soft">
      <div class="section-header">
        <div>
          <h2 class="section-title">Yoga / Rehabilitation</h2>
          <p class="section-subtitle">
            Expand each movement for details and video.
          </p>
        </div>
      </div>

      <form id="yoga-form" class="mind-form">
        <h3 class="card-title">Add Exercise</h3>

        <div class="mind-form-grid">
          <label>
            <span>Title</span>
            <input type="text" name="title" placeholder="Ex: Hip Flexor Stretch" required />
          </label>

          <label>
            <span>Video URL</span>
            <input
              type="text"
              name="video"
              placeholder="Paste YouTube link or embed code (optional)"
            />
          </label>

          <label>
            <span>Weight</span>
            <input type="text" name="weight" placeholder="Ex: 30" />
          </label>

          <label>
            <span>Sets</span>
            <input type="text" name="sets" placeholder="Ex: 3-4" required />
          </label>

          <label>
            <span>Reps</span>
            <input type="text" name="reps" placeholder="Ex: 8-12" required />
          </label>

          <label>
            <span>Weeks</span>
            <input type="text" name="weeks" placeholder="Ex: 4" required />
          </label>
        </div>

        <div class="mind-form-actions">
          <button type="submit" class="action-btn">Add Exercise</button>
          <button type="button" id="restore-yoga-defaults" class="secondary-btn">
            Restore Default Exercises
          </button>
        </div>
      </form>

      <div id="yoga-list" class="grid two"></div>
    </article>
  </section>

  <section class="section">
    <article class="card">
      <div class="section-header">
        <div>
          <h2 class="section-title">Soothing Techniques</h2>
          <p class="section-subtitle">
            Expand a technique when you need a reset.
          </p>
        </div>
      </div>

      <form id="technique-form" class="mind-form">
        <h3 class="card-title">Add Technique</h3>

        <div class="mind-form-grid">
          <label>
            <span>Title</span>
            <input type="text" name="title" placeholder="Ex: Box Breathing" required />
          </label>

          <label class="full-width">
            <span>Points</span>
            <textarea
              name="points"
              rows="5"
              placeholder="One point per line"
              required
            ></textarea>
          </label>
        </div>

        <div class="mind-form-actions">
          <button type="submit" class="action-btn">Add Technique</button>
          <button type="button" id="restore-technique-defaults" class="secondary-btn">
            Restore Default Techniques
          </button>
        </div>
      </form>

      <div id="technique-list" class="mind-stack"></div>
    </article>
  </section>

  <script define:vars={{ defaultMindData }}>
    const pageKey = "mind";

    function cloneDefaults() {
      return JSON.parse(defaultMindData);
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function parseYouTubeTimeToSeconds(value) {
      if (!value) return 0;

      if (/^\d+$/.test(value)) return Number(value);

      const match = value.match(/(?:(\d+)h)?(?:(\d+)m)?(?:(\d+)s)?/i);
      if (!match) return 0;

      const hours = Number(match[1] || 0);
      const minutes = Number(match[2] || 0);
      const seconds = Number(match[3] || 0);

      return hours * 3600 + minutes * 60 + seconds;
    }

    function normalizeYouTubeEmbed(input) {
      if (!input) return "";

      const raw = String(input).trim();
      let candidate = raw;

      if (raw.includes("<iframe")) {
        const srcMatch = raw.match(/src=["']([^"']+)["']/i);
        candidate = srcMatch?.[1]?.trim() || "";
      }

      if (!candidate) return "";

      let url;
      try {
        url = new URL(candidate);
      } catch {
        return "";
      }

      const host = url.hostname.replace(/^www\./, "");
      let videoId = "";
      let startSeconds = 0;

      if (host === "youtube.com" || host === "m.youtube.com") {
        if (url.pathname === "/watch") {
          videoId = url.searchParams.get("v") || "";
          startSeconds = parseYouTubeTimeToSeconds(url.searchParams.get("t") || "");
        } else if (url.pathname.startsWith("/embed/")) {
          videoId = url.pathname.split("/embed/")[1]?.split("/")[0] || "";
          startSeconds = parseYouTubeTimeToSeconds(url.searchParams.get("start") || "");
        } else if (url.pathname.startsWith("/shorts/")) {
          videoId = url.pathname.split("/shorts/")[1]?.split("/")[0] || "";
        } else if (url.pathname.startsWith("/live/")) {
          videoId = url.pathname.split("/live/")[1]?.split("/")[0] || "";
        }
      } else if (host === "youtu.be") {
        videoId = url.pathname.replace(/^\/+/, "").split("/")[0] || "";
        startSeconds = parseYouTubeTimeToSeconds(url.searchParams.get("t") || "");
      }

      if (!videoId) return "";

      const embedUrl = new URL(`https://www.youtube.com/embed/${videoId}`);
      if (startSeconds > 0) {
        embedUrl.searchParams.set("start", String(startSeconds));
      }

      return embedUrl.toString();
    }

    function normalizeYogaItem(item) {
      return {
        id: item?.id || `yoga-${Date.now()}-${Math.random().toString(16).slice(2)}`,
        title: item?.title || "Untitled Exercise",
        video: normalizeYouTubeEmbed(item?.video || ""),
        stats: {
          weight: item?.stats?.weight || "",
          sets: item?.stats?.sets || "",
          reps: item?.stats?.reps || "",
          weeks: item?.stats?.weeks || "",
        },
        isDefault: !!item?.isDefault,
      };
    }

    function normalizeTechnique(item) {
      return {
        id: item?.id || `technique-${Date.now()}-${Math.random().toString(16).slice(2)}`,
        title: item?.title || "Untitled Technique",
        points: Array.isArray(item?.points) ? item.points.map((p) => String(p || "")) : [],
        isDefault: !!item?.isDefault,
      };
    }

    function normalizeData(raw) {
      const defaults = cloneDefaults();
      const parsed = raw && typeof raw === "object" ? raw : {};

      return {
        defaultYogaItems: Array.isArray(parsed.defaultYogaItems)
          ? parsed.defaultYogaItems.map(normalizeYogaItem)
          : defaults.defaultYogaItems.map(normalizeYogaItem),
        defaultSoothingTechniques: Array.isArray(parsed.defaultSoothingTechniques)
          ? parsed.defaultSoothingTechniques.map(normalizeTechnique)
          : defaults.defaultSoothingTechniques.map(normalizeTechnique),
        customYogaItems: Array.isArray(parsed.customYogaItems)
          ? parsed.customYogaItems.map(normalizeYogaItem).map((item) => ({ ...item, isDefault: false }))
          : [],
        customTechniques: Array.isArray(parsed.customTechniques)
          ? parsed.customTechniques.map(normalizeTechnique).map((item) => ({ ...item, isDefault: false }))
          : [],
        hiddenDefaultYogaIds: Array.isArray(parsed.hiddenDefaultYogaIds) ? parsed.hiddenDefaultYogaIds : [],
        hiddenDefaultTechniqueIds: Array.isArray(parsed.hiddenDefaultTechniqueIds)
          ? parsed.hiddenDefaultTechniqueIds
          : [],
      };
    }

    async function loadState() {
      try {
        const res = await fetch(`/api/state?pageKey=${encodeURIComponent(pageKey)}`, {
          credentials: "include",
          cache: "no-store",
        });

        if (!res.ok) return null;

        const data = await res.json();
        return data?.state ?? null;
      } catch (error) {
        console.error("Failed to load mind state:", error);
        return null;
      }
    }

    let isSaving = false;
    let pendingSave = false;
    let hasLoadedInitialState = false;

    async function saveState() {
      if (!hasLoadedInitialState) return;

      if (isSaving) {
        pendingSave = true;
        return;
      }

      isSaving = true;

      try {
        await fetch("/api/state", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            pageKey,
            state: {
              defaultYogaItems,
              defaultSoothingTechniques,
              customYogaItems,
              customTechniques,
              hiddenDefaultYogaIds,
              hiddenDefaultTechniqueIds,
            },
          }),
        });
      } catch (error) {
        console.error("Failed to save mind state:", error);
      } finally {
        isSaving = false;

        if (pendingSave) {
          pendingSave = false;
          await saveState();
        }
      }
    }

    let defaultYogaItems = cloneDefaults().defaultYogaItems.map(normalizeYogaItem);
    let defaultSoothingTechniques = cloneDefaults().defaultSoothingTechniques.map(normalizeTechnique);
    let customYogaItems = [];
    let customTechniques = [];
    let hiddenDefaultYogaIds = [];
    let hiddenDefaultTechniqueIds = [];

    function getVisibleYogaItems() {
      return [
        ...defaultYogaItems.filter((item) => !hiddenDefaultYogaIds.includes(item.id)),
        ...customYogaItems.map((item) => ({ ...item, isDefault: false })),
      ];
    }

    function getVisibleTechniques() {
      return [
        ...defaultSoothingTechniques.filter((item) => !hiddenDefaultTechniqueIds.includes(item.id)),
        ...customTechniques.map((item) => ({ ...item, isDefault: false })),
      ];
    }

    function renderYogaItems() {
      const yogaList = document.getElementById("yoga-list");
      if (!yogaList) return;

      const allYogaItems = getVisibleYogaItems();

      yogaList.innerHTML = allYogaItems
        .map((item) => {
          const safeVideo = normalizeYouTubeEmbed(item.video || "");

          return `
            <details class="mind-dropdown">
              <summary class="mind-summary">
                <div>
                  <h3 class="card-title">${escapeHtml(item.title)}</h3>
                  <p class="meta">
                    ${item.isDefault ? "Default exercise" : "Custom exercise"}
                  </p>
                </div>
                <span class="mind-summary-icon">+</span>
              </summary>

              <div class="mind-dropdown-body">
                <div class="metric-grid yoga-metrics">
                  <article class="metric">
                    <p class="metric-label">Weight</p>
                    <p class="big-number">${escapeHtml(item.stats?.weight || "--")}</p>
                  </article>
                  <article class="metric">
                    <p class="metric-label">Sets</p>
                    <p class="big-number">${escapeHtml(item.stats?.sets || "--")}</p>
                  </article>
                  <article class="metric">
                    <p class="metric-label">Reps</p>
                    <p class="big-number">${escapeHtml(item.stats?.reps || "--")}</p>
                  </article>
                  <article class="metric">
                    <p class="metric-label">Weeks</p>
                    <p class="big-number">${escapeHtml(item.stats?.weeks || "--")}</p>
                  </article>
                </div>

                ${
                  safeVideo
                    ? `
                  <div class="video-wrap">
                    <iframe
                      src="${safeVideo}"
                      title="${escapeHtml(item.title)}"
                      frameborder="0"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                      referrerpolicy="strict-origin-when-cross-origin"
                      allowfullscreen
                      loading="lazy"
                    ></iframe>
                  </div>
                `
                    : ""
                }

                <div class="mind-item-actions">
                  <button
                    type="button"
                    class="delete-btn"
                    data-delete-yoga-id="${escapeHtml(item.id)}"
                    data-yoga-default="${item.isDefault ? "true" : "false"}"
                  >
                    Delete Exercise
                  </button>
                </div>
              </div>
            </details>
          `;
        })
        .join("");
    }

    function renderTechniques() {
      const techniqueList = document.getElementById("technique-list");
      const allTechniques = getVisibleTechniques();

      techniqueList.innerHTML = allTechniques
        .map(
          (item) => `
            <details class="mind-dropdown soothing-dropdown">
              <summary class="mind-summary">
                <div>
                  <h3 class="card-title">${escapeHtml(item.title)}</h3>
                  <p class="meta">
                    ${item.isDefault ? "Default technique" : "Custom technique"}
                  </p>
                </div>
                <span class="mind-summary-icon">+</span>
              </summary>

              <div class="mind-dropdown-body">
                <ul class="list-clean">
                  ${item.points.map((point) => `<li>${escapeHtml(point)}</li>`).join("")}
                </ul>

                <div class="mind-item-actions">
                  <button
                    type="button"
                    class="delete-btn"
                    data-delete-technique-id="${escapeHtml(item.id)}"
                    data-technique-default="${item.isDefault ? "true" : "false"}"
                  >
                    Delete Technique
                  </button>
                </div>
              </div>
            </details>
          `
        )
        .join("");
    }

    function setupYogaForm() {
      const form = document.getElementById("yoga-form");
      if (!(form instanceof HTMLFormElement)) return;

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        try {
          const formData = new FormData(form);

          const title = String(formData.get("title") || "").trim();
          const rawVideo = String(formData.get("video") || "").trim();
          const weight = String(formData.get("weight") || "").trim();
          const sets = String(formData.get("sets") || "").trim();
          const reps = String(formData.get("reps") || "").trim();
          const weeks = String(formData.get("weeks") || "").trim();

          if (!title) {
            window.alert("Please enter an exercise title.");
            return;
          }

          if (!sets || !reps || !weeks) {
            window.alert("Please fill out sets, reps, and weeks.");
            return;
          }

          const newItem = normalizeYogaItem({
            id:
              typeof crypto !== "undefined" && crypto.randomUUID
                ? crypto.randomUUID()
                : `yoga-${Date.now()}-${Math.random().toString(16).slice(2)}`,
            title,
            video: rawVideo,
            stats: {
              weight,
              sets,
              reps,
              weeks,
            },
            isDefault: false,
          });

          customYogaItems = [...customYogaItems, { ...newItem, isDefault: false }];

          form.reset();
          renderYogaItems();
          await saveState();
        } catch (error) {
          console.error("Failed to add yoga exercise:", error);
          window.alert("Could not add exercise. Check console for the exact error.");
        }
      });
    }

    function setupTechniqueForm() {
      const form = document.getElementById("technique-form");

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        const formData = new FormData(form);
        const rawPoints = String(formData.get("points") || "").trim();

        const newItem = normalizeTechnique({
          id:
            typeof crypto !== "undefined" && crypto.randomUUID
              ? crypto.randomUUID()
              : `technique-${Date.now()}-${Math.random().toString(16).slice(2)}`,
          title: String(formData.get("title") || "").trim(),
          points: rawPoints
            .split("\n")
            .map((point) => point.trim())
            .filter(Boolean),
          isDefault: false,
        });

        customTechniques.push({ ...newItem, isDefault: false });
        form.reset();
        renderTechniques();
        await saveState();
      });
    }

    function setupDeleteHandlers() {
      document.addEventListener("click", async (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;

        const yogaId = target.getAttribute("data-delete-yoga-id");
        if (yogaId) {
          event.preventDefault();
          event.stopPropagation();

          const isDefault = target.getAttribute("data-yoga-default") === "true";

          if (isDefault) {
            if (!hiddenDefaultYogaIds.includes(yogaId)) {
              hiddenDefaultYogaIds = [...hiddenDefaultYogaIds, yogaId];
            }
          } else {
            customYogaItems = customYogaItems.filter((item) => item.id !== yogaId);
          }

          renderYogaItems();
          await saveState();
          return;
        }

        const techniqueId = target.getAttribute("data-delete-technique-id");
        if (techniqueId) {
          event.preventDefault();
          event.stopPropagation();

          const isDefault = target.getAttribute("data-technique-default") === "true";

          if (isDefault) {
            if (!hiddenDefaultTechniqueIds.includes(techniqueId)) {
              hiddenDefaultTechniqueIds = [...hiddenDefaultTechniqueIds, techniqueId];
            }
          } else {
            customTechniques = customTechniques.filter((item) => item.id !== techniqueId);
          }

          renderTechniques();
          await saveState();
        }
      });
    }

    function setupRestoreButtons() {
      const restoreYogaBtn = document.getElementById("restore-yoga-defaults");
      const restoreTechniqueBtn = document.getElementById("restore-technique-defaults");

      if (restoreYogaBtn) {
        restoreYogaBtn.addEventListener("click", async () => {
          hiddenDefaultYogaIds = [];
          renderYogaItems();
          await saveState();
        });
      }

      if (restoreTechniqueBtn) {
        restoreTechniqueBtn.addEventListener("click", async () => {
          hiddenDefaultTechniqueIds = [];
          renderTechniques();
          await saveState();
        });
      }
    }

    async function init() {
      const saved = normalizeData(await loadState());

      defaultYogaItems =
        Array.isArray(saved.defaultYogaItems) && saved.defaultYogaItems.length
          ? saved.defaultYogaItems.map(normalizeYogaItem)
          : cloneDefaults().defaultYogaItems.map(normalizeYogaItem);

      defaultSoothingTechniques =
        Array.isArray(saved.defaultSoothingTechniques) && saved.defaultSoothingTechniques.length
          ? saved.defaultSoothingTechniques.map(normalizeTechnique)
          : cloneDefaults().defaultSoothingTechniques.map(normalizeTechnique);

      customYogaItems = Array.isArray(saved.customYogaItems)
        ? saved.customYogaItems.map(normalizeYogaItem).map((item) => ({ ...item, isDefault: false }))
        : [];

      customTechniques = Array.isArray(saved.customTechniques)
        ? saved.customTechniques.map(normalizeTechnique).map((item) => ({ ...item, isDefault: false }))
        : [];

      hiddenDefaultYogaIds = Array.isArray(saved.hiddenDefaultYogaIds) ? saved.hiddenDefaultYogaIds : [];
      hiddenDefaultTechniqueIds = Array.isArray(saved.hiddenDefaultTechniqueIds)
        ? saved.hiddenDefaultTechniqueIds
        : [];

      hasLoadedInitialState = true;

      renderYogaItems();
      renderTechniques();
      setupYogaForm();
      setupTechniqueForm();
      setupDeleteHandlers();
      setupRestoreButtons();
    }

    init();
  </script>
</BaseLayout>