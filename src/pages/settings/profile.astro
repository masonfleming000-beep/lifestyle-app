---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import SectionCard from "../../components/SectionCard.astro";
import {
  PROFILE_SETTINGS_PAGE_KEY,
  DEFAULT_PROFILE_SETTINGS,
  PROFILE_THEME_OPTIONS,
  PROFILE_TEXT_SIZE_OPTIONS,
} from "../../lib/profile/constants";
---

<BaseLayout title="Profile Settings | Lifestyle App" description="Manage your profile and visibility settings">
  <PageHero
    kicker="Profile Settings"
    title="Profile settings"
    description="Manage your account details, public profile, privacy controls, and appearance in one place."
  />

  <section class="section">
    <div class="grid two profile-top-grid">
      <article class="card">
        <div class="section-header">
          <div>
            <h2 class="section-title">Account</h2>
            <p class="section-subtitle">Login identity and recovery settings.</p>
          </div>
        </div>

        <div class="form-stack">
          <label class="field-group">
            <span class="field-label">Email</span>
            <input id="email" class="ui-input" type="email" placeholder="you@example.com" />
          </label>

          <label class="field-group">
            <span class="field-label">Username</span>
            <input id="username" class="ui-input" type="text" placeholder="mason" />
          </label>

          <label class="field-group">
            <span class="field-label">Handle</span>
            <input id="handle" class="ui-input" type="text" placeholder="@mason" />
          </label>

          <div class="button-row">
            <button id="change-password-btn" type="button" class="ui-button ui-button-secondary">
              Change Password
            </button>
          </div>
        </div>
      </article>

      <article class="card soft">
        <div class="section-header">
          <div>
            <h2 class="section-title">Profile snapshot</h2>
            <p class="section-subtitle">Quick summary of how your public profile is configured.</p>
          </div>
        </div>

        <div class="summary-grid compact-summary">
          <div class="summary-metric">
            <p class="metric-label">Display Name</p>
            <p class="summary-value" id="snapshot-display-name">—</p>
          </div>
          <div class="summary-metric">
            <p class="metric-label">Headline</p>
            <p class="summary-value" id="snapshot-headline">—</p>
          </div>
          <div class="summary-metric">
            <p class="metric-label">Location</p>
            <p class="summary-value" id="snapshot-location">—</p>
          </div>
          <div class="summary-metric">
            <p class="metric-label">Theme</p>
            <p class="summary-value" id="snapshot-theme">—</p>
          </div>
        </div>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="grid one">
      <SectionCard title="Public Profile" subtitle="What people see on your profile" open={true}>
        <div class="form-stack">
          <div class="grid two profile-field-grid">
            <label class="field-group">
              <span class="field-label">Display Name</span>
              <input id="displayName" class="ui-input" type="text" placeholder="Mason Fleming" />
            </label>

            <label class="field-group">
              <span class="field-label">Headline</span>
              <input id="headline" class="ui-input" type="text" placeholder="Builder, athlete, student, engineer" />
            </label>

            <label class="field-group">
              <span class="field-label">Location</span>
              <input id="location" class="ui-input" type="text" placeholder="West Lafayette, IN" />
            </label>

            <label class="field-group">
              <span class="field-label">Avatar URL</span>
              <input id="avatarUrl" class="ui-input" type="url" placeholder="https://..." />
            </label>
          </div>

          <label class="field-group">
            <span class="field-label">Banner URL</span>
            <input id="bannerUrl" class="ui-input" type="url" placeholder="https://..." />
          </label>

          <label class="field-group">
            <span class="field-label">Bio</span>
            <textarea id="bio" class="ui-textarea" rows="5" placeholder="Write a short bio"></textarea>
          </label>
        </div>
      </SectionCard>

      <SectionCard title="Privacy & Visibility" subtitle="Control what the public profile shows">
        <div class="settings-toggle-list">
          <label class="settings-toggle-card" for="visibility-profile">
            <div class="settings-toggle-copy">
              <span class="settings-toggle-title">Public profile enabled</span>
              <span class="settings-toggle-description">Allow your public profile page to be visible.</span>
            </div>
            <input id="visibility-profile" class="settings-checkbox" type="checkbox" />
          </label>

          <label class="settings-toggle-card" for="visibility-bio">
            <div class="settings-toggle-copy">
              <span class="settings-toggle-title">Show bio</span>
              <span class="settings-toggle-description">Display your written intro on the public profile.</span>
            </div>
            <input id="visibility-bio" class="settings-checkbox" type="checkbox" />
          </label>

          <label class="settings-toggle-card" for="visibility-stats">
            <div class="settings-toggle-copy">
              <span class="settings-toggle-title">Show stats</span>
              <span class="settings-toggle-description">Include interactive stats and progress data.</span>
            </div>
            <input id="visibility-stats" class="settings-checkbox" type="checkbox" />
          </label>

          <label class="settings-toggle-card" for="visibility-portfolio">
            <div class="settings-toggle-copy">
              <span class="settings-toggle-title">Show portfolio button</span>
              <span class="settings-toggle-description">Expose your portfolio link or portfolio area.</span>
            </div>
            <input id="visibility-portfolio" class="settings-checkbox" type="checkbox" />
          </label>

          <label class="settings-toggle-card" for="visibility-activity">
            <div class="settings-toggle-copy">
              <span class="settings-toggle-title">Show recent activity</span>
              <span class="settings-toggle-description">Let others see your latest visible activity.</span>
            </div>
            <input id="visibility-activity" class="settings-checkbox" type="checkbox" />
          </label>

          <label class="settings-toggle-card" for="visibility-achievements">
            <div class="settings-toggle-copy">
              <span class="settings-toggle-title">Show achievements</span>
              <span class="settings-toggle-description">Display badges, milestones, and accomplishments.</span>
            </div>
            <input id="visibility-achievements" class="settings-checkbox" type="checkbox" />
          </label>

          <label class="settings-toggle-card" for="visibility-contact">
            <div class="settings-toggle-copy">
              <span class="settings-toggle-title">Show contact section</span>
              <span class="settings-toggle-description">Allow visitors to see your contact area.</span>
            </div>
            <input id="visibility-contact" class="settings-checkbox" type="checkbox" />
          </label>
        </div>
      </SectionCard>

      <SectionCard title="Stats Sources" subtitle="Choose which app areas contribute public stats">
        <div class="settings-toggle-list compact-toggle-list">
          <label class="settings-toggle-card" for="stats-fitness">
            <div class="settings-toggle-copy">
              <span class="settings-toggle-title">Fitness</span>
              <span class="settings-toggle-description">Use workout and cardio data in public stats.</span>
            </div>
            <input id="stats-fitness" class="settings-checkbox" type="checkbox" />
          </label>

          <label class="settings-toggle-card" for="stats-hobbies">
            <div class="settings-toggle-copy">
              <span class="settings-toggle-title">Hobbies</span>
              <span class="settings-toggle-description">Include hobbies and learning progress.</span>
            </div>
            <input id="stats-hobbies" class="settings-checkbox" type="checkbox" />
          </label>
        </div>
      </SectionCard>

      <SectionCard title="Interactive Stats Display" subtitle="Configure exactly how the public stats view behaves">
        <div class="form-stack">
          <div class="settings-toggle-list">
            <label class="settings-toggle-card" for="stats-display-auto">
              <div class="settings-toggle-copy">
                <span class="settings-toggle-title">Use interactive formatted stats</span>
                <span class="settings-toggle-description">Show the richer interactive version of public stats.</span>
              </div>
              <input id="stats-display-auto" class="settings-checkbox" type="checkbox" />
            </label>

            <label class="settings-toggle-card" for="stats-display-overview">
              <div class="settings-toggle-copy">
                <span class="settings-toggle-title">Show overview cards</span>
                <span class="settings-toggle-description">Display top-level summary cards first.</span>
              </div>
              <input id="stats-display-overview" class="settings-checkbox" type="checkbox" />
            </label>

            <label class="settings-toggle-card" for="stats-display-sections">
              <div class="settings-toggle-copy">
                <span class="settings-toggle-title">Show lifting section summary</span>
                <span class="settings-toggle-description">Include grouped weightlifting summaries.</span>
              </div>
              <input id="stats-display-sections" class="settings-checkbox" type="checkbox" />
            </label>

            <label class="settings-toggle-card" for="stats-display-workouts">
              <div class="settings-toggle-copy">
                <span class="settings-toggle-title">Show workout charts</span>
                <span class="settings-toggle-description">Display strength workout charts when available.</span>
              </div>
              <input id="stats-display-workouts" class="settings-checkbox" type="checkbox" />
            </label>

            <label class="settings-toggle-card" for="stats-display-cardio">
              <div class="settings-toggle-copy">
                <span class="settings-toggle-title">Show cardio charts</span>
                <span class="settings-toggle-description">Display cardio data and chart sections.</span>
              </div>
              <input id="stats-display-cardio" class="settings-checkbox" type="checkbox" />
            </label>

            <label class="settings-toggle-card" for="stats-display-recent">
              <div class="settings-toggle-copy">
                <span class="settings-toggle-title">Show recent sessions</span>
                <span class="settings-toggle-description">Highlight your latest visible sessions.</span>
              </div>
              <input id="stats-display-recent" class="settings-checkbox" type="checkbox" />
            </label>
          </div>

          <div class="grid three profile-select-grid">
            <label class="field-group">
              <span class="field-label">Default Time Range</span>
              <select id="stats-default-range" class="ui-select">
                <option value="7d">7 days</option>
                <option value="30d">30 days</option>
                <option value="90d">90 days</option>
                <option value="6m">6 months</option>
                <option value="1y">1 year</option>
                <option value="all">All time</option>
              </select>
            </label>

            <label class="field-group">
              <span class="field-label">Default Lifting Section</span>
              <select id="stats-default-section" class="ui-select">
                <option value="all">All sections</option>
                <option value="shoulders">Shoulders</option>
                <option value="chest">Chest</option>
                <option value="back">Back</option>
                <option value="legs">Legs</option>
                <option value="arms">Arms</option>
                <option value="core">Core</option>
              </select>
            </label>

            <label class="field-group">
              <span class="field-label">Default Workout</span>
              <select id="stats-default-workout" class="ui-select">
                <option value="all">All workouts</option>
                <option value="reverse-cable-crossovers">Reverse Cable Crossovers</option>
                <option value="bench-press">Bench Press</option>
                <option value="lat-pulldown">Lat Pulldown</option>
                <option value="squat">Squat</option>
                <option value="deadlift">Deadlift</option>
              </select>
            </label>
          </div>

          <div class="grid three profile-select-grid">
            <label class="field-group">
              <span class="field-label">Default Cardio Type</span>
              <select id="stats-default-cardio-type" class="ui-select">
                <option value="all">All cardio</option>
                <option value="steady">Steady</option>
                <option value="recovery">Recovery</option>
                <option value="long-run">Long Run</option>
                <option value="tempo">Tempo</option>
                <option value="intervals">Intervals</option>
                <option value="hiit">HIIT</option>
                <option value="fartlek">Fartlek</option>
                <option value="hills">Hills</option>
                <option value="power">Power</option>
              </select>
            </label>

            <label class="field-group">
              <span class="field-label">Default Hobby</span>
              <select id="stats-default-hobby-id" class="ui-select">
                <option value="all">All hobbies</option>
                <option value="reading">Reading</option>
                <option value="drumming">Drumming</option>
              </select>
            </label>

            <label class="field-group">
              <span class="field-label">Default Hobby Stage</span>
              <select id="stats-default-hobby-stage-id" class="ui-select">
                <option value="all">All stages</option>
                <option value="beginner">Beginner</option>
                <option value="intermediate">Intermediate</option>
                <option value="advanced">Advanced</option>
              </select>
            </label>
          </div>

          <div class="grid three profile-select-grid">
            <label class="field-group">
              <span class="field-label">Portfolio Mode</span>
              <select id="stats-portfolio-mode" class="ui-select">
                <option value="link">Link only</option>
                <option value="full">Full</option>
              </select>
            </label>
          </div>
        </div>
      </SectionCard>

      <SectionCard title="Notifications" subtitle="Choose how profile-related updates reach you">
        <div class="settings-toggle-list compact-toggle-list">
          <label class="settings-toggle-card" for="notifications-email">
            <div class="settings-toggle-copy">
              <span class="settings-toggle-title">Email</span>
              <span class="settings-toggle-description">Send updates to your inbox.</span>
            </div>
            <input id="notifications-email" class="settings-checkbox" type="checkbox" />
          </label>

          <label class="settings-toggle-card" for="notifications-push">
            <div class="settings-toggle-copy">
              <span class="settings-toggle-title">Push</span>
              <span class="settings-toggle-description">Send device push alerts.</span>
            </div>
            <input id="notifications-push" class="settings-checkbox" type="checkbox" />
          </label>

          <label class="settings-toggle-card" for="notifications-product">
            <div class="settings-toggle-copy">
              <span class="settings-toggle-title">Product updates</span>
              <span class="settings-toggle-description">Hear about new features and improvements.</span>
            </div>
            <input id="notifications-product" class="settings-checkbox" type="checkbox" />
          </label>

          <label class="settings-toggle-card" for="notifications-reminders">
            <div class="settings-toggle-copy">
              <span class="settings-toggle-title">Reminders</span>
              <span class="settings-toggle-description">Receive profile-related reminder notifications.</span>
            </div>
            <input id="notifications-reminders" class="settings-checkbox" type="checkbox" />
          </label>

          <label class="settings-toggle-card" for="notifications-marketing">
            <div class="settings-toggle-copy">
              <span class="settings-toggle-title">Marketing</span>
              <span class="settings-toggle-description">Allow promotional updates and campaigns.</span>
            </div>
            <input id="notifications-marketing" class="settings-checkbox" type="checkbox" />
          </label>
        </div>
      </SectionCard>

      <SectionCard title="Theme" subtitle="Apply profile preferences across the app">
        <div class="grid three profile-select-grid">
          <label class="field-group">
            <span class="field-label">Color Mode</span>
            <select id="theme-mode" class="ui-select">
              {PROFILE_THEME_OPTIONS.map((option) => (
                <option value={option}>{option}</option>
              ))}
            </select>
          </label>

          <label class="field-group">
            <span class="field-label">Accent</span>
            <input id="theme-accent" class="ui-input" type="text" placeholder="default" />
          </label>

          <label class="field-group">
            <span class="field-label">Text Size</span>
            <select id="theme-text-size" class="ui-select">
              {PROFILE_TEXT_SIZE_OPTIONS.map((option) => (
                <option value={option}>{option}</option>
              ))}
            </select>
          </label>
        </div>
      </SectionCard>
    </div>
  </section>

  <section class="section">
    <article class="card">
      <div class="section-header">
        <div>
          <h2 class="section-title">Public profile preview</h2>
          <p class="section-subtitle">See the interactive profile layout before saving</p>
        </div>
      </div>
      <div id="profile-preview-root">
        <p>Loading preview...</p>
      </div>
    </article>
  </section>

  <section class="section">
    <div class="profile-settings-actions card">
      <div id="profile-settings-status" class="save-status neutral">Loading...</div>
      <div class="button-row">
        <button id="refresh-preview-btn" type="button" class="ui-button ui-button-secondary">Refresh Preview</button>
        <button id="save-profile-settings-btn" type="button" class="ui-button">Save Profile Settings</button>
      </div>
    </div>
  </section>

  <script define:vars={{ pageKey: PROFILE_SETTINGS_PAGE_KEY, defaultProfileSettings: JSON.stringify(DEFAULT_PROFILE_SETTINGS) }}>
    (() => {
      const statusEl = document.getElementById("profile-settings-status");
      const previewRoot = document.getElementById("profile-preview-root");

      let state = null;
      let hasLoadedInitialState = false;
      let isSaving = false;
      let pendingSave = false;
      let previewRefreshTimer = null;

      function setStatus(text, mode = "neutral") {
        if (!statusEl) return;
        statusEl.textContent = text;
        statusEl.className = `save-status ${mode}`;
      }

      function cloneDefaults() {
        return JSON.parse(defaultProfileSettings);
      }

      function normalizeString(value) {
        return typeof value === "string" ? value : "";
      }

      function normalizeBoolean(value, fallback = false) {
        return typeof value === "boolean" ? value : fallback;
      }

      function slugifyProfileValue(value) {
        return String(value || "")
          .trim()
          .toLowerCase()
          .replace(/^@+/, "")
          .replace(/[^a-z0-9._-]+/g, ".")
          .replace(/\.{2,}/g, ".")
          .replace(/^\.+|\.+$/g, "");
      }

      function byId(id) {
        return document.getElementById(id);
      }

      function setValue(id, value) {
        const el = byId(id);
        if (!el) return;

        const normalizedValue = value ?? "";

        if (el.tagName === "SELECT") {
          const hasOption = Array.from(el.options).some((option) => option.value === normalizedValue);
          el.value = hasOption ? normalizedValue : el.options[0]?.value || "";
          return;
        }

        el.value = normalizedValue;
      }

      function setChecked(id, value) {
        const el = byId(id);
        if (!el) return;
        el.checked = !!value;
      }

      function getValue(id) {
        return String(byId(id)?.value || "").trim();
      }

      function getChecked(id) {
        return !!byId(id)?.checked;
      }

      function formatPreviewValue(value) {
        const num = Number(value);
        if (Number.isFinite(num)) {
          return num.toFixed(2);
        }
        return String(value || "—");
      }

      function deriveUsernameCandidate() {
        const explicitUsername = slugifyProfileValue(getValue("username"));
        if (explicitUsername) return explicitUsername;

        const explicitHandle = slugifyProfileValue(getValue("handle"));
        if (explicitHandle) return explicitHandle;

        const email = getValue("email");
        const emailLocal = slugifyProfileValue(email.split("@")[0] || "");
        if (emailLocal) return emailLocal;

        const displayName = slugifyProfileValue(getValue("displayName"));
        if (displayName) return displayName;

        return "";
      }

      function deriveHandleCandidate(username) {
        const explicitHandle = slugifyProfileValue(getValue("handle"));
        if (explicitHandle) return `@${explicitHandle}`;
        return username ? `@${username}` : "";
      }

      function refreshSnapshot(nextState) {
        const set = (id, value) => {
          const el = byId(id);
          if (el) el.textContent = value || "—";
        };

        set("snapshot-display-name", nextState.displayName);
        set("snapshot-headline", nextState.headline);
        set("snapshot-location", nextState.location);
        set("snapshot-theme", `${nextState.theme.mode} / ${nextState.theme.textSize}`);
      }

      function normalizeState(raw) {
        const defaults = cloneDefaults();
        const source = raw && typeof raw === "object" ? raw : {};

        return {
          ...defaults,
          ...source,
          username: normalizeString(source?.username || defaults.username),
          handle: normalizeString(source?.handle || defaults.handle),
          displayName: normalizeString(source?.displayName || defaults.displayName),
          headline: normalizeString(source?.headline || defaults.headline),
          location: normalizeString(source?.location || defaults.location),
          bio: normalizeString(source?.bio || defaults.bio),
          bannerUrl: normalizeString(source?.bannerUrl || defaults.bannerUrl),
          avatarUrl: normalizeString(source?.avatarUrl || defaults.avatarUrl),
          visibility: {
            ...defaults.visibility,
            ...(source?.visibility || {}),
          },
          portfolioFilters: {
            ...defaults.portfolioFilters,
            ...(source?.portfolioFilters || {}),
          },
          statsSources: {
            ...defaults.statsSources,
            ...(source?.statsSources || {}),
          },
          statsDisplay: {
            ...defaults.statsDisplay,
            ...(source?.statsDisplay || {}),
            autoFormatted: normalizeBoolean(source?.statsDisplay?.autoFormatted, defaults.statsDisplay?.autoFormatted ?? true),
            showOverview: normalizeBoolean(source?.statsDisplay?.showOverview, defaults.statsDisplay?.showOverview ?? true),
            showSections: normalizeBoolean(source?.statsDisplay?.showSections, defaults.statsDisplay?.showSections ?? true),
            showWorkouts: normalizeBoolean(source?.statsDisplay?.showWorkouts, defaults.statsDisplay?.showWorkouts ?? true),
            showCardio: normalizeBoolean(source?.statsDisplay?.showCardio, defaults.statsDisplay?.showCardio ?? true),
            showRecentSessions: normalizeBoolean(source?.statsDisplay?.showRecentSessions, defaults.statsDisplay?.showRecentSessions ?? true),
            defaultRange: normalizeString(source?.statsDisplay?.defaultRange || defaults.statsDisplay?.defaultRange || "30d"),
            defaultSection: normalizeString(source?.statsDisplay?.defaultSection || defaults.statsDisplay?.defaultSection || "all"),
            defaultWorkout: normalizeString(source?.statsDisplay?.defaultWorkout || defaults.statsDisplay?.defaultWorkout || "all"),
            defaultCardioType: normalizeString(source?.statsDisplay?.defaultCardioType || defaults.statsDisplay?.defaultCardioType || "all"),
            defaultHobbyId: normalizeString(source?.statsDisplay?.defaultHobbyId || defaults.statsDisplay?.defaultHobbyId || "all"),
            defaultHobbyStageId: normalizeString(source?.statsDisplay?.defaultHobbyStageId || defaults.statsDisplay?.defaultHobbyStageId || "all"),
            portfolioMode: normalizeString(source?.statsDisplay?.portfolioMode || defaults.statsDisplay?.portfolioMode || "link"),
            featuredFitnessMetrics: defaults.statsDisplay.featuredFitnessMetrics,
            featuredCardioMetrics: defaults.statsDisplay.featuredCardioMetrics,
            featuredHobbyMetrics: defaults.statsDisplay.featuredHobbyMetrics,
          },
          notifications: {
            ...defaults.notifications,
            ...(source?.notifications || {}),
          },
          theme: {
            ...defaults.theme,
            ...(source?.theme || {}),
            mode: normalizeString(source?.theme?.mode || defaults.theme.mode),
            accent: normalizeString(source?.theme?.accent || defaults.theme.accent),
            textSize: normalizeString(source?.theme?.textSize || defaults.theme.textSize),
          },
          account: {
            email: normalizeString(source?.account?.email || defaults?.account?.email),
          },
        };
      }

      function applyState(nextState) {
        setValue("email", nextState?.account?.email || "");
        setValue("username", nextState.username || "");
        setValue("handle", nextState.handle || "");
        setValue("displayName", nextState.displayName);
        setValue("headline", nextState.headline);
        setValue("location", nextState.location);
        setValue("bio", nextState.bio);
        setValue("bannerUrl", nextState.bannerUrl);
        setValue("avatarUrl", nextState.avatarUrl);

        setChecked("visibility-profile", nextState.visibility.profile);
        setChecked("visibility-bio", nextState.visibility.bio);
        setChecked("visibility-stats", nextState.visibility.stats);
        setChecked("visibility-portfolio", nextState.visibility.portfolio);
        setChecked("visibility-activity", nextState.visibility.activity);
        setChecked("visibility-achievements", nextState.visibility.achievements);
        setChecked("visibility-contact", nextState.visibility.contact);

        setChecked("stats-fitness", nextState.statsSources.fitness);
        setChecked("stats-hobbies", nextState.statsSources.hobbies);

        setChecked("stats-display-auto", nextState.statsDisplay.autoFormatted);
        setChecked("stats-display-overview", nextState.statsDisplay.showOverview);
        setChecked("stats-display-sections", nextState.statsDisplay.showSections);
        setChecked("stats-display-workouts", nextState.statsDisplay.showWorkouts);
        setChecked("stats-display-cardio", nextState.statsDisplay.showCardio);
        setChecked("stats-display-recent", nextState.statsDisplay.showRecentSessions);
        setValue("stats-default-range", nextState.statsDisplay.defaultRange);
        setValue("stats-default-section", nextState.statsDisplay.defaultSection);
        setValue("stats-default-workout", nextState.statsDisplay.defaultWorkout);
        setValue("stats-default-cardio-type", nextState.statsDisplay.defaultCardioType);
        setValue("stats-default-hobby-id", nextState.statsDisplay.defaultHobbyId);
        setValue("stats-default-hobby-stage-id", nextState.statsDisplay.defaultHobbyStageId);
        setValue("stats-portfolio-mode", nextState.statsDisplay.portfolioMode);

        setChecked("notifications-email", nextState.notifications.email);
        setChecked("notifications-push", nextState.notifications.push);
        setChecked("notifications-product", nextState.notifications.product);
        setChecked("notifications-reminders", nextState.notifications.reminders);
        setChecked("notifications-marketing", nextState.notifications.marketing);

        setValue("theme-mode", nextState.theme.mode);
        setValue("theme-accent", nextState.theme.accent);
        setValue("theme-text-size", nextState.theme.textSize);

        refreshSnapshot(nextState);
      }

      function collectState() {
        const defaults = cloneDefaults();
        const derivedUsername = deriveUsernameCandidate();
        const derivedHandle = deriveHandleCandidate(derivedUsername);

        return {
          ...defaults,
          displayName: getValue("displayName"),
          username: derivedUsername,
          handle: derivedHandle,
          bio: getValue("bio"),
          bannerUrl: getValue("bannerUrl"),
          avatarUrl: getValue("avatarUrl"),
          location: getValue("location"),
          headline: getValue("headline"),
          visibility: {
            profile: getChecked("visibility-profile"),
            bio: getChecked("visibility-bio"),
            stats: getChecked("visibility-stats"),
            portfolio: getChecked("visibility-portfolio"),
            activity: getChecked("visibility-activity"),
            achievements: getChecked("visibility-achievements"),
            contact: getChecked("visibility-contact"),
          },
          statsSources: {
            fitness: getChecked("stats-fitness"),
            hobbies: getChecked("stats-hobbies"),
          },
          statsDisplay: {
            autoFormatted: getChecked("stats-display-auto"),
            showOverview: getChecked("stats-display-overview"),
            showSections: getChecked("stats-display-sections"),
            showWorkouts: getChecked("stats-display-workouts"),
            showCardio: getChecked("stats-display-cardio"),
            showRecentSessions: getChecked("stats-display-recent"),
            defaultRange: getValue("stats-default-range") || "30d",
            defaultSection: getValue("stats-default-section") || "all",
            defaultWorkout: getValue("stats-default-workout") || "all",
            defaultCardioType: getValue("stats-default-cardio-type") || "all",
            defaultHobbyId: getValue("stats-default-hobby-id") || "all",
            defaultHobbyStageId: getValue("stats-default-hobby-stage-id") || "all",
            featuredFitnessMetrics: defaults.statsDisplay.featuredFitnessMetrics,
            featuredCardioMetrics: defaults.statsDisplay.featuredCardioMetrics,
            featuredHobbyMetrics: defaults.statsDisplay.featuredHobbyMetrics,
            portfolioMode: getValue("stats-portfolio-mode") || "link",
          },
          notifications: {
            email: getChecked("notifications-email"),
            push: getChecked("notifications-push"),
            product: getChecked("notifications-product"),
            reminders: getChecked("notifications-reminders"),
            marketing: getChecked("notifications-marketing"),
          },
          theme: {
            mode: getValue("theme-mode") || defaults.theme.mode,
            accent: getValue("theme-accent") || defaults.theme.accent,
            textSize: getValue("theme-text-size") || defaults.theme.textSize,
          },
          account: {
            email: getValue("email"),
          },
          portfolioFilters: {
            ...(defaults.portfolioFilters || {}),
          },
        };
      }

      async function loadState() {
        try {
          const response = await fetch(`/api/state?pageKey=${encodeURIComponent(pageKey)}`, {
            credentials: "include",
            cache: "no-store",
          });

          if (!response.ok) return null;

          const payload = await response.json();
          return payload?.state ?? null;
        } catch (error) {
          console.error("Failed to load profile settings:", error);
          return null;
        }
      }

      async function persistState(nextState) {
        const response = await fetch("/api/state", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ pageKey, state: nextState }),
        });

        if (!response.ok) {
          throw new Error("Failed to save profile settings");
        }
      }

      async function saveState(nextState = state, options = {}) {
        const { silent = false } = options;

        if (!hasLoadedInitialState) return;

        if (isSaving) {
          pendingSave = true;
          state = normalizeState(nextState);
          return;
        }

        isSaving = true;
        state = normalizeState(nextState);

        if (!silent) {
          setStatus("Saving...", "neutral");
        }

        try {
          await persistState(state);
          applyTheme(state);

          if (!silent) {
            setStatus("Saved", "success");
          }
        } catch (error) {
          console.error(error);
          if (!silent) {
            setStatus("Unable to save", "error");
          }
        } finally {
          isSaving = false;

          if (pendingSave) {
            pendingSave = false;
            await saveState(state, options);
          }
        }
      }

      function applyTheme(nextState) {
        const mode = nextState?.theme?.mode || "system";
        const accent = nextState?.theme?.accent || "default";
        const textSize = nextState?.theme?.textSize || "medium";

        localStorage.setItem("profile-theme-mode", mode);
        localStorage.setItem("profile-theme-accent", accent);
        localStorage.setItem("profile-theme-text-size", textSize);

        document.documentElement.dataset.theme = mode;
        document.documentElement.dataset.textSize = textSize;
        document.documentElement.dataset.accent = accent;
      }

      function escapeHtml(value) {
        return String(value || "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function safeArray(value) {
        return Array.isArray(value) ? value : [];
      }

      function safeObject(value) {
        return value && typeof value === "object" ? value : {};
      }

      function renderPreview(payload) {
        const profile = payload?.profile;

        if (!profile) {
          previewRoot.innerHTML = `<p>Preview unavailable.</p>`;
          return;
        }

        const fitness = safeObject(profile?.interactiveData?.fitness);
        const hobbies = safeObject(profile?.interactiveData?.hobbies);

        previewRoot.innerHTML = `
          <div class="preview-stack">
            <article class="preview-card">
              <h3>${escapeHtml(profile?.displayName || "Profile")}</h3>
              <p>${escapeHtml(profile?.headline || "")}</p>
              <p class="meta">${escapeHtml(profile?.location || "")}</p>
              ${profile?.bio ? `<p>${escapeHtml(profile.bio)}</p>` : ""}
            </article>

            <div class="grid three">
              ${safeArray(fitness?.overviewCards).map((item) => `
                <article class="preview-stat-card">
                  <p class="metric-label">${escapeHtml(item?.label || "")}</p>
                  <h4>${escapeHtml(formatPreviewValue(item?.value))}</h4>
                </article>
              `).join("")}
            </div>

            <article class="preview-card">
              <h4>Weightlifting sections</h4>
              <p>${safeArray(fitness?.sections).map((item) => escapeHtml(item?.label || item?.id)).join(", ") || "None yet"}</p>
            </article>

            <article class="preview-card">
              <h4>Cardio types</h4>
              <p>${safeArray(fitness?.cardioTypes).map((item) => escapeHtml(item?.label || item?.id)).join(", ") || "None yet"}</p>
            </article>

            <article class="preview-card">
              <h4>Hobbies</h4>
              <p>${safeArray(hobbies?.hobbies).map((item) => escapeHtml(item?.name || item?.id)).join(", ") || "None yet"}</p>
            </article>

            <article class="preview-card">
              <h4>Portfolio mode</h4>
              <p>${escapeHtml(profile?.portfolioMode || "link")}</p>
            </article>
          </div>
        `;
      }

      async function refreshPreview() {
        previewRoot.innerHTML = `<p>Refreshing preview...</p>`;

        try {
          const response = await fetch(`/api/profile/public?preview=1`, {
            credentials: "include",
            cache: "no-store",
          });

          const payload = await response.json().catch(() => ({}));
          renderPreview(payload);
        } catch (error) {
          console.error(error);
          previewRoot.innerHTML = `<p>Preview failed to load.</p>`;
        }
      }

      function schedulePreviewRefresh() {
        if (previewRefreshTimer) {
          clearTimeout(previewRefreshTimer);
        }

        previewRefreshTimer = window.setTimeout(async () => {
          await refreshPreview();
        }, 350);
      }

      async function syncFromInputs(options = {}) {
        state = normalizeState(collectState());
        refreshSnapshot(state);
        applyTheme(state);
        await saveState(state, options);
        schedulePreviewRefresh();
      }

      function attachAutoSaveListeners() {
        const fieldIds = [
          "email",
          "username",
          "handle",
          "displayName",
          "headline",
          "location",
          "avatarUrl",
          "bannerUrl",
          "bio",
          "visibility-profile",
          "visibility-bio",
          "visibility-stats",
          "visibility-portfolio",
          "visibility-activity",
          "visibility-achievements",
          "visibility-contact",
          "stats-fitness",
          "stats-hobbies",
          "stats-display-auto",
          "stats-display-overview",
          "stats-display-sections",
          "stats-display-workouts",
          "stats-display-cardio",
          "stats-display-recent",
          "stats-default-range",
          "stats-default-section",
          "stats-default-workout",
          "stats-default-cardio-type",
          "stats-default-hobby-id",
          "stats-default-hobby-stage-id",
          "stats-portfolio-mode",
          "notifications-email",
          "notifications-push",
          "notifications-product",
          "notifications-reminders",
          "notifications-marketing",
          "theme-mode",
          "theme-accent",
          "theme-text-size",
        ];

        fieldIds.forEach((id) => {
          const el = byId(id);
          if (!el) return;

          const eventName =
            el.tagName === "SELECT" || el.type === "checkbox" ? "change" : "input";

          el.addEventListener(eventName, async () => {
            await syncFromInputs({ silent: true });
          });
        });
      }

      document.getElementById("save-profile-settings-btn")?.addEventListener("click", async () => {
        state = normalizeState(collectState());
        refreshSnapshot(state);
        setStatus("Saving...", "neutral");

        await saveState(state);
        await refreshPreview();
      });

      document.getElementById("refresh-preview-btn")?.addEventListener("click", async () => {
        state = normalizeState(collectState());
        refreshSnapshot(state);
        await refreshPreview();
      });

      document.getElementById("change-password-btn")?.addEventListener("click", () => {
        window.location.href = "/forgot-password";
      });

      async function init() {
        setStatus("Loading...", "neutral");

        const saved = await loadState();
        state = normalizeState(saved);

        applyState(state);
        applyTheme(state);
        attachAutoSaveListeners();

        hasLoadedInitialState = true;

        await refreshPreview();
        setStatus("Ready", "success");
      }

      init();
    })();
  </script>

  <style>
    .profile-top-grid {
      align-items: start;
    }

    .form-stack {
      display: grid;
      gap: 1rem;
    }

    .field-group {
      display: grid;
      gap: 0.5rem;
      min-width: 0;
    }

    .field-label {
      font-size: 0.92rem;
      font-weight: 700;
      color: #334155;
    }

    .ui-input,
    .ui-select,
    .ui-textarea {
      width: 100%;
      min-width: 0;
      border-radius: 14px;
      border: 1px solid rgba(15, 23, 42, 0.1);
      background: rgba(255, 255, 255, 0.92);
      padding: 0.9rem 1rem;
      font: inherit;
      color: #0f172a;
      box-sizing: border-box;
      transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
    }

    .ui-input:focus,
    .ui-select:focus,
    .ui-textarea:focus {
      outline: none;
      border-color: rgba(47, 93, 98, 0.45);
      box-shadow: 0 0 0 4px rgba(47, 93, 98, 0.1);
      background: rgba(255, 255, 255, 1);
    }

    .ui-textarea {
      resize: vertical;
      min-height: 120px;
    }

    .ui-button {
      border: none;
      border-radius: 999px;
      padding: 0.82rem 1.15rem;
      font: inherit;
      font-weight: 700;
      background: #2f5d62;
      color: white;
      cursor: pointer;
      transition: transform 0.18s ease, opacity 0.18s ease, box-shadow 0.18s ease;
    }

    .ui-button:hover {
      transform: translateY(-1px);
      box-shadow: 0 12px 24px rgba(47, 93, 98, 0.16);
    }

    .ui-button-secondary {
      background: rgba(255, 255, 255, 0.88);
      color: #1e293b;
      border: 1px solid rgba(15, 23, 42, 0.1);
      box-shadow: none;
    }

    .button-row {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .settings-toggle-list {
      display: grid;
      gap: 0.85rem;
    }

    .compact-toggle-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .settings-toggle-card {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 1rem;
      width: 100%;
      padding: 1rem 1.05rem;
      border-radius: 18px;
      border: 1px solid rgba(15, 23, 42, 0.08);
      background: rgba(255, 255, 255, 0.78);
      cursor: pointer;
      box-sizing: border-box;
      transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
    }

    .settings-toggle-card:hover {
      transform: translateY(-1px);
      border-color: rgba(47, 93, 98, 0.28);
      box-shadow: 0 14px 26px rgba(15, 23, 42, 0.05);
    }

    .settings-toggle-copy {
      display: grid;
      gap: 0.22rem;
      min-width: 0;
    }

    .settings-toggle-title {
      display: block;
      font-weight: 700;
      color: #0f172a;
      line-height: 1.35;
      word-break: break-word;
    }

    .settings-toggle-description {
      display: block;
      font-size: 0.92rem;
      line-height: 1.45;
      color: #64748b;
      word-break: break-word;
    }

    .settings-checkbox {
      width: 1.1rem;
      height: 1.1rem;
      flex: 0 0 auto;
      margin: 0;
      accent-color: #2f5d62;
      justify-self: end;
      align-self: center;
    }

    .compact-summary {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem;
    }

    .summary-metric {
      min-width: 0;
    }

    .summary-value {
      word-break: break-word;
    }

    .profile-settings-actions {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .preview-stack {
      display: grid;
      gap: 1rem;
    }

    .preview-card,
    .preview-stat-card {
      border-radius: 18px;
      padding: 1rem;
      border: 1px solid rgba(15, 23, 42, 0.08);
      background: rgba(255, 255, 255, 0.82);
    }

    .profile-field-grid,
    .profile-select-grid {
      gap: 1rem;
    }

    @media (max-width: 900px) {
      .compact-toggle-list,
      .compact-summary {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 720px) {
      .settings-toggle-card {
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 0.85rem;
        padding: 0.95rem;
      }

      .settings-checkbox {
        width: 1rem;
        height: 1rem;
      }

      .profile-settings-actions {
        align-items: stretch;
      }

      .profile-settings-actions .button-row {
        width: 100%;
      }

      .profile-settings-actions .ui-button {
        flex: 1 1 100%;
      }
    }

    @media (max-width: 560px) {
      .settings-toggle-card {
        padding: 0.9rem;
      }

      .settings-toggle-title {
        font-size: 0.98rem;
      }

      .settings-toggle-description {
        font-size: 0.88rem;
      }

      .ui-input,
      .ui-select,
      .ui-textarea {
        padding: 0.85rem 0.95rem;
      }
    }
  </style>
</BaseLayout>