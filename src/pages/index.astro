---
/**
 * Main homepage/dashboard for the app.
 * Introduces the lifestyle system and provides quick access
 * to major sections like Today, Fitness, Nutrition, Mind, and more.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import { quotes, morals } from "../data/home";

const navCards = [
  { href: "/today", title: "Today", text: "Daily dashboard, routines, and priorities." },
  { href: "/fitness", title: "Fitness", text: "Training hub for running and lifting." },
  { href: "/nutrition", title: "Nutrition", text: "Macros, food reminders, and tracking." },
  { href: "/mind", title: "Mind", text: "Recovery, yoga, and calming techniques." },
  { href: "/education", title: "Education", text: "Classes, school goals, and planning." },
  { href: "/work", title: "Work", text: "Tasks, meetings, sections, and deadlines." },
  { href: "/career", title: "Career", text: "Professional direction, projects, and skills." },
  { href: "/hobbies", title: "Hobbies", text: "Personal interests and development." },
];

const defaultQuotes = JSON.stringify(quotes);
const defaultMorals = JSON.stringify(morals);
---

<BaseLayout title="Home | Lifestyle App" description="Personal lifestyle home page">
  <section class="hero">
    <div class="hero-card">
      <p class="kicker">Home</p>
      <h1>Your life, organized simply.</h1>
      <p>Use this page as the main hub. Tap into each area below.</p>
    </div>
  </section>

  <section class="section">
    <div class="section-header nav-header">
      <div>
        <h2 class="section-title">Navigate</h2>
        <p class="section-subtitle">Choose a section.</p>
      </div>

      <div class="view-switcher" role="group" aria-label="Navigation layout">
        <button
          type="button"
          class="view-btn is-active"
          data-view-btn="grid"
          aria-pressed="true"
        >
          Grid
        </button>
        <button
          type="button"
          class="view-btn"
          data-view-btn="list"
          aria-pressed="false"
        >
          List
        </button>
      </div>
    </div>

    <div id="nav-cards" class="quick-links-grid quick-links-grid--grid">
      {navCards.map((card) => (
        <a href={card.href} class="link-card quick-link-card">
          <div class="quick-link-card-inner">
            <div class="quick-link-copy">
              <h3>{card.title}</h3>
              <p>{card.text}</p>
            </div>
            <span class="quick-link-arrow" aria-hidden="true">→</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <details class="dropdown-card" open>
      <summary class="dropdown-summary">
        <div>
          <h2 class="section-title">Featured Quotes</h2>
          <p class="section-subtitle">Open when you want perspective.</p>
        </div>
        <span class="dropdown-icon">+</span>
      </summary>

      <div class="dropdown-body">
        <form id="quote-form" class="input-card">
          <h3 class="card-title">Add Quote</h3>
          <div class="form-stack">
            <input id="quote-text" type="text" placeholder="Quote text" required />
            <input id="quote-author" type="text" placeholder="Author or reminder source" />
            <button type="submit" class="action-btn">Add Quote</button>
          </div>
        </form>

        <div style="margin: 0 0 1rem 0;">
          <button id="restore-quotes-btn" type="button" class="action-btn secondary-btn">
            Restore Default Quotes
          </button>
        </div>

        <div id="quotes-list" class="grid three"></div>
      </div>
    </details>
  </section>

  <section class="section">
    <details class="dropdown-card">
      <summary class="dropdown-summary">
        <div>
          <h2 class="section-title">Core Reminders</h2>
          <p class="section-subtitle">Keep these tucked away until needed.</p>
        </div>
        <span class="dropdown-icon">+</span>
      </summary>

      <div class="dropdown-body">
        <form id="reminder-form" class="input-card">
          <h3 class="card-title">Add Core Reminder</h3>
          <div class="form-stack">
            <input id="reminder-title" type="text" placeholder="Reminder title" required />
            <textarea id="reminder-text" placeholder="Reminder details" rows="4" required></textarea>
            <button type="submit" class="action-btn">Add Reminder</button>
          </div>
        </form>

        <div style="margin: 0 0 1rem 0;">
          <button id="restore-reminders-btn" type="button" class="action-btn secondary-btn">
            Restore Default Reminders
          </button>
        </div>

        <div id="reminders-list" class="grid three"></div>
      </div>
    </details>
  </section>

  <script define:vars={{ defaultQuotes, defaultMorals }}>
    const pageKey = "home";
    const navViewStorageKey = "home-nav-view";

    const quotesList = document.getElementById("quotes-list");
    const remindersList = document.getElementById("reminders-list");

    const quoteForm = document.getElementById("quote-form");
    const quoteTextInput = document.getElementById("quote-text");
    const quoteAuthorInput = document.getElementById("quote-author");
    const restoreQuotesBtn = document.getElementById("restore-quotes-btn");

    const reminderForm = document.getElementById("reminder-form");
    const reminderTitleInput = document.getElementById("reminder-title");
    const reminderTextInput = document.getElementById("reminder-text");
    const restoreRemindersBtn = document.getElementById("restore-reminders-btn");

    const navCardsContainer = document.getElementById("nav-cards");
    const viewButtons = document.querySelectorAll("[data-view-btn]");

    const defaultQuoteItems = JSON.parse(defaultQuotes);
    const defaultMoralItems = JSON.parse(defaultMorals);

    function quoteKey(q) {
      return `${q.text}::${q.author || ""}`;
    }

    function moralKey(m) {
      return `${m.title}::${m.text}`;
    }

    const defaultQuoteKeySet = new Set(defaultQuoteItems.map(quoteKey));
    const defaultMoralKeySet = new Set(defaultMoralItems.map(moralKey));

    let state = {
      quotes: [],
      morals: [],
      removedDefaultQuotes: [],
      removedDefaultMorals: [],
    };

    function normalizeState(saved) {
      return {
        quotes: Array.isArray(saved?.quotes) ? saved.quotes : [],
        morals: Array.isArray(saved?.morals) ? saved.morals : [],
        removedDefaultQuotes: Array.isArray(saved?.removedDefaultQuotes) ? saved.removedDefaultQuotes : [],
        removedDefaultMorals: Array.isArray(saved?.removedDefaultMorals) ? saved.removedDefaultMorals : [],
      };
    }

    function mergeDefaults(savedItems, defaultItems, removedKeys, keyFn) {
      const removedSet = new Set(removedKeys || []);
      const merged = [...(savedItems || [])];
      const existingKeys = new Set(merged.map(keyFn));

      defaultItems.forEach((defaultItem) => {
        const key = keyFn(defaultItem);
        if (removedSet.has(key)) return;
        if (existingKeys.has(key)) return;

        merged.push(defaultItem);
        existingKeys.add(key);
      });

      return merged;
    }

    function dedupeBy(items, keyFn) {
      const seen = new Set();
      return (items || []).filter((item) => {
        const key = keyFn(item);
        if (seen.has(key)) return false;
        seen.add(key);
        return true;
      });
    }

    async function loadState() {
      try {
        const res = await fetch(`/api/state?pageKey=${encodeURIComponent(pageKey)}`, {
          credentials: "include",
        });

        if (!res.ok) return null;

        const data = await res.json();
        return data?.state ?? null;
      } catch (error) {
        console.error("Failed to load state:", error);
        return null;
      }
    }

    async function saveState() {
      try {
        await fetch("/api/state", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ pageKey, state }),
        });
      } catch (error) {
        console.error("Failed to save state:", error);
      }
    }

    function saveStateOnLeave() {
      try {
        navigator.sendBeacon(
          "/api/state",
          new Blob([JSON.stringify({ pageKey, state })], {
            type: "application/json",
          })
        );
      } catch (error) {
        console.error("Failed to save on leave:", error);
      }
    }

    function escapeHtml(value) {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function setNavView(view) {
      if (!navCardsContainer) return;

      const normalizedView = view === "list" ? "list" : "grid";

      navCardsContainer.classList.remove("quick-links-grid--grid", "quick-links-grid--list");
      navCardsContainer.classList.add(`quick-links-grid--${normalizedView}`);

      viewButtons.forEach((button) => {
        const isActive = button.getAttribute("data-view-btn") === normalizedView;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-pressed", String(isActive));
      });

      localStorage.setItem(navViewStorageKey, normalizedView);
    }

    function initNavView() {
      const savedView = localStorage.getItem(navViewStorageKey);
      setNavView(savedView === "list" ? "list" : "grid");

      viewButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const view = button.getAttribute("data-view-btn");
          setNavView(view);
        });
      });
    }

    function renderQuotes() {
      if (!quotesList) return;
      quotesList.innerHTML = "";

      state.quotes.forEach((quote, index) => {
        const article = document.createElement("article");
        article.className = "card quote-card";

        article.innerHTML = `
          <div>
            <p class="quote-text">“${escapeHtml(quote.text)}”</p>
            <span class="quote-author">${escapeHtml(quote.author || "Personal reminder")}</span>
          </div>
          <button class="delete-btn" data-quote-index="${index}" type="button">Remove</button>
        `;

        quotesList.appendChild(article);
      });

      quotesList.querySelectorAll("[data-quote-index]").forEach((btn) => {
        btn.addEventListener("click", async (event) => {
          const index = Number(event.currentTarget.getAttribute("data-quote-index"));
          const item = state.quotes[index];
          if (!item) return;

          const key = quoteKey(item);

          state.quotes.splice(index, 1);

          if (defaultQuoteKeySet.has(key) && !state.removedDefaultQuotes.includes(key)) {
            state.removedDefaultQuotes.push(key);
          }

          renderQuotes();
          await saveState();
        });
      });
    }

    function renderMorals() {
      if (!remindersList) return;
      remindersList.innerHTML = "";

      state.morals.forEach((item, index) => {
        const article = document.createElement("article");
        article.className = "card";

        article.innerHTML = `
          <h3 class="card-title">${escapeHtml(item.title)}</h3>
          <p>${escapeHtml(item.text)}</p>
          <button class="delete-btn" data-reminder-index="${index}" type="button">Remove</button>
        `;

        remindersList.appendChild(article);
      });

      remindersList.querySelectorAll("[data-reminder-index]").forEach((btn) => {
        btn.addEventListener("click", async (event) => {
          const index = Number(event.currentTarget.getAttribute("data-reminder-index"));
          const item = state.morals[index];
          if (!item) return;

          const key = moralKey(item);

          state.morals.splice(index, 1);

          if (defaultMoralKeySet.has(key) && !state.removedDefaultMorals.includes(key)) {
            state.removedDefaultMorals.push(key);
          }

          renderMorals();
          await saveState();
        });
      });
    }

    quoteForm?.addEventListener("submit", async (event) => {
      event.preventDefault();

      const text = quoteTextInput?.value.trim();
      const author = quoteAuthorInput?.value.trim() || "Personal reminder";
      if (!text) return;

      const newQuote = { text, author };
      const newKey = quoteKey(newQuote);

      state.quotes = dedupeBy([newQuote, ...state.quotes], quoteKey);
      state.removedDefaultQuotes = state.removedDefaultQuotes.filter((key) => key !== newKey);

      renderQuotes();
      quoteForm.reset();
      await saveState();
    });

    reminderForm?.addEventListener("submit", async (event) => {
      event.preventDefault();

      const title = reminderTitleInput?.value.trim();
      const text = reminderTextInput?.value.trim();
      if (!title || !text) return;

      const newReminder = { title, text };
      const newKey = moralKey(newReminder);

      state.morals = dedupeBy([newReminder, ...state.morals], moralKey);
      state.removedDefaultMorals = state.removedDefaultMorals.filter((key) => key !== newKey);

      renderMorals();
      reminderForm.reset();
      await saveState();
    });

    restoreQuotesBtn?.addEventListener("click", async () => {
      state.removedDefaultQuotes = [];
      state.quotes = mergeDefaults(
        state.quotes,
        defaultQuoteItems,
        state.removedDefaultQuotes,
        quoteKey
      );
      state.quotes = dedupeBy(state.quotes, quoteKey);
      renderQuotes();
      await saveState();
    });

    restoreRemindersBtn?.addEventListener("click", async () => {
      state.removedDefaultMorals = [];
      state.morals = mergeDefaults(
        state.morals,
        defaultMoralItems,
        state.removedDefaultMorals,
        moralKey
      );
      state.morals = dedupeBy(state.morals, moralKey);
      renderMorals();
      await saveState();
    });

    window.addEventListener("pagehide", saveStateOnLeave);
    window.addEventListener("beforeunload", saveStateOnLeave);

    async function init() {
      const saved = normalizeState(await loadState());

      state = {
        quotes: mergeDefaults(
          saved.quotes,
          defaultQuoteItems,
          saved.removedDefaultQuotes,
          quoteKey
        ),
        morals: mergeDefaults(
          saved.morals,
          defaultMoralItems,
          saved.removedDefaultMorals,
          moralKey
        ),
        removedDefaultQuotes: [...saved.removedDefaultQuotes],
        removedDefaultMorals: [...saved.removedDefaultMorals],
      };

      state.quotes = dedupeBy(state.quotes, quoteKey);
      state.morals = dedupeBy(state.morals, moralKey);

      initNavView();
      renderQuotes();
      renderMorals();
    }

    init();
  </script>

  <style>
    .nav-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .view-switcher {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.3rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .view-btn {
      border: 0;
      cursor: pointer;
      padding: 0.6rem 0.95rem;
      border-radius: 999px;
      font: inherit;
      color: inherit;
      background: transparent;
      transition: background 0.18s ease, transform 0.18s ease;
    }

    .view-btn:hover,
    .view-btn:focus-visible {
      background: rgba(255, 255, 255, 0.08);
    }

    .view-btn.is-active {
      background: rgba(255, 255, 255, 0.16);
    }

    .quick-links-grid {
      align-items: stretch;
    }

    .quick-links-grid--grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .quick-links-grid--list {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }

    .quick-link-card {
      display: block;
      text-decoration: none;
      color: inherit;
      height: 100%;
      border-radius: 1.35rem;
      overflow: hidden;
    }

    .quick-link-card-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      min-height: 124px;
      height: 100%;
      padding: 1.15rem 1.2rem;
      border-radius: inherit;
    }

    .quick-links-grid--list .quick-link-card-inner {
      min-height: 92px;
      padding: 1rem 1.1rem;
    }

    .quick-link-copy {
      min-width: 0;
      flex: 1 1 auto;
    }

    .quick-link-copy h3 {
      margin: 0 0 0.45rem 0;
      line-height: 1.15;
    }

    .quick-link-copy p {
      margin: 0;
      line-height: 1.45;
    }

    .quick-link-arrow {
      flex: 0 0 auto;
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      font-weight: 700;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.12);
      transition: transform 0.18s ease, background 0.18s ease;
    }

    .quick-link-card:hover .quick-link-arrow,
    .quick-link-card:focus-visible .quick-link-arrow {
      transform: translateX(3px);
      background: rgba(255, 255, 255, 0.14);
    }

    @media (max-width: 720px) {
      .nav-header {
        align-items: stretch;
      }

      .view-switcher {
        width: 100%;
        justify-content: flex-start;
      }

      .quick-links-grid--grid {
        grid-template-columns: 1fr;
      }

      .quick-link-card-inner {
        min-height: 110px;
        padding: 1rem;
      }

      .quick-link-arrow {
        width: 2.25rem;
        height: 2.25rem;
      }
    }
  </style>
</BaseLayout>