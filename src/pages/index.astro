---
import BaseLayout from "../layouts/BaseLayout.astro";
import { quotes, morals } from "../data/home";

const navCards = [
  { href: "/today", title: "Today", text: "Daily dashboard, routines, and priorities." },
  { href: "/fitness", title: "Fitness", text: "Training hub for running and lifting." },
  { href: "/nutrition", title: "Nutrition", text: "Macros, food reminders, and tracking." },
  { href: "/mind", title: "Mind", text: "Recovery, yoga, and calming techniques." },
  { href: "/education", title: "Education", text: "Classes, school goals, and planning." },
  { href: "/work", title: "Work", text: "Tasks, meetings, sections, and deadlines." },
  { href: "/career", title: "Career", text: "Professional direction, projects, and skills." },
  { href: "/hobbies", title: "Hobbies", text: "Personal interests and development." },
];

const defaultQuotes = JSON.stringify(quotes);
const defaultMorals = JSON.stringify(morals);
---

<BaseLayout title="Home | Lifestyle App" description="Personal lifestyle home page">
  <section class="hero">
    <div class="hero-card">
      <p class="kicker">Home</p>
      <h1>Your life, organized simply.</h1>
      <p>Use this page as the main hub. Tap into each area below.</p>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <h2 class="section-title">Navigate</h2>
        <p class="section-subtitle">Choose a section.</p>
      </div>
    </div>

    <div class="grid two">
      {navCards.map((card) => (
        <a href={card.href} class="link-card">
          <h3>{card.title}</h3>
          <p>{card.text}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <details class="dropdown-card" open>
      <summary class="dropdown-summary">
        <div>
          <h2 class="section-title">Featured Quotes</h2>
          <p class="section-subtitle">Open when you want perspective.</p>
        </div>
        <span class="dropdown-icon">+</span>
      </summary>

      <div class="dropdown-body">
        <form id="quote-form" class="input-card">
          <h3 class="card-title">Add Quote</h3>
          <div class="form-stack">
            <input id="quote-text" type="text" placeholder="Quote text" required />
            <input id="quote-author" type="text" placeholder="Author or reminder source" />
            <button type="submit" class="action-btn">Add Quote</button>
          </div>
        </form>

        <div id="quotes-list" class="grid three"></div>
      </div>
    </details>
  </section>

  <section class="section">
    <details class="dropdown-card">
      <summary class="dropdown-summary">
        <div>
          <h2 class="section-title">Core Reminders</h2>
          <p class="section-subtitle">Keep these tucked away until needed.</p>
        </div>
        <span class="dropdown-icon">+</span>
      </summary>

      <div class="dropdown-body">
        <form id="reminder-form" class="input-card">
          <h3 class="card-title">Add Core Reminder</h3>
          <div class="form-stack">
            <input id="reminder-title" type="text" placeholder="Reminder title" required />
            <textarea id="reminder-text" placeholder="Reminder details" rows="4" required></textarea>
            <button type="submit" class="action-btn">Add Reminder</button>
          </div>
        </form>

        <div id="reminders-list" class="grid three"></div>
      </div>
    </details>
  </section>
  <script define:vars={{ defaultQuotes, defaultMorals }}>
    const pageKey = "home";

    const quotesList = document.getElementById("quotes-list");
    const remindersList = document.getElementById("reminders-list");

    const quoteForm = document.getElementById("quote-form");
    const quoteTextInput = document.getElementById("quote-text");
    const quoteAuthorInput = document.getElementById("quote-author");

    const reminderForm = document.getElementById("reminder-form");
    const reminderTitleInput = document.getElementById("reminder-title");
    const reminderTextInput = document.getElementById("reminder-text");

    const defaultQuoteItems = JSON.parse(defaultQuotes);
    const defaultMoralItems = JSON.parse(defaultMorals);

    let state = {
      quotes: [...defaultQuoteItems],
      morals: [...defaultMoralItems],
    };
    
    function mergeDefaults(savedItems, defaultItems, keyFn) {
      const merged = [...(savedItems || [])];

      defaultItems.forEach((defaultItem) => {
        const exists = merged.some((item) => keyFn(item) === keyFn(defaultItem));
        if (!exists) merged.push(defaultItem);
      });

      return merged;
    }

    async function loadState() {
      try {
        const res = await fetch(`/api/state?pageKey=${encodeURIComponent(pageKey)}`, {
          credentials: "include",
        });

        if (!res.ok) return null;

        const data = await res.json();
        return data?.state ?? null;
      } catch (error) {
        console.error("Failed to load state:", error);
        return null;
      }
    }

    async function saveState() {
      try {
        await fetch("/api/state", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ pageKey, state }),
        });
      } catch (error) {
        console.error("Failed to save state:", error);
      }
    }

    function saveStateOnLeave() {
      try {
        navigator.sendBeacon(
          "/api/state",
          new Blob([JSON.stringify({ pageKey, state })], {
            type: "application/json",
          })
        );
      } catch (error) {
        console.error("Failed to save on leave:", error);
      }
    }

    function renderQuotes() {
      if (!quotesList) return;
      quotesList.innerHTML = "";

      state.quotes.forEach((quote, index) => {
        const article = document.createElement("article");
        article.className = "card quote-card soft";

        article.innerHTML = `
          <div>
            <p class="quote-text">“${escapeHtml(quote.text)}”</p>
            <span class="quote-author">${escapeHtml(quote.author || "Personal reminder")}</span>
          </div>
          <button class="delete-btn" data-quote-index="${index}" type="button">Remove</button>
        `;

        quotesList.appendChild(article);
      });

      quotesList.querySelectorAll("[data-quote-index]").forEach((btn) => {
        btn.addEventListener("click", async (event) => {
          const index = Number(event.currentTarget.getAttribute("data-quote-index"));
          state.quotes.splice(index, 1);
          renderQuotes();
          await saveState();
        });
      });
    }

    function renderMorals() {
      if (!remindersList) return;
      remindersList.innerHTML = "";

      state.morals.forEach((item, index) => {
        const article = document.createElement("article");
        article.className = "card";

        article.innerHTML = `
          <h3 class="card-title">${escapeHtml(item.title)}</h3>
          <p>${escapeHtml(item.text)}</p>
          <button class="delete-btn" data-reminder-index="${index}" type="button">Remove</button>
        `;

        remindersList.appendChild(article);
      });

      remindersList.querySelectorAll("[data-reminder-index]").forEach((btn) => {
        btn.addEventListener("click", async (event) => {
          const index = Number(event.currentTarget.getAttribute("data-reminder-index"));
          state.morals.splice(index, 1);
          renderMorals();
          await saveState();
        });
      });
    }

    function escapeHtml(value) {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    quoteForm?.addEventListener("submit", async (event) => {
      event.preventDefault();

      const text = quoteTextInput?.value.trim();
      const author = quoteAuthorInput?.value.trim() || "Personal reminder";
      if (!text) return;

      state.quotes.unshift({ text, author });
      renderQuotes();
      quoteForm.reset();
      await saveState();
    });

    reminderForm?.addEventListener("submit", async (event) => {
      event.preventDefault();

      const title = reminderTitleInput?.value.trim();
      const text = reminderTextInput?.value.trim();
      if (!title || !text) return;

      state.morals.unshift({ title, text });
      renderMorals();
      reminderForm.reset();
      await saveState();
    });

    window.addEventListener("pagehide", saveStateOnLeave);
    window.addEventListener("beforeunload", saveStateOnLeave);

    async function init() {
      renderQuotes();
      renderMorals();

      const saved = await loadState();

      state = {
        quotes: mergeDefaults(
          saved?.quotes,
          defaultQuoteItems,
          (q) => `${q.text}::${q.author || ""}`
        ),
        morals: mergeDefaults(
          saved?.morals,
          defaultMoralItems,
          (m) => `${m.title}::${m.text}`
        ),
      };

      renderQuotes();
      renderMorals();
    }

    init();
  </script>
</BaseLayout>