---
/**
 * Education page.
 * Used to manage school-related work such as classes,
 * assignments, deadlines, sections, and academic tasks.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SurfaceCard from "../components/SurfaceCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import FormCard from "../components/FormCard.astro";
import Button from "../components/Button.astro";
import { educationClientConfig } from "../config/pages/education";
---

<BaseLayout title="Education | Lifestyle App" description="Education dashboard">
  <PageHero
    kicker="Education"
    title="Academic dashboard"
    description="Track classes, assignments, due dates, grade weight, and what needs attention first."
  />

  <section class="section">
    <div class="education-shell">
      <details class="dropdown-card surface-dropdown education-panel" open>
        <summary>
          <div>
            <h2 class="section-title">Due This Week</h2>
            <p class="section-subtitle">Closest deadlines first.</p>
          </div>
          <span class="dropdown-arrow">⌄</span>
        </summary>
        <div class="dropdown-content">
          <div id="due-this-week" class="education-list"></div>
        </div>
      </details>

      <details class="dropdown-card surface-dropdown education-panel" open>
        <summary>
          <div>
            <h2 class="section-title">All Upcoming</h2>
            <p class="section-subtitle">Sorted by due date.</p>
          </div>
          <span class="dropdown-arrow">⌄</span>
        </summary>
        <div class="dropdown-content">
          <div id="all-upcoming" class="education-list"></div>
        </div>
      </details>

      <FormCard
        title="Add Assignment"
        subtitle="Add work by class, due date, and optional start or due times."
        formId="assignment-form"
        submitLabel="Add Assignment"
      >
        <div class="edu-form-grid">
          <label class="edu-label">
            <span>Assignment name</span>
            <input type="text" id="assignment-name" required placeholder="Homework 4" />
          </label>

          <label class="edu-label">
            <span>Due date</span>
            <input type="date" id="assignment-due" required />
          </label>

          <label class="edu-label">
            <span>Start time (optional)</span>
            <input type="time" id="assignment-start-time" />
          </label>

          <label class="edu-label">
            <span>Due time (optional)</span>
            <input type="time" id="assignment-due-time" />
          </label>

          <label class="edu-label">
            <span>Class</span>
            <select id="assignment-class" required>
              <option value="">Select a class</option>
            </select>
          </label>

          <label class="edu-label">
            <span>Percent of grade (optional)</span>
            <input
              type="number"
              id="assignment-weight"
              min="0"
              max="100"
              step="0.1"
              placeholder="10"
            />
          </label>
        </div>
      </FormCard>

      <SurfaceCard className="education-panel">
        <SectionHeader
          title="Classes"
          subtitle="Create classes with color tags."
        >
          <Button id="restore-classes-btn" type="button">Restore Defaults</Button>
        </SectionHeader>

        <FormCard formId="class-form" submitLabel="Add Class" compact={true}>
          <div class="edu-form-grid class-grid">
            <label class="edu-label">
              <span>Class name</span>
              <input type="text" id="class-name" required placeholder="ECE 30200" />
            </label>

            <div class="edu-label">
              <span>Color</span>
              <input type="hidden" id="class-color" value="#2f5d62" />

              <div class="color-picker-row" id="class-color-picker">
                <button type="button" class="color-swatch is-selected" data-color="#2f5d62" style="background:#2f5d62;"></button>
                <button type="button" class="color-swatch" data-color="#111827" style="background:#111827;"></button>
                <button type="button" class="color-swatch" data-color="#6b7280" style="background:#6b7280;"></button>
                <button type="button" class="color-swatch" data-color="#2563eb" style="background:#2563eb;"></button>
                <button type="button" class="color-swatch" data-color="#38bdf8" style="background:#38bdf8;"></button>
                <button type="button" class="color-swatch" data-color="#16a34a" style="background:#16a34a;"></button>
                <button type="button" class="color-swatch" data-color="#4ade80" style="background:#4ade80;"></button>
                <button type="button" class="color-swatch" data-color="#dc2626" style="background:#dc2626;"></button>
                <button type="button" class="color-swatch" data-color="#f87171" style="background:#f87171;"></button>
                <button type="button" class="color-swatch" data-color="#ea580c" style="background:#ea580c;"></button>
                <button type="button" class="color-swatch" data-color="#fb923c" style="background:#fb923c;"></button>
                <button type="button" class="color-swatch" data-color="#fde047" style="background:#fde047;"></button>
                <button type="button" class="color-swatch" data-color="#6a3fa0" style="background:#6a3fa0;"></button>
                <button type="button" class="color-swatch" data-color="#a78bfa" style="background:#a78bfa;"></button>
                <button type="button" class="color-swatch" data-color="#db2777" style="background:#db2777;"></button>
                <button type="button" class="color-swatch" data-color="#7a4b2a" style="background:#7a4b2a;"></button>
              </div>
            </div>
          </div>
        </FormCard>

        <div id="class-list" class="class-list"></div>
      </SurfaceCard>

      <details class="card education-panel completed-panel">
        <summary class="completed-summary">
          <span>Completed</span>
          <span id="completed-count" class="completed-count">0</span>
        </summary>
        <div id="completed-list" class="education-list completed-list"></div>
      </details>
    </div>
  </section>
</BaseLayout>


  <script id="education-page-config" type="application/json" set:html={JSON.stringify(educationClientConfig)} />

  <script>
    import { initEducationPage } from "../lib/client/educationPage";

    const configElement = document.getElementById("education-page-config");
    const config = JSON.parse(configElement?.textContent || "{}");

    initEducationPage(config);
  </script>
