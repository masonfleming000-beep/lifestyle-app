---
interface Props {
  align?: "start" | "end";
  class?: string;
}

const { align = "end", class: className = "" } = Astro.props;
---

<div class:list={["form-actions-row", `form-actions-${align}`, className]}>
  <slot />
</div>

<style>
  .form-actions-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .form-actions-start {
    justify-content: flex-start;
  }

  .form-actions-end {
    justify-content: flex-end;
  }
</style>
