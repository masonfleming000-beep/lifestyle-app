---
import ExpandableSection from "../ExpandableSection.astro";
import ActionBar from "../ActionBar.astro";

interface ActionItem {
  label: string;
  id?: string;
  type?: "button" | "submit" | "reset";
  variant?: "primary" | "secondary" | "danger";
  disabled?: boolean;
}

interface Props {
  kicker?: string;
  title: string;
  subtitle?: string;
  open?: boolean;
  listId: string;
  listClass?: string;
  actions?: readonly ActionItem[];
}

const {
  kicker = "",
  title,
  subtitle = "",
  open = false,
  listId,
  listClass = "",
  actions = [],
} = Astro.props;
---

<ExpandableSection kicker={kicker} title={title} subtitle={subtitle} open={open}>
  <ActionBar actions={actions} align="end" />
  <ul id={listId} class:list={["list-clean", "editable-list", listClass]}></ul>
  <slot />
</ExpandableSection>
