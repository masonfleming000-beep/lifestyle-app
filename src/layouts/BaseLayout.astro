---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Lifestyle App",
  description = "A clean mobile-first lifestyle dashboard.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <Navbar />
    <main class="site-shell">
      <slot />
    </main>

    <script>
      import { App } from "@capacitor/app";
      import { Browser } from "@capacitor/browser";

      App.addListener("appUrlOpen", async ({ url }: { url: string }) => {
        if (url.startsWith("com.lifestyle.app://auth/success")) {
          await Browser.close();
          window.location.href = "/dashboard";
        }
      });
    </script>

    <script is:inline>
      (() => {
        const root = document.documentElement;
        const mode = localStorage.getItem("profile-theme-mode") || "system";
        const accent = localStorage.getItem("profile-theme-accent") || "default";
        const textSize = localStorage.getItem("profile-theme-text-size") || "md";

        root.dataset.theme = mode;
        root.dataset.accent = accent;
        root.dataset.textSize = textSize;
      })();
    </script>
  </body>
</html>