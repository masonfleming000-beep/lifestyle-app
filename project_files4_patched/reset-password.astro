---
import BaseLayout from "../layouts/BaseLayout.astro";

const token = Astro.url.searchParams.get("token") || "";
---

<BaseLayout title="Reset Password | Lifestyle App" description="Choose a new password">
  <section class="auth-page">
    <div class="auth-shell">
      <div class="auth-intro">
        <p class="kicker">Lifestyle App</p>
        <h1>Choose a new password.</h1>
        <p>Enter a new password for your account.</p>
      </div>

      <div class="auth-card">
        <h2 class="auth-title">Reset password</h2>
        <p id="reset-message" class="auth-note" style="display:none;"></p>

        <form id="reset-form" class="auth-form">
          <input type="hidden" name="token" value={token} />

          <label for="password">New password</label>
          <input id="password" name="password" type="password" minlength="12" required />

          <button type="submit" class="auth-button">Reset password</button>
        </form>

        <p class="auth-footer">
          <a href="/login">Back to login</a>
        </p>
      </div>
    </div>
  </section>

  <script is:inline>
    const resetForm = document.getElementById("reset-form");
    const resetMessage = document.getElementById("reset-message");

    function setMessage(text, isError = false) {
      if (!resetMessage) return;
      resetMessage.textContent = text;
      resetMessage.style.display = text ? "block" : "none";
      resetMessage.style.color = isError ? "#b42318" : "";
    }

    resetForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      setMessage("");

      const formData = new FormData(resetForm);
      const token = String(formData.get("token") || "");
      const password = String(formData.get("password") || "");

      const submitButton = resetForm.querySelector('button[type="submit"]');
      if (submitButton) submitButton.disabled = true;

      try {
        const response = await fetch("/api/auth/reset-password", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ token, password }),
        });

        const data = await response.json().catch(() => ({}));

        if (!response.ok || !data.ok) {
          setMessage(data.error || "Reset failed.", true);
          return;
        }

        setMessage(data.message || "Password reset successful. You can now sign in.");
      } catch (error) {
        console.error("Reset password request failed:", error);
        setMessage("Unable to reach the server.", true);
      } finally {
        if (submitButton) submitButton.disabled = false;
      }
    });
  </script>
</BaseLayout>