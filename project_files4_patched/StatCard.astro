---
interface Props {
  label: string;
  value: string | number;
  description?: string;
  href?: string;
}

const { label, value, description = "", href = "" } = Astro.props;
const Tag = href ? "a" : "article";
---

<Tag class="stat-card surface-section" href={href || undefined}>
  <div class="stat-card-top">
    <p class="stat-card-label">{label}</p>
    <h3 class="stat-card-value">{value}</h3>
  </div>

  {description && <p class="stat-card-description">{description}</p>}
</Tag>

<style>
  .stat-card-label,
  .stat-card-value,
  .stat-card-description {
    margin: 0;
  }

  .stat-card-value {
    margin-top: 0.1rem;
  }

  .stat-card-description {
    margin-top: 0.35rem;
  }
</style>