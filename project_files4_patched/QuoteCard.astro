---
interface Props {
  href?: string;
  title: string;
  text?: string;
}

const { href = "", title, text = "" } = Astro.props;
const Tag = href ? "a" : "article";
---

<Tag href={href || undefined} class="quote-card surface-section">
  <h3>{title}</h3>
  {text && <p>{text}</p>}
</Tag>

<style>
  .quote-card {
    display: block;
    text-decoration: none;
    color: inherit;

    padding: 1.1rem;
    border-radius: 20px;

    /* 🔥 THEME SYSTEM */
    background: var(--quote-card-surface-color, var(--resolved-section-color));
    border: 1px solid var(--border-color);
    box-shadow: var(--card-shadow);

    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  }

  .quote-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--card-shadow-hover);
  }

  .quote-card h3,
  .quote-card p {
    margin: 0;
  }

  .quote-card h3 {
    font-weight: 600;
    color: var(--text-primary);
  }

  .quote-card p {
    margin-top: 0.5rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
  }
</style>