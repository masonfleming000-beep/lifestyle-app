---
import PublicLayout from "../../layouts/PublicLayout.astro";
import CareerPortfolioPreviewShell from "../../components/career/CareerPortfolioPreviewShell.astro";
import {
  careerInformationPageKey,
  careerPortfolioSectionTitles,
} from "../../config/pages/careerShared";

const useTempPublicPortfolio = import.meta.env.TEMP_PUBLIC_PORTFOLIO_ONLY === "true";
const shareLinkBaseUrl = useTempPublicPortfolio
  ? import.meta.env.TEMP_PUBLIC_PORTFOLIO_URL || import.meta.env.PUBLIC_APP_URL || import.meta.env.APP_URL || ""
  : import.meta.env.PUBLIC_APP_URL || import.meta.env.APP_URL || "";
const assetBaseUrl = import.meta.env.PUBLIC_APP_URL || import.meta.env.APP_URL || shareLinkBaseUrl || "";
---

<PublicLayout title="Portfolio Preview | Lifestyle App" description="Portfolio preview">
  <CareerPortfolioPreviewShell
    pageKey={careerInformationPageKey}
    sectionTitles={careerPortfolioSectionTitles}
    shareBasePath="/portfolio"
    shareLinkBaseUrl={shareLinkBaseUrl}
    assetBaseUrl={assetBaseUrl}
  />
</PublicLayout>
