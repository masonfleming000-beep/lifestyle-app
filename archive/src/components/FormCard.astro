---
/**
 * Standardized form container for add/edit flows.
 */
interface Props {
  title?: string;
  subtitle?: string;
  kicker?: string;
  formId?: string;
  submitLabel?: string;
  submitVariant?: "primary" | "secondary";
  compact?: boolean;
  className?: string;
  formClass?: string;
}

const {
  title = "",
  subtitle = "",
  kicker = "",
  formId = "",
  submitLabel = "Save",
  submitVariant = "primary",
  compact = false,
  className = "",
  formClass = "",
} = Astro.props;
---

<article class:list={["input-card", "form-card", compact && "form-card-compact", className]}>
  {(title || subtitle || kicker) && (
    <div class="form-card-header">
      <div class="form-card-copy">
        {kicker && <p class="kicker">{kicker}</p>}
        {title && <h3 class="section-title">{title}</h3>}
        {subtitle && <p class="section-subtitle">{subtitle}</p>}
      </div>

      <slot name="header-actions" />
    </div>
  )}

  <form id={formId || undefined} class:list={["todo-form", "form-stack", "form-card-form", formClass]}>
    <slot />

    <div class="form-card-actions">
      <slot name="actions">
        <button type="submit" class={submitVariant === "secondary" ? "button-secondary" : "button-primary"}>
          {submitLabel}
        </button>
      </slot>
    </div>
  </form>
</article>

<style>
  .form-card {
    display: grid;
    gap: 0.9rem;
  }

  .form-card-compact {
    padding: 0.85rem;
  }

  .form-card-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
  }

  .form-card-copy {
    min-width: 0;
  }

  .form-card-form,
  .form-card-actions {
    display: grid;
    gap: 0.75rem;
  }
</style>
