---
import type { FieldConfig } from '../../lib/ui/types';
interface Props { field: FieldConfig; }
const { field } = Astro.props;
---
<label class="form-stack">
  <span>{field.label}</span>
  <textarea id={field.id} name={field.name} placeholder={field.placeholder}>{String(field.value ?? '')}</textarea>
  {field.helpText && <small>{field.helpText}</small>}
</label>
