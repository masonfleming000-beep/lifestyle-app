---
interface Props {
  title?: string;
  subtitle?: string;
  kicker?: string;
  padded?: boolean;
}
const { title = '', subtitle = '', kicker = '', padded = true } = Astro.props;
---
<article class:list={["surface-card", "surface-section", padded && 'surface-card-padded']}>
  {(title || subtitle || kicker) && (
    <header class="surface-card-header">
      <div>
        {kicker && <p class="kicker">{kicker}</p>}
        {title && <h2 class="section-title">{title}</h2>}
        {subtitle && <p class="section-subtitle">{subtitle}</p>}
      </div>
      <slot name="actions" />
    </header>
  )}
  <slot />
</article>
<style>
  .surface-card { border: 1px solid var(--border-soft); border-radius: var(--radius); background: var(--card-surface-color, var(--resolved-section-color, var(--section-color))); box-shadow: var(--card-shadow); }
  .surface-card-padded { padding: 1rem; }
  .surface-card-header { display:flex; align-items:end; justify-content:space-between; gap:1rem; margin-bottom:0.75rem; }
</style>
