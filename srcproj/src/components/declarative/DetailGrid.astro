---
interface DetailItem { label: string; value: string; }
interface Props { title?: string; items?: DetailItem[]; }
const { title = '', items = [] } = Astro.props;
---
<section class="input-card detail-grid-card">
  {title && <h3 class="section-title">{title}</h3>}
  <dl class="detail-grid">
    {items.map((item) => (
      <div>
        <dt>{item.label}</dt>
        <dd>{item.value}</dd>
      </div>
    ))}
  </dl>
</section>
<style>
  .detail-grid { display:grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap:0.75rem; margin:0; }
  dt { font-size:0.8rem; color:var(--text-muted); }
  dd { margin:0.2rem 0 0; }
</style>
