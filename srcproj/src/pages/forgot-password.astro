---
/**
 * Forgot password page.
 * Allows a user to request a password reset
 * by submitting their account email or login information.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import AuthPage from "../components/auth/AuthPage.astro";
import { forgotPasswordClientConfig, forgotPasswordPageConfig } from "../config/pages/auth";
---

<BaseLayout title={forgotPasswordPageConfig.title} description={forgotPasswordPageConfig.description}>
  <AuthPage config={forgotPasswordPageConfig} />

  <script id="forgot-password-page-config" type="application/json" set:html={JSON.stringify(forgotPasswordClientConfig)} />

  <script>
    import { initAuthFormPage } from "../lib/client/authForms";

    const configElement = document.getElementById("forgot-password-page-config");
    const config = JSON.parse(configElement?.textContent || "{}");

    initAuthFormPage(config);
  </script>
</BaseLayout>
